{
  "name": "synergygig/web",
  "description": "SynergyGig - HR & Workforce Management Web Platform (Symfony 6.4)",
  "type": "project",
  "license": "proprietary",
  "require": {
    "php": ">=8.1",
    "symfony/console": "6.4.*",
    "symfony/dotenv": "6.4.*",
    "symfony/framework-bundle": "6.4.*",
    "symfony/yaml": "6.4.*",
    "symfony/orm-pack": "^2.5",
    "symfony/maker-bundle": "^1.53",
    "symfony/security-bundle": "6.4.*",
    "symfony/twig-bundle": "6.4.*",
    "symfony/translation": "6.4.*",
    "symfony/validator": "6.4.*",
    "symfony/web-profiler-bundle": "6.4.*",
    "symfony/monolog-bundle": "^3.8",
    "symfony/messenger": "6.4.*",
    "symfony/http-client": "6.4.*",
    "symfony/asset": "6.4.*",
    "symfony/runtime": "6.4.*",
    "symfony/form": "^6.4",
    "symfony/mime": "^6.4",
    "symfony/mailer": "6.4.*",
    "knplabs/knp-paginator-bundle": "^6.10"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0",
    "symfony/debug-bundle": "6.4.*",
    "phpstan/phpstan": "^1.10",
    "phpstan/extension-installer": "^1.3"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "App\\Tests\\": "tests/"
    }
  },
  "scripts": {
  },
  "conflict": {
    "symfony/symfony": "*"
  },
  "extra": {
    "symfony": {
      "allow-contrib": true,
      "require": "6.4.*"
    }
  },
  "config": {
    "allow-plugins": {
      "phpstan/extension-installer": true,
      "symfony/runtime": true
    }
  }
}
