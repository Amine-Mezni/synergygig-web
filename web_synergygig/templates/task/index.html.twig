{% extends 'layouts/admin.html.twig' %}

{% block page_title %}Tasks{% endblock %}

{% block header_actions %}
    <a href="{{ path('app_task_new') }}" class="btn btn-primary btn-sm">+ New Task</a>
{% endblock %}

{% block content %}
{# Search & Filter bar #}
<div class="card" style="padding:var(--space-md) var(--space-lg);margin-bottom:var(--space-lg);display:flex;align-items:center;gap:var(--space-md)">
    <form method="get" action="{{ path('app_task_index') }}" style="flex:1;display:flex;align-items:center;gap:var(--space-md)">
        <div style="position:relative;flex:1">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--text-muted)" stroke-width="2" style="position:absolute;left:.75rem;top:50%;transform:translateY(-50%)"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <input type="text" name="q" value="{{ app.request.query.get('q') }}" placeholder="Search tasks..." class="form-control" style="padding-left:2.25rem">
        </div>
        <select name="status" class="form-control form-select" style="width:auto;min-width:120px">
            <option value="">All Status</option>
            <option value="TODO" {{ app.request.query.get('status') == 'TODO' ? 'selected' }}>TODO</option>
            <option value="IN_PROGRESS" {{ app.request.query.get('status') == 'IN_PROGRESS' ? 'selected' }}>IN PROGRESS</option>
            <option value="SUBMITTED" {{ app.request.query.get('status') == 'SUBMITTED' ? 'selected' }}>SUBMITTED</option>
            <option value="DONE" {{ app.request.query.get('status') == 'DONE' ? 'selected' }}>DONE</option>
        </select>
        <button type="submit" class="btn btn-secondary btn-sm">Filter</button>
    </form>
</div>

<div class="card">
    {% if tasks|length > 0 %}
    <div class="table-wrap">
        <table class="table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Title</th>
                    <th>Project</th>
                    <th>Assigned To</th>
                    <th>Status</th>
                    <th>Priority</th>
                    <th>Due Date</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for t in tasks %}
                <tr>
                    <td class="text-muted">{{ t.id }}</td>
                    <td><a href="{{ path('app_task_show', {id: t.id}) }}" style="color:var(--accent-blue);font-weight:600">{{ t.title }}</a></td>
                    <td>{% if t.project %}<a href="{{ path('app_project_show', {id: t.project.id}) }}" style="color:var(--text-secondary)">{{ t.project.name }}</a>{% else %}<span class="text-muted">—</span>{% endif %}</td>
                    <td>
                        {% if t.assignedTo %}
                            <div style="display:flex;align-items:center;gap:0.5rem">
                                <div class="avatar avatar--sm">{{ t.assignedTo.firstName|first }}{{ t.assignedTo.lastName|first }}</div>
                                {{ t.assignedTo.firstName }} {{ t.assignedTo.lastName }}
                            </div>
                        {% else %}<span class="text-muted">Unassigned</span>{% endif %}
                    </td>
                    <td>
                        {% set sc = {'TODO': 'blue', 'IN_PROGRESS': 'orange', 'DONE': 'green'} %}
                        <span class="badge badge--{{ sc[t.status] ?? 'blue' }}">{{ t.status ?? 'N/A' }}</span>
                    </td>
                    <td>
                        {% set pc = {'LOW': 'green', 'MEDIUM': 'blue', 'HIGH': 'orange'} %}
                        <span class="badge badge--{{ pc[t.priority] ?? 'blue' }}">{{ t.priority ?? '—' }}</span>
                    </td>
                    <td>{{ t.dueDate ? t.dueDate|date('M d, Y') : '—' }}</td>
                    <td>
                        <details class="crud-actions-menu">
                            <summary class="btn btn-ghost btn-sm" title="Actions"><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="5" r="2"/><circle cx="12" cy="12" r="2"/><circle cx="12" cy="19" r="2"/></svg></summary>
                            <div class="crud-actions-dropdown">
                                <a href="{{ path('app_task_show', {id: t.id}) }}" class="crud-action-item"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg> View</a>
                                <a href="{{ path('app_task_edit', {id: t.id}) }}" class="crud-action-item"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg> Edit</a>
                                <form method="post" action="{{ path('app_task_delete', {id: t.id}) }}" onsubmit="return confirm('Delete this task?')">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ t.id) }}">
                                    <button type="submit" class="crud-action-item crud-action-danger"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg> Delete</button>
                                </form>
                            </div>
                        </details>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    {% else %}
    <div style="text-align:center;padding:3rem">
        <p class="text-muted">No tasks yet.</p>
        <a href="{{ path('app_task_new') }}" class="btn btn-primary" style="margin-top:1rem">+ Create Task</a>
    </div>
    {% endif %}
</div>

{% if pagination is defined %}{% include 'components/_pagination.html.twig' %}{% endif %}
{% endblock %}
