{% extends 'layouts/admin.html.twig' %}

{% block title %}HR Dashboard | SynergyGig{% endblock %}
{% block page_title %}HR Dashboard{% endblock %}

{% block content %}
{# ── Stat Cards Row ── #}
<div style="display:grid;grid-template-columns:repeat(5,1fr);gap:var(--space-lg);margin-bottom:var(--space-xl)">
    {% set cards = [
        {label:'Total Employees', value:stats.employees, icon:'<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/>', color:'#2C666E', route:'app_user_index'},
        {label:'Departments', value:stats.departments, icon:'<path d="M2 20a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V8l-7 5V8l-7 5V4a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2Z"/>', color:'#7C3AED', route:'app_department_index'},
        {label:'Present Today', value:stats.present_today, icon:'<path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>', color:'#059669', route:'app_attendance_index'},
        {label:'Pending Leaves', value:stats.pending_leaves, icon:'<path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/>', color:'#D97706', route:'app_leave_index'},
        {label:'Pending Payroll', value:stats.pending_payroll, icon:'<line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>', color:'#DC2626', route:'app_payroll_index'}
    ] %}
    {% for c in cards %}
    <a href="{{ path(c.route) }}" class="card" style="padding:var(--space-lg);text-align:center;text-decoration:none;color:inherit">
        <div style="width:48px;height:48px;border-radius:var(--radius-lg);background:{{ c.color }}22;display:flex;align-items:center;justify-content:center;margin:0 auto var(--space-md)">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="{{ c.color }}" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">{{ c.icon|raw }}</svg>
        </div>
        <div style="font-size:2rem;font-weight:700;color:var(--text-primary)">{{ c.value }}</div>
        <div class="text-muted" style="font-size:.875rem">{{ c.label }}</div>
    </a>
    {% endfor %}
</div>

{# ── Two Column: Holidays + Team Building ── #}
<div style="display:grid;grid-template-columns:1fr 1fr;gap:var(--space-xl);margin-bottom:var(--space-xl)">
    {# Public Holidays #}
    <div class="card" style="padding:var(--space-xl)">
        <div style="display:flex;align-items:center;gap:var(--space-sm);margin-bottom:var(--space-lg)">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--accent-primary)" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            <h2 style="font-size:1.125rem;color:var(--text-primary);margin:0">Upcoming Public Holidays</h2>
        </div>
        {% if holidays|length > 0 %}
            {% for h in holidays %}
            <div style="display:flex;justify-content:space-between;align-items:center;padding:var(--space-md) 0;{% if not loop.last %}border-bottom:1px solid var(--border-primary);{% endif %}">
                <div>
                    <div style="color:var(--text-primary);font-weight:500">{{ h.name }}</div>
                    <div class="text-muted" style="font-size:.8rem">{{ h.date_obj|date('M d, Y') }} · {{ h.type }}</div>
                </div>
                <span class="badge" style="background:{% if h.days_until <= 7 %}#DC262622;color:#DC2626{% elseif h.days_until <= 30 %}#D9770622;color:#D97706{% else %}var(--accent-primary)22;color:var(--accent-primary){% endif %}">
                    {% if h.days_until == 0 %}Today{% elseif h.days_until == 1 %}Tomorrow{% else %}{{ h.days_until }} days{% endif %}
                </span>
            </div>
            {% endfor %}
        {% else %}
            <p class="text-muted" style="text-align:center;padding:var(--space-xl) 0">No upcoming holidays</p>
        {% endif %}
    </div>

    {# Team Building Suggestion #}
    <div class="card" style="padding:var(--space-xl)">
        <div style="display:flex;align-items:center;gap:var(--space-sm);margin-bottom:var(--space-lg);justify-content:space-between">
            <div style="display:flex;align-items:center;gap:var(--space-sm)">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--accent-primary)" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                <h2 style="font-size:1.125rem;color:var(--text-primary);margin:0">Team Building Suggestion</h2>
            </div>
            <button id="refreshActivityBtn" style="background:none;border:none;font-size:1.2rem;cursor:pointer;padding:4px;color:var(--text-muted);transition:all 0.2s" title="Get new suggestion">🔄</button>
        </div>
        <div style="text-align:center;padding:var(--space-lg) 0">
            <div id="activityIcon" style="font-size:3rem;margin-bottom:var(--space-md)">🔄</div>
            <h3 id="activityTitle" style="color:var(--text-primary);font-size:1.25rem;margin:0 0 var(--space-sm)">Loading suggestion...</h3>
            <p id="activityDesc" class="text-muted" style="max-width:320px;margin:0 auto var(--space-lg)">Fetching from activity database...</p>
            <span id="activityMeta" class="badge badge--blue" style="font-size:.875rem;padding:.5rem 1.25rem">⏳ Finding activities...</span>
        </div>
    </div>
</div>

<script>
(function() {
    const iconEl = document.getElementById('activityIcon');
    const titleEl = document.getElementById('activityTitle');
    const descEl = document.getElementById('activityDesc');
    const metaEl = document.getElementById('activityMeta');
    const refreshBtn = document.getElementById('refreshActivityBtn');

    const typeIcons = {
        'education': '📚',
        'recreational': '🎮',
        'social': '🎉',
        'diy': '🛠️',
        'charity': '❤️',
        'cooking': '🍳',
        'relaxation': '😌',
        'music': '🎵',
        'busywork': '📋',
    };

    const fallbackActivities = [
        {activity: 'Escape Room Challenge', type: 'recreational', participants: 6},
        {activity: 'Team Cooking Workshop', type: 'cooking', participants: 8},
        {activity: 'Outdoor Hiking Adventure', type: 'recreational', participants: 10},
        {activity: 'Office Hackathon Day', type: 'education', participants: 12},
        {activity: 'Board Game Tournament', type: 'social', participants: 8},
        {activity: 'Volunteer at a Local Shelter', type: 'charity', participants: 5},
        {activity: 'Group Yoga Session', type: 'relaxation', participants: 15},
        {activity: 'Karaoke Night', type: 'music', participants: 10},
        {activity: 'Office Trivia Quiz', type: 'social', participants: 12},
        {activity: 'DIY Workshop — Build Something Together', type: 'diy', participants: 6},
        {activity: 'Photography Walk', type: 'recreational', participants: 8},
        {activity: 'Team Lunch Potluck', type: 'cooking', participants: 15},
    ];

    function showActivity(data) {
        const icon = typeIcons[data.type] || '💡';
        const title = data.activity || 'Activity Not Found';
        const type = data.type ? data.type.charAt(0).toUpperCase() + data.type.slice(1) : 'General';
        const participants = data.participants || 'Any number';

        iconEl.textContent = icon;
        titleEl.textContent = title;
        descEl.textContent = 'This activity is perfect for building team cohesion and morale.';
        metaEl.innerHTML = `🎯 Type: <strong>${type}</strong> • 👥 Best for: <strong>${participants}</strong> ${typeof participants === 'number' && participants === 1 ? 'person' : 'people'}`;

        refreshBtn.style.opacity = '1';
        refreshBtn.disabled = false;
    }

    function useFallback() {
        const fb = fallbackActivities[Math.floor(Math.random() * fallbackActivities.length)];
        showActivity(fb);
    }

    function fetchActivity() {
        titleEl.textContent = 'Loading...';
        descEl.textContent = 'Finding the perfect team activity...';
        metaEl.innerHTML = '⏳ Fetching...';
        refreshBtn.style.opacity = '0.5';
        refreshBtn.disabled = true;

        const controller = new AbortController();
        const timeout = setTimeout(() => controller.abort(), 5000);

        fetch('https://bored-api.appbrewery.com/random', {signal: controller.signal})
            .then(r => { clearTimeout(timeout); if (!r.ok) throw new Error('HTTP ' + r.status); return r.json(); })
            .then(data => {
                if (data && data.activity) {
                    showActivity(data);
                } else {
                    useFallback();
                }
            })
            .catch(() => {
                clearTimeout(timeout);
                useFallback();
            });
    }

    refreshBtn.addEventListener('click', fetchActivity);
    window.addEventListener('load', fetchActivity);
})();
</script>

{# ── Two Column: Recent Leaves + Today's Attendance ── #}
<div style="display:grid;grid-template-columns:1fr 1fr;gap:var(--space-xl)">
    {# Recent Leave Requests #}
    <div class="card" style="padding:var(--space-xl)">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:var(--space-lg)">
            <h2 style="font-size:1.125rem;color:var(--text-primary);margin:0">Recent Leave Requests</h2>
            <a href="{{ path('app_leave_index') }}" class="text-muted" style="font-size:.8rem;text-decoration:none">View All →</a>
        </div>
        <table class="table">
            <thead>
                <tr><th>Employee</th><th>Type</th><th>Status</th><th>From</th></tr>
            </thead>
            <tbody>
                {% for leave in recent_leaves %}
                <tr>
                    <td>
                        {% if leave.user %}
                            {{ leave.user.firstName ?? '' }} {{ leave.user.lastName ?? '' }}
                        {% else %}
                            <span class="text-muted">—</span>
                        {% endif %}
                    </td>
                    <td>{{ leave.type ?? '—' }}</td>
                    <td>
                        {% set s = leave.status|default('—') %}
                        <span class="badge {% if s == 'APPROVED' %}badge--green{% elseif s == 'REJECTED' %}badge--red{% else %}badge--yellow{% endif %}">{{ s }}</span>
                    </td>
                    <td>{{ leave.startDate ? leave.startDate|date('M d') : '—' }}</td>
                </tr>
                {% else %}
                <tr><td colspan="4" class="text-muted" style="text-align:center;padding:var(--space-xl)">No recent leave requests</td></tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    {# Today's Attendance #}
    <div class="card" style="padding:var(--space-xl)">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:var(--space-lg)">
            <h2 style="font-size:1.125rem;color:var(--text-primary);margin:0">Today's Attendance</h2>
            <a href="{{ path('app_attendance_index') }}" class="text-muted" style="font-size:.8rem;text-decoration:none">View All →</a>
        </div>
        <table class="table">
            <thead>
                <tr><th>Employee</th><th>Check In</th><th>Status</th></tr>
            </thead>
            <tbody>
                {% for att in today_attendance %}
                <tr>
                    <td>
                        {% if att.user %}
                            {{ att.user.firstName ?? '' }} {{ att.user.lastName ?? '' }}
                        {% else %}
                            <span class="text-muted">—</span>
                        {% endif %}
                    </td>
                    <td>{{ att.checkIn ? att.checkIn|date('H:i') : '—' }}</td>
                    <td><span class="badge badge--green">Present</span></td>
                </tr>
                {% else %}
                <tr><td colspan="3" class="text-muted" style="text-align:center;padding:var(--space-xl)">No attendance records today</td></tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
