{% extends 'layouts/admin.html.twig' %}

{% block page_title %}Payroll{% endblock %}

{% block header_actions %}
    {% if is_granted('ROLE_HR') %}
    <a href="{{ path('app_export_payroll_csv') }}" class="btn btn-ghost btn-sm" title="Export CSV">📥 CSV</a>
    <a href="{{ path('app_payroll_generate') }}" class="btn btn-primary btn-sm">⚡ Auto-Generate</a>
    <a href="{{ path('app_payroll_new') }}" class="btn btn-ghost btn-sm">+ Manual Entry</a>
    {% endif %}
{% endblock %}

{% block content %}
{# Filter bar #}
<div class="card" style="padding:var(--space-md) var(--space-lg);margin-bottom:var(--space-lg);display:flex;align-items:center;gap:var(--space-md)">
    <form method="get" action="{{ path('app_payroll_index') }}" style="flex:1;display:flex;align-items:center;gap:var(--space-md)">
        <select name="status" class="form-control form-select" style="width:auto;min-width:120px">
            <option value="">All Status</option>
            <option value="PENDING" {{ app.request.query.get('status') == 'PENDING' ? 'selected' }}>Pending</option>
            <option value="PAID" {{ app.request.query.get('status') == 'PAID' ? 'selected' }}>Paid</option>
        </select>
        <button type="submit" class="btn btn-secondary btn-sm">Filter</button>
    </form>
</div>

<div class="card">
    {% if payrolls|length > 0 %}
    <div class="table-wrap">
        <table class="table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Employee</th>
                    <th>Period</th>
                    <th>Base Salary</th>
                    <th>Bonus</th>
                    <th>Deductions</th>
                    <th>Net Salary</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% set months = {1:'Jan',2:'Feb',3:'Mar',4:'Apr',5:'May',6:'Jun',7:'Jul',8:'Aug',9:'Sep',10:'Oct',11:'Nov',12:'Dec'} %}
                {% for p in payrolls %}
                <tr>
                    <td class="text-muted">{{ p.id }}</td>
                    <td>
                        {% if p.user %}
                            <div style="display:flex;align-items:center;gap:0.5rem">
                                <div class="avatar avatar--sm">{{ p.user.firstName|first }}{{ p.user.lastName|first }}</div>
                                {{ p.user.firstName }} {{ p.user.lastName }}
                            </div>
                        {% else %}—{% endif %}
                    </td>
                    <td>{{ months[p.month] ?? p.month }} {{ p.year }}</td>
                    <td>{{ p.baseSalary ? p.baseSalary|number_format(2) : '—' }}</td>
                    <td style="color:var(--color-success)">{{ p.bonus ? '+' ~ p.bonus|number_format(2) : '—' }}</td>
                    <td style="color:var(--color-danger)">{{ p.deductions ? '-' ~ p.deductions|number_format(2) : '—' }}</td>
                    <td style="font-weight:700;color:var(--accent-blue)">{{ p.netSalary ? p.netSalary|number_format(2) : '—' }}</td>
                    <td>
                        {% set sc = {'PENDING': 'blue', 'PAID': 'green', 'CANCELLED': 'red'} %}
                        <span class="badge badge--{{ sc[p.status] ?? 'blue' }}">{{ p.status ?? 'N/A' }}</span>
                    </td>
                    <td>
                        <details class="crud-actions-menu">
                            <summary class="btn btn-ghost btn-sm" title="Actions"><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="5" r="2"/><circle cx="12" cy="12" r="2"/><circle cx="12" cy="19" r="2"/></svg></summary>
                            <div class="crud-actions-dropdown">
                                <a href="{{ path('app_payroll_show', {id: p.id}) }}" class="crud-action-item"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg> View</a>
                                {% if is_granted('ROLE_HR') %}
                                <a href="{{ path('app_payroll_edit', {id: p.id}) }}" class="crud-action-item"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg> Edit</a>
                                <form method="post" action="{{ path('app_payroll_delete', {id: p.id}) }}" onsubmit="return confirm('Delete this payroll record?')">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ p.id) }}">
                                    <button type="submit" class="crud-action-item crud-action-danger"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg> Delete</button>
                                </form>
                                {% endif %}
                            </div>
                        </details>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    {% else %}
    <div style="text-align:center;padding:3rem">
        <p class="text-muted">No payroll records yet.</p>
        <a href="{{ path('app_payroll_new') }}" class="btn btn-primary" style="margin-top:1rem">+ Generate Payroll</a>
    </div>
    {% endif %}
</div>

{% if pagination is defined %}{% include 'components/_pagination.html.twig' %}{% endif %}
{% endblock %}
