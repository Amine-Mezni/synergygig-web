{% extends 'layouts/admin.html.twig' %}

{% block page_title %}AI Quiz: {{ course.title }}{% endblock %}

{% block header_actions %}
    <a href="{{ path('app_training_show', {id: course.id}) }}" class="btn btn-ghost btn-sm">Cancel</a>
{% endblock %}

{% block content %}
<div id="quizApp" data-timer="{{ timer }}" data-total="{{ questions|length }}" data-course-id="{{ course.id }}">

    {# AI badge #}
    <div style="text-align:center;margin-bottom:1rem">
        <span class="badge badge--purple" style="font-size:.8rem;padding:.4rem 1rem;letter-spacing:.03em">🤖 AI-Generated Quiz · {{ course.title }}</span>
    </div>

    {# ── Top bar ── #}
    <div style="display:flex;align-items:center;gap:1rem;margin-bottom:1.5rem;background:var(--bg-secondary);padding:1rem 1.5rem;border-radius:var(--radius-lg)">
        <div style="flex:1">
            <div style="height:8px;background:var(--glass-border);border-radius:4px;overflow:hidden">
                <div id="progressBar" style="height:100%;background:var(--accent-blue);border-radius:4px;transition:width 0.4s;width:0%"></div>
            </div>
        </div>
        <span id="questionCounter" style="font-weight:700;color:var(--text-primary)">1/{{ questions|length }}</span>
        <span id="streakDisplay" style="color:#FBBF24;font-weight:700;min-width:50px">🔥 0</span>
        <span id="scoreDisplay" style="color:var(--color-success);font-weight:700;min-width:50px">⭐ 0</span>
    </div>

    {# ── SVG Circular Timer ── #}
    <div style="text-align:center;margin-bottom:1.5rem">
        <div id="timerRing" style="display:inline-block;position:relative;width:72px;height:72px">
            <svg width="72" height="72" style="transform:rotate(-90deg)">
                <circle cx="36" cy="36" r="30" fill="none" stroke="rgba(255,255,255,0.08)" stroke-width="5"/>
                <circle id="timerArc" cx="36" cy="36" r="30" fill="none" stroke="#4ADE80" stroke-width="5"
                        stroke-dasharray="188.5" stroke-dashoffset="0" stroke-linecap="round"
                        style="transition:stroke-dashoffset 0.9s linear,stroke 0.4s"/>
            </svg>
            <span id="timerText" style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);font-size:1.3rem;font-weight:700;color:#4ADE80;transition:color 0.4s">{{ timer }}</span>
        </div>
    </div>

    {# ── Question area ── #}
    <div id="questionArea" style="text-align:center;margin-bottom:2rem">
        <div id="categoryBadge" class="badge badge--purple" style="margin-bottom:.75rem">🤖 AI Generated</div>
        <h3 id="questionText" style="color:var(--text-primary);font-size:1.2rem;line-height:1.65;margin-bottom:1.5rem;max-width:700px;margin-left:auto;margin-right:auto"></h3>

        <div id="optionsGrid" style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;max-width:640px;margin:0 auto"></div>
    </div>

    {# ── Feedback overlay ── #}
    <div id="feedbackArea" style="text-align:center;display:none;margin-bottom:1.5rem;animation:fadeIn .2s ease">
        <div id="feedbackText" style="font-size:1.15rem;font-weight:700;padding:.7rem 1.75rem;border-radius:var(--radius-md);display:inline-block;max-width:560px;word-wrap:break-word"></div>
    </div>

    {# ── Hidden submission form (same route as standard quiz) ── #}
    <form id="quizForm" method="post" action="{{ path('app_training_quiz_submit', {id: course.id}) }}">
        <input type="hidden" name="_token" value="{{ csrf_token('quiz' ~ course.id) }}">
        {% for q in questions %}
            <input type="hidden" name="answers[{{ q.index }}]" id="answer_{{ q.index }}" value="-1">
        {% endfor %}
    </form>

    {# ── Bottom info ── #}
    <div style="display:flex;justify-content:center;gap:2rem;color:var(--text-muted);font-size:.8rem;margin-top:1rem">
        <span>⏱ {{ timer }}s per question</span>
        <span>🎯 Pass: 70%</span>
        <span>🤖 AI-powered</span>
    </div>
</div>

<style>
@keyframes fadeIn { from { opacity:0; transform:translateY(4px); } to { opacity:1; transform:none; } }
.quiz-opt-btn {
    background: #2D70AE;
    color: #fff;
    border: none;
    padding: 1rem;
    border-radius: var(--radius-md);
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    min-height: 72px;
    transition: transform .15s, box-shadow .15s, opacity .15s;
    text-align: center;
    word-wrap: break-word;
    line-height: 1.4;
}
.quiz-opt-btn:hover:not(:disabled) { transform: scale(1.025); box-shadow: 0 4px 16px rgba(0,0,0,.25); }
</style>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
(function(){
    var questions  = {{ questions|json_encode|raw }};
    var timerSec   = {{ timer }};
    var total      = questions.length;
    var currentIdx = 0;
    var score      = 0;
    var streak     = 0;
    var interval   = null;
    var timeLeft   = 0;
    var answered   = false;

    var ARC_TOTAL  = 2 * Math.PI * 30; // circumference for r=30
    var OPT_COLORS = ['#E14B4B', '#2D70AE', '#D89E00', '#298F47'];
    var OPT_ICONS  = ['◆', '●', '▲', '■'];

    function updateArc(fraction) {
        var arc  = document.getElementById('timerArc');
        var text = document.getElementById('timerText');
        var offset = ARC_TOTAL * (1 - Math.max(0, fraction));
        arc.style.strokeDashoffset = offset;
        var color = fraction > 0.5 ? '#4ADE80' : (fraction > 0.25 ? '#FBBF24' : '#F87171');
        arc.style.stroke = color;
        text.style.color = color;
    }

    function showQuestion(idx) {
        answered = false;
        var q = questions[idx];

        document.getElementById('questionCounter').textContent = (idx + 1) + '/' + total;
        document.getElementById('progressBar').style.width = ((idx / total) * 100) + '%';
        document.getElementById('questionText').textContent = q.q;
        document.getElementById('feedbackArea').style.display = 'none';

        var grid = document.getElementById('optionsGrid');
        grid.innerHTML = '';
        q.options.forEach(function(opt, i) {
            var btn = document.createElement('button');
            btn.type = 'button';
            btn.className = 'quiz-opt-btn';
            btn.style.background = OPT_COLORS[i];
            btn.textContent = OPT_ICONS[i] + '  ' + opt;
            btn.addEventListener('click', function() { selectAnswer(idx, i); });
            grid.appendChild(btn);
        });

        // Start countdown
        timeLeft = timerSec;
        document.getElementById('timerText').textContent = timeLeft;
        updateArc(1);
        clearInterval(interval);
        interval = setInterval(function() {
            timeLeft--;
            document.getElementById('timerText').textContent = timeLeft;
            updateArc(timeLeft / timerSec);
            if (timeLeft <= 0) {
                clearInterval(interval);
                if (!answered) timeUp(idx);
            }
        }, 1000);
    }

    function selectAnswer(qIdx, optIdx) {
        if (answered) return;
        answered = true;
        clearInterval(interval);

        // Record answer for server submission
        document.getElementById('answer_' + questions[qIdx].index).value = optIdx;

        var correctIdx = questions[qIdx].answer;
        var isCorrect  = (optIdx === correctIdx);

        // Dim all buttons
        var btns = document.getElementById('optionsGrid').children;
        for (var i = 0; i < btns.length; i++) {
            btns[i].style.cursor  = 'default';
            btns[i].style.opacity = '0.45';
            btns[i].style.transform = 'scale(0.97)';
        }

        // Highlight correct answer green
        btns[correctIdx].style.opacity   = '1';
        btns[correctIdx].style.transform = 'scale(1.04)';
        btns[correctIdx].style.boxShadow = '0 0 0 4px #4ADE80, 0 0 20px rgba(74,222,128,.35)';

        // Outline wrong selection red
        if (!isCorrect) {
            btns[optIdx].style.opacity   = '0.8';
            btns[optIdx].style.boxShadow = '0 0 0 3px #F87171';
        }

        if (isCorrect) { score++; streak++; }
        else            { streak = 0; }

        document.getElementById('scoreDisplay').textContent   = '⭐ ' + score;
        document.getElementById('streakDisplay').textContent  = '🔥 ' + streak;

        var fb     = document.getElementById('feedbackArea');
        var fbText = document.getElementById('feedbackText');
        fb.style.display = 'block';
        fb.style.animation = 'none'; fb.offsetHeight; fb.style.animation = ''; // restart

        if (isCorrect) {
            fbText.textContent        = '✅ Correct!';
            fbText.style.background   = 'rgba(74,222,128,0.12)';
            fbText.style.color        = '#4ADE80';
        } else {
            fbText.textContent        = '❌ Wrong — correct answer: ' + questions[qIdx].options[correctIdx];
            fbText.style.background   = 'rgba(248,113,113,0.12)';
            fbText.style.color        = '#F87171';
        }

        setTimeout(nextQuestion, 1500);
    }

    function timeUp(qIdx) {
        answered = true;
        streak   = 0;
        document.getElementById('streakDisplay').textContent = '🔥 0';
        document.getElementById('answer_' + questions[qIdx].index).value = -1;
        updateArc(0);

        var correctIdx = questions[qIdx].answer;
        var btns = document.getElementById('optionsGrid').children;
        for (var i = 0; i < btns.length; i++) {
            btns[i].style.cursor  = 'default';
            btns[i].style.opacity = '0.45';
        }
        btns[correctIdx].style.opacity   = '1';
        btns[correctIdx].style.boxShadow = '0 0 0 4px #4ADE80';

        var fb     = document.getElementById('feedbackArea');
        var fbText = document.getElementById('feedbackText');
        fb.style.display      = 'block';
        fbText.textContent    = '⏰ Time\'s up! Correct: ' + questions[qIdx].options[correctIdx];
        fbText.style.background = 'rgba(248,113,113,0.12)';
        fbText.style.color    = '#F87171';

        setTimeout(nextQuestion, 1800);
    }

    function nextQuestion() {
        currentIdx++;
        if (currentIdx < total) {
            showQuestion(currentIdx);
        } else {
            document.getElementById('progressBar').style.width = '100%';
            document.getElementById('quizForm').submit();
        }
    }

    if (questions.length > 0) showQuestion(0);
})();
</script>
{% endblock %}
