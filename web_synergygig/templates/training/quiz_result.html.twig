{% extends 'layouts/admin.html.twig' %}

{% block page_title %}Quiz Results: {{ course.title }}{% endblock %}

{% block header_actions %}
    <a href="{{ path('app_training_show', {id: course.id}) }}" class="btn btn-ghost btn-sm">Back to Course</a>
{% endblock %}

{% block content %}
{# ── Score card ── #}
<div class="card" style="margin-bottom:2rem;text-align:center;padding:2.5rem">
    <div style="font-size:4rem;margin-bottom:0.5rem">
        {% if passed %}🏆{% else %}📋{% endif %}
    </div>
    <h2 style="color:var(--text-primary);margin-bottom:0.5rem">
        {% if passed %}Congratulations! You Passed!{% else %}Quiz Complete{% endif %}
    </h2>
    <div style="font-size:3rem;font-weight:700;margin:1rem 0;
        {% if passed %}color:var(--color-success){% else %}color:var(--color-danger){% endif %}">
        {{ scorePercent|number_format(0) }}%
    </div>
    <div style="color:var(--text-muted);font-size:1rem">
        {{ correct }} out of {{ total }} correct
    </div>
    <div style="margin-top:0.5rem;font-size:0.85rem;color:var(--text-muted)">
        {% if passed %}
            <span style="color:var(--color-success)">✓ Pass threshold: 70%</span>
        {% else %}
            <span style="color:var(--color-danger)">✗ You need at least 70% to pass. Study and try again!</span>
        {% endif %}
    </div>

    {% if passed and issuedCertificate %}
    <div style="margin-top:1.5rem;padding:1rem;background:rgba(16,185,129,0.1);border-radius:var(--radius-md);border:1px solid rgba(16,185,129,0.3)">
        <div style="font-size:1.1rem;font-weight:600;color:var(--color-success)">🎓 Certificate Ready!</div>
        <div style="font-size:0.85rem;color:var(--text-muted);margin-top:0.25rem">{% if certificateGenerated %}A new certificate was generated and auto-signed.{% else %}Your certificate is ready and auto-signed.{% endif %}</div>
        <div style="margin-top:0.9rem">
            <a href="{{ path('app_training_certificate_pdf', {id: issuedCertificate.id}) }}" class="btn btn-primary btn-sm" target="_blank">📄 Download Certificate</a>
        </div>
    </div>
    {% endif %}
</div>

{# ── Score bar ── #}
<div class="card" style="margin-bottom:2rem;padding:1.5rem">
    <div style="display:flex;align-items:center;gap:1rem;margin-bottom:0.75rem">
        <div style="font-weight:600;color:var(--text-primary)">Score Breakdown</div>
        <div style="flex:1;height:12px;background:var(--glass-border);border-radius:6px;overflow:hidden">
            <div style="height:100%;border-radius:6px;transition:width 0.5s;width:{{ scorePercent }}%;
                {% if passed %}background:var(--color-success){% else %}background:var(--color-danger){% endif %}">
            </div>
        </div>
        <span style="font-weight:700;color:var(--text-primary)">{{ scorePercent|number_format(0) }}%</span>
    </div>
    <div style="display:flex;gap:2rem;font-size:0.85rem;color:var(--text-muted)">
        <span>✅ Correct: {{ correct }}</span>
        <span>❌ Wrong: {{ total - correct }}</span>
        <span>📝 Total: {{ total }}</span>
    </div>
</div>

{# ── Answer review ── #}
<div class="card" style="margin-bottom:2rem">
    <div class="card__header"><h4>📋 Question-by-Question Review</h4></div>
    <div class="card__body" style="padding:0">
        {% for r in results %}
        <div style="padding:1.1rem 1.25rem;border-bottom:1px solid var(--glass-border);
            {% if r.isCorrect %}background:rgba(16,185,129,0.05){% else %}background:rgba(220,38,38,0.04){% endif %}">

            {# Question header #}
            <div style="display:flex;align-items:flex-start;gap:0.6rem;margin-bottom:0.65rem">
                <span style="flex-shrink:0;font-size:1rem">{{ r.isCorrect ? '✅' : '❌' }}</span>
                <strong style="color:var(--text-primary);font-size:0.92rem">Q{{ r.index + 1 }}. {{ r.question }}</strong>
            </div>

            {# Options list #}
            {% if r.options|length > 0 %}
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.35rem 1rem;padding-left:1.6rem">
                {% for i, opt in r.options %}
                <div style="font-size:0.82rem;padding:0.3rem 0.6rem;border-radius:4px;
                    {% if i == r.correct and i == r.submitted %}
                        background:rgba(16,185,129,0.18);color:#065f46;font-weight:700;border:1px solid rgba(16,185,129,0.5)
                    {% elseif i == r.correct %}
                        background:rgba(16,185,129,0.12);color:#065f46;font-weight:600;border:1px solid rgba(16,185,129,0.35)
                    {% elseif i == r.submitted %}
                        background:rgba(220,38,38,0.12);color:#991b1b;font-weight:600;border:1px solid rgba(220,38,38,0.35)
                    {% else %}
                        color:var(--text-muted)
                    {% endif %}
                ">
                    {% if i == r.correct and i == r.submitted %}✅ {% elseif i == r.correct %}✔ {% elseif i == r.submitted %}✗ {% endif %}
                    {{ opt }}
                </div>
                {% endfor %}
            </div>
            {% else %}
            <div style="font-size:0.82rem;color:var(--text-muted);padding-left:1.6rem">
                Your answer: option {{ r.submitted >= 0 ? (r.submitted + 1) : '⏰ Not answered' }}
                {% if not r.isCorrect %}
                    &nbsp;·&nbsp;<span style="color:var(--color-success)">Correct: option {{ r.correct + 1 }}</span>
                {% endif %}
            </div>
            {% endif %}
        </div>
        {% endfor %}
    </div>
</div>

{# ── Actions ── #}
<div style="display:flex;gap:1rem;justify-content:center;margin-top:2rem">
    {% if not passed %}
        <a href="{{ path('app_training_quiz', {id: course.id}) }}" class="btn btn-primary">🔄 Retry Quiz</a>
    {% endif %}
    <a href="{{ path('app_training_show', {id: course.id}) }}" class="btn btn-secondary">📚 Back to Course</a>
</div>
{% endblock %}
