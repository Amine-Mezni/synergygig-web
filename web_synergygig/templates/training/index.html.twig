{% extends 'layouts/admin.html.twig' %}

{% block page_title %}Training Center{% endblock %}

{% block header_actions %}
    {% if is_granted('ROLE_HR') %}
        <a href="{{ path('app_training_new') }}" class="btn btn-primary btn-sm">+ New Course</a>
    {% endif %}
{% endblock %}

{% block content %}
{# ====== Tab Navigation ====== #}
<div class="card" style="padding:0;margin-bottom:var(--space-lg);overflow:visible">
    <div style="display:flex;border-bottom:1px solid var(--glass-border);overflow-x:auto;padding:0 var(--space-sm)">
        {% set tabs = [
            {key:'dashboard', icon:'📊', label:'Dashboard'},
            {key:'catalog', icon:'📚', label:'Catalog'},
            {key:'learning', icon:'🎓', label:'My Learning'},
            {key:'certificates', icon:'🏆', label:'Certificates'},
        ] %}
        {% for t in tabs %}
            <a href="{{ path('app_training_index', {tab: t.key}) }}"
               style="padding:.875rem 1.25rem;text-decoration:none;font-size:.85rem;font-weight:500;white-space:nowrap;border-bottom:2px solid {{ tab == t.key ? 'var(--accent)' : 'transparent' }};color:{{ tab == t.key ? 'var(--accent)' : 'var(--text-muted)' }};transition:all .2s"
            >{{ t.icon }} {{ t.label }}</a>
        {% endfor %}
        {% if is_granted('ROLE_HR') %}
            <a href="{{ path('app_training_index', {tab: 'manage'}) }}"
               style="padding:.875rem 1.25rem;text-decoration:none;font-size:.85rem;font-weight:500;white-space:nowrap;border-bottom:2px solid {{ tab == 'manage' ? 'var(--accent)' : 'transparent' }};color:{{ tab == 'manage' ? 'var(--accent)' : 'var(--text-muted)' }};transition:all .2s"
            >⚙️ Manage</a>
        {% endif %}
    </div>
</div>

{# ====== DASHBOARD TAB ====== #}
{% if tab == 'dashboard' %}
<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:var(--space-md);margin-bottom:var(--space-lg)">
    <div class="card" style="padding:var(--space-md);text-align:center">
        <div style="font-size:1.5rem;font-weight:700;color:var(--accent-blue)">{{ totalCourses }}</div>
        <div style="font-size:.75rem;color:var(--text-muted);margin-top:4px">Active Courses</div>
    </div>
    <div class="card" style="padding:var(--space-md);text-align:center">
        <div style="font-size:1.5rem;font-weight:700;color:var(--accent)">{{ myEnrollmentCount }}</div>
        <div style="font-size:.75rem;color:var(--text-muted);margin-top:4px">My Enrollments</div>
    </div>
    <div class="card" style="padding:var(--space-md);text-align:center">
        <div style="font-size:1.5rem;font-weight:700;color:#10b981">{{ completedCount }}</div>
        <div style="font-size:.75rem;color:var(--text-muted);margin-top:4px">Completed</div>
    </div>
    <div class="card" style="padding:var(--space-md);text-align:center">
        <div style="font-size:1.5rem;font-weight:700;color:#f59e0b">{{ certCount }}</div>
        <div style="font-size:.75rem;color:var(--text-muted);margin-top:4px">Certificates</div>
    </div>
    <div class="card" style="padding:var(--space-md);text-align:center">
        <div style="font-size:1.5rem;font-weight:700;color:#8b5cf6">{{ avgProgress }}%</div>
        <div style="font-size:.75rem;color:var(--text-muted);margin-top:4px">Avg Progress</div>
    </div>
</div>

{# Recent Enrollments #}
<div class="card" style="padding:var(--space-lg)">
    <h3 style="margin-bottom:var(--space-md);font-size:1rem;color:var(--text-primary)">📋 Recent Enrollments</h3>
    {% if recentEnrollments|length > 0 %}
        <div style="display:flex;flex-direction:column;gap:var(--space-sm)">
        {% for e in recentEnrollments %}
            {% set cert = certificateByEnrollmentId[e.id] is defined ? certificateByEnrollmentId[e.id] : null %}
            <div style="display:flex;align-items:center;gap:var(--space-md);padding:.75rem;border-radius:var(--radius-md);background:var(--bg-tertiary)">
                <div style="flex:1;min-width:0">
                    <div style="font-weight:600;font-size:.85rem;color:var(--text-primary);white-space:nowrap;overflow:hidden;text-overflow:ellipsis">
                        <a href="{{ path('app_training_show', {id: e.course.id}) }}" style="color:var(--accent-blue);text-decoration:none">{{ e.course.title }}</a>
                    </div>
                    <div style="font-size:.75rem;color:var(--text-muted);margin-top:2px">Enrolled {{ e.enrolledAt ? e.enrolledAt|date('M j, Y') : '—' }}</div>
                </div>
                <div style="width:120px">
                    <div style="height:6px;background:var(--glass-border);border-radius:3px;overflow:hidden">
                        <div style="height:100%;width:{{ e.progress ?? 0 }}%;background:{{ e.status == 'COMPLETED' ? '#10b981' : 'var(--accent)' }};border-radius:3px"></div>
                    </div>
                    <div style="font-size:.7rem;color:var(--text-muted);margin-top:2px;text-align:center">{{ e.progress ?? 0 }}%</div>
                </div>
                {% set esc = {'ENROLLED':'blue','IN_PROGRESS':'orange','COMPLETED':'green','DROPPED':'red'} %}
                <div style="display:flex;align-items:center;gap:.5rem;flex-shrink:0">
                    <span class="badge badge--{{ esc[e.status] ?? 'blue' }}" style="font-size:.7rem">{{ e.status }}</span>
                    {% if e.status == 'COMPLETED' and cert %}
                        <a href="{{ path('app_training_certificate_pdf', {id: cert.id}) }}" class="btn btn-ghost btn-sm" style="font-size:.72rem;white-space:nowrap" target="_blank">📄 Download</a>
                    {% endif %}
                </div>
            </div>
        {% endfor %}
        </div>
    {% else %}
        <div style="text-align:center;padding:2rem;color:var(--text-muted)">
            <div style="font-size:2rem;margin-bottom:.5rem">📚</div>
            <p>No enrollments yet. <a href="{{ path('app_training_index', {tab:'catalog'}) }}" style="color:var(--accent)">Browse the catalog</a> to get started!</p>
        </div>
    {% endif %}
</div>

{# ── Dashboard row: Daily Trivia + Recommended Reading ── #}
<div style="display:grid;grid-template-columns:1fr 1fr;gap:var(--space-md);margin-top:var(--space-md)">

    {# Daily Trivia Widget #}
    <div class="card" style="padding:var(--space-lg)">
        <h3 style="margin-bottom:var(--space-md);font-size:1rem;color:var(--text-primary)">🧠 Daily Trivia Challenge</h3>
        <div id="triviaWidget">
            <div id="triviaLoading" style="text-align:center;padding:2rem;color:var(--text-muted)">
                <div style="font-size:1.5rem;margin-bottom:.5rem">⏳</div>
                <p style="font-size:.85rem">Loading question…</p>
            </div>
            <div id="triviaContent" style="display:none">
                <div id="triviaCat" class="badge badge--blue" style="font-size:.7rem;margin-bottom:.75rem"></div>
                <p id="triviaQ" style="font-size:.9rem;color:var(--text-primary);font-weight:600;margin-bottom:1rem;line-height:1.55"></p>
                <div id="triviaOptions" style="display:flex;flex-direction:column;gap:.5rem"></div>
                <div id="triviaFb" style="display:none;margin-top:.75rem;padding:.6rem 1rem;border-radius:var(--radius-md);font-size:.85rem;font-weight:600"></div>
                <button id="triviaNext" style="display:none;margin-top:.75rem;padding:.5rem 1.25rem;background:var(--accent-blue);color:#fff;border:none;border-radius:var(--radius-md);cursor:pointer;font-size:.85rem;font-weight:600" onclick="loadTrivia()">Next Question →</button>
            </div>
            <div id="triviaError" style="display:none;text-align:center;padding:1.5rem;color:var(--text-muted);font-size:.85rem">
                😕 Couldn't load trivia right now.
            </div>
        </div>
    </div>

    {# Recommended Reading Widget #}
    <div class="card" style="padding:var(--space-lg)">
        <h3 style="margin-bottom:var(--space-md);font-size:1rem;color:var(--text-primary)">📖 Recommended Reading</h3>
        <div id="booksWidget">
            <div id="booksLoading" style="text-align:center;padding:2rem;color:var(--text-muted)">
                <div style="font-size:1.5rem;margin-bottom:.5rem">⏳</div>
                <p style="font-size:.85rem">Finding books…</p>
            </div>
            <div id="booksContent" style="display:none;flex-direction:column;gap:.75rem"></div>
            <div id="booksError" style="display:none;text-align:center;padding:1.5rem;color:var(--text-muted);font-size:.85rem">
                😕 Couldn't load recommendations right now.
            </div>
        </div>
    </div>
</div>

{# ── Dashboard row: AI Course Recommendations ── #}
<div class="card" style="padding:var(--space-lg);margin-top:var(--space-md)" id="aiRecoWidget">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:var(--space-md)">
        <h3 style="margin:0;font-size:1rem;color:var(--text-primary)">🤖 AI-Recommended Courses For You</h3>
        <span style="font-size:.72rem;color:var(--text-muted);background:var(--bg-tertiary);padding:2px 8px;border-radius:12px;border:1px solid var(--glass-border)">Powered by AI</span>
    </div>
    <div id="aiRecoLoading" style="text-align:center;padding:2rem;color:var(--text-muted)">
        <div style="font-size:1.5rem;margin-bottom:.5rem">🔄</div>
        <p style="font-size:.85rem">Analyzing your learning profile…</p>
    </div>
    <div id="aiRecoContent" style="display:none;flex-direction:column;gap:.65rem"></div>
    <div id="aiRecoError" style="display:none;text-align:center;padding:1.5rem;color:var(--text-muted);font-size:.85rem">
        😕 Couldn't load AI recommendations right now.
    </div>
</div>

<script>
// ─── Daily Trivia ───────────────────────────────────────────
var triviaCorrect = null;

function htmlDecode(s) {
    var el = document.createElement('div');
    el.innerHTML = s;
    return el.textContent || el.innerText;
}

function loadTrivia() {
    document.getElementById('triviaLoading').style.display = 'block';
    document.getElementById('triviaContent').style.display = 'none';
    document.getElementById('triviaError').style.display   = 'none';
    document.getElementById('triviaFb').style.display      = 'none';
    document.getElementById('triviaNext').style.display    = 'none';

    fetch('https://opentdb.com/api.php?amount=1&type=multiple')
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (!data.results || data.results.length === 0) throw new Error('no results');
            var q = data.results[0];
            triviaCorrect = htmlDecode(q.correct_answer);

            document.getElementById('triviaCat').textContent = htmlDecode(q.category);
            document.getElementById('triviaQ').textContent   = htmlDecode(q.question);

            var opts = q.incorrect_answers.concat([q.correct_answer]).map(htmlDecode);
            opts.sort(function() { return Math.random() - 0.5; });

            var container = document.getElementById('triviaOptions');
            container.innerHTML = '';
            opts.forEach(function(opt) {
                var btn = document.createElement('button');
                btn.textContent = opt;
                btn.style.cssText = 'width:100%;text-align:left;padding:.5rem .85rem;background:var(--bg-tertiary);color:var(--text-primary);border:1px solid var(--glass-border);border-radius:var(--radius-md);cursor:pointer;font-size:.85rem;transition:background .15s';
                btn.onmouseover = function() { if(!btn.disabled) btn.style.background = 'var(--bg-secondary)'; };
                btn.onmouseout  = function() { if(!btn.disabled) btn.style.background = 'var(--bg-tertiary)'; };
                btn.onclick = function() { answerTrivia(opt, btn); };
                container.appendChild(btn);
            });

            document.getElementById('triviaLoading').style.display = 'none';
            document.getElementById('triviaContent').style.display = 'block';
        })
        .catch(function() {
            document.getElementById('triviaLoading').style.display = 'none';
            document.getElementById('triviaError').style.display   = 'block';
        });
}

function answerTrivia(chosen, clickedBtn) {
    var isCorrect = chosen === triviaCorrect;
    // Disable all buttons
    var btns = document.getElementById('triviaOptions').children;
    for (var i = 0; i < btns.length; i++) {
        btns[i].disabled = true;
        btns[i].style.cursor = 'default';
        if (btns[i].textContent === triviaCorrect) {
            btns[i].style.background = 'rgba(74,222,128,0.15)';
            btns[i].style.borderColor = '#4ADE80';
            btns[i].style.color = '#4ADE80';
            btns[i].style.fontWeight = '700';
        }
    }
    if (!isCorrect) {
        clickedBtn.style.background  = 'rgba(248,113,113,0.15)';
        clickedBtn.style.borderColor = '#F87171';
        clickedBtn.style.color       = '#F87171';
    }
    var fb = document.getElementById('triviaFb');
    fb.textContent       = isCorrect ? '✅ Correct!' : '❌ Wrong — the correct answer was: ' + triviaCorrect;
    fb.style.background  = isCorrect ? 'rgba(74,222,128,0.12)' : 'rgba(248,113,113,0.12)';
    fb.style.color       = isCorrect ? '#4ADE80' : '#F87171';
    fb.style.display     = 'block';
    document.getElementById('triviaNext').style.display = 'block';
}

// ─── Recommended Reading ────────────────────────────────────
var BOOK_TOPICS = ['leadership', 'productivity', 'communication', 'management', 'professional development'];

function loadBooks() {
    var topic = BOOK_TOPICS[Math.floor(Math.random() * BOOK_TOPICS.length)];
    var url   = 'https://openlibrary.org/search.json?q=' + encodeURIComponent(topic) +
                '&limit=20&fields=title,author_name,first_publish_year,cover_i,key&language=eng';

    fetch(url)
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (!data.docs || data.docs.length === 0) throw new Error('empty');

            // Pick 3 random from top 20
            var shuffled = data.docs.filter(function(b) { return b.title && b.author_name; });
            shuffled.sort(function() { return Math.random() - 0.5; });
            var picks = shuffled.slice(0, 3);

            var container = document.getElementById('booksContent');
            container.innerHTML = '';
            picks.forEach(function(book) {
                var coverUrl = book.cover_i
                    ? 'https://covers.openlibrary.org/b/id/' + book.cover_i + '-S.jpg'
                    : null;
                var bookKey = book.key ? 'https://openlibrary.org' + book.key : '#';

                var el = document.createElement('div');
                el.style.cssText = 'display:flex;align-items:center;gap:.75rem;padding:.6rem;background:var(--bg-tertiary);border-radius:var(--radius-md)';
                el.innerHTML =
                    (coverUrl
                        ? '<img src="' + coverUrl + '" alt="" style="width:38px;height:54px;object-fit:cover;border-radius:3px;flex-shrink:0">'
                        : '<div style="width:38px;height:54px;background:var(--glass-border);border-radius:3px;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:1.2rem">📖</div>') +
                    '<div style="min-width:0">' +
                        '<a href="' + bookKey + '" target="_blank" rel="noopener noreferrer" style="color:var(--accent-blue);text-decoration:none;font-weight:600;font-size:.85rem;display:block;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">' + book.title + '</a>' +
                        '<div style="font-size:.75rem;color:var(--text-muted);margin-top:2px">' + (book.author_name ? book.author_name[0] : 'Unknown') + (book.first_publish_year ? ' · ' + book.first_publish_year : '') + '</div>' +
                    '</div>';
                container.appendChild(el);
            });

            document.getElementById('booksLoading').style.display = 'none';
            container.style.display = 'flex';

            // Topic label at bottom
            var lbl = document.createElement('div');
            lbl.style.cssText = 'font-size:.72rem;color:var(--text-muted);margin-top:.5rem;text-align:center';
            lbl.textContent = '📚 Topic: ' + topic.charAt(0).toUpperCase() + topic.slice(1);
            container.appendChild(lbl);
        })
        .catch(function() {
            document.getElementById('booksLoading').style.display = 'none';
            document.getElementById('booksError').style.display   = 'block';
        });
}

// Initialise both widgets on page load
document.addEventListener('DOMContentLoaded', function() {
    if (document.getElementById('triviaWidget')) loadTrivia();
    if (document.getElementById('booksWidget'))  loadBooks();
    if (document.getElementById('aiRecoWidget')) loadAiRecommendations();
});

// ─── AI Course Recommendations ──────────────────────────────
function loadAiRecommendations() {
    fetch('/training/recommendations-ai')
        .then(function(r) { return r.json(); })
        .then(function(data) {
            var recs = data.recommendations || [];
            var container = document.getElementById('aiRecoContent');
            var loading   = document.getElementById('aiRecoLoading');
            var error     = document.getElementById('aiRecoError');

            if (recs.length === 0) {
                loading.style.display = 'none';
                container.innerHTML = '<div style="text-align:center;padding:1rem;color:var(--text-muted);font-size:.85rem">No recommendations yet — enroll in more courses first!</div>';
                container.style.display = 'block';
                return;
            }

            container.innerHTML = '';
            recs.forEach(function(rec, i) {
                var colors = ['#6366f1','#10b981','#f59e0b'];
                var el = document.createElement('div');
                el.style.cssText = 'display:flex;gap:.75rem;padding:.75rem;background:var(--bg-tertiary);border-radius:var(--radius-md);border-left:3px solid ' + colors[i % colors.length];
                el.innerHTML =
                    '<div style="font-size:1.3rem;flex-shrink:0">🤖</div>' +
                    '<div style="min-width:0">' +
                        '<div style="font-weight:600;font-size:.85rem;color:var(--text-primary)">' + (rec.title || '') + '</div>' +
                        '<div style="font-size:.75rem;color:var(--text-muted);margin-top:3px">' + (rec.reason || '') + '</div>' +
                        (rec.course_id
                            ? '<a href="/training/' + rec.course_id + '" style="font-size:.72rem;color:var(--accent-blue);text-decoration:none;margin-top:4px;display:inline-block">View Course →</a>'
                            : '') +
                    '</div>';
                container.appendChild(el);
            });

            loading.style.display = 'none';
            container.style.display = 'flex';
        })
        .catch(function() {
            document.getElementById('aiRecoLoading').style.display = 'none';
            document.getElementById('aiRecoError').style.display   = 'block';
        });
}
</script>

{% endif %}

{# ====== CATALOG TAB ====== #}
{% if tab == 'catalog' %}
{# Search + Filters #}
<div class="card" style="padding:var(--space-md) var(--space-lg);margin-bottom:var(--space-lg)">
    <form method="get" action="{{ path('app_training_index') }}" style="display:flex;align-items:center;gap:var(--space-md);flex-wrap:wrap">
        <input type="hidden" name="tab" value="catalog">
        <div style="position:relative;flex:1;min-width:200px">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--text-muted)" stroke-width="2" style="position:absolute;left:.75rem;top:50%;transform:translateY(-50%)"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <input type="text" name="q" id="catalogSearch" value="{{ app.request.query.get('q') }}" placeholder="Search courses..." class="form-control" style="padding-left:2.25rem">
        </div>
        <select name="category" id="catalogCategory" class="form-control" style="width:auto;min-width:140px">
            <option value="">All Categories</option>
            {% for cat in ['TECHNICAL','SOFT_SKILLS','COMPLIANCE','ONBOARDING','LEADERSHIP'] %}
                <option value="{{ cat }}" {{ app.request.query.get('category') == cat ? 'selected' : '' }}>{{ cat|replace({'_': ' '})|title }}</option>
            {% endfor %}
        </select>
        <select name="difficulty" id="catalogDifficulty" class="form-control" style="width:auto;min-width:130px">
            <option value="">All Levels</option>
            {% for d in ['BEGINNER','INTERMEDIATE','ADVANCED'] %}
                <option value="{{ d }}" {{ app.request.query.get('difficulty') == d ? 'selected' : '' }}>{{ d|title }}</option>
            {% endfor %}
        </select>
        <button type="submit" class="btn btn-secondary btn-sm">Search</button>
    </form>
</div>

{# Course Cards Grid #}
{% if courses|length > 0 %}
<div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:var(--space-md);margin-bottom:var(--space-lg)">
    {% for c in courses %}
    {% set categoryColors = {'TECHNICAL':'#6366f1','SOFT_SKILLS':'#ec4899','COMPLIANCE':'#f59e0b','ONBOARDING':'#8b5cf6','LEADERSHIP':'#ef4444'} %}
    {% set enrollment = enrollmentMap[c.id] is defined ? enrollmentMap[c.id] : null %}
    <div class="catalog-card card" style="padding:0;overflow:hidden;display:flex;flex-direction:column"
         data-title="{{ c.title|lower }}"
         data-category="{{ c.category }}"
         data-difficulty="{{ c.difficulty }}">
        {# Category color banner #}
        <div style="height:4px;background:{{ categoryColors[c.category] ?? '#6366f1' }}"></div>
        <div style="padding:var(--space-md);flex:1;display:flex;flex-direction:column">
            {# Badges #}
            <div style="display:flex;gap:.375rem;flex-wrap:wrap;margin-bottom:var(--space-sm)">
                {% set cc = {'TECHNICAL':'blue','SOFT_SKILLS':'green','COMPLIANCE':'orange','ONBOARDING':'purple','LEADERSHIP':'red'} %}
                <span class="badge badge--{{ cc[c.category] ?? 'blue' }}" style="font-size:.7rem">{{ c.category|replace({'_': ' '}) }}</span>
                {% set dc = {'BEGINNER':'green','INTERMEDIATE':'orange','ADVANCED':'red'} %}
                <span class="badge badge--{{ dc[c.difficulty] ?? 'blue' }}" style="font-size:.7rem">{{ c.difficulty }}</span>
                {% if enrollment %}
                    <span class="badge badge--green" style="font-size:.7rem">✅ ENROLLED</span>
                {% endif %}
            </div>
            {# Title + Description #}
            <h4 style="margin:0 0 .375rem;font-size:.95rem;color:var(--text-primary)">
                <a href="{{ path('app_training_show', {id: c.id}) }}" style="color:inherit;text-decoration:none">{{ c.title }}</a>
            </h4>
            <p style="font-size:.8rem;color:var(--text-muted);margin:0 0 var(--space-sm);flex:1;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden">{{ c.description|default('No description available.')|slice(0,100) }}</p>
            {# Meta #}
            <div style="display:flex;gap:var(--space-md);font-size:.75rem;color:var(--text-muted);margin-bottom:var(--space-sm)">
                {% if c.durationHours %}<span>⏱ {{ c.durationHours }}h</span>{% endif %}
                {% if c.instructorName %}<span>👤 {{ c.instructorName }}</span>{% endif %}
                {% if c.quizTimerSeconds %}<span>⏰ {{ c.quizTimerSeconds }}s/Q</span>{% endif %}
            </div>
            {% if c.startDate or c.endDate %}
            <div style="font-size:.7rem;color:var(--text-muted);margin-bottom:var(--space-sm)">
                📅 {{ c.startDate ? c.startDate|date('M j') : '?' }} → {{ c.endDate ? c.endDate|date('M j, Y') : 'Ongoing' }}
            </div>
            {% endif %}
            {# Action row #}
            <div style="display:flex;gap:.5rem;margin-top:auto;padding-top:var(--space-sm);border-top:1px solid var(--glass-border)">
                {% if enrollment %}
                    {% if enrollment.status != 'COMPLETED' %}
