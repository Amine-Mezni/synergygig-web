<script>
document.addEventListener('DOMContentLoaded', function() {
    // ── Advanced course warning ──
    document.querySelectorAll('form[data-advanced="true"]').forEach(function(form) {
        form.addEventListener('submit', function(e) {
            var ok = confirm(
                '⚠️ Advanced Course Warning\n\n' +
                'This is an ADVANCED level course. It is recommended to complete Beginner and Intermediate courses first.\n\n' +
                'Are you sure you want to enroll?'
            );
            if (!ok) e.preventDefault();
        });
    });

    // ── Live catalog filtering ──
    var searchEl    = document.getElementById('catalogSearch');
    var catEl       = document.getElementById('catalogCategory');
    var diffEl      = document.getElementById('catalogDifficulty');
    var cards       = document.querySelectorAll('.catalog-card');
    var noResults   = document.getElementById('catalogNoResults');

    function filterCatalog() {
        var q    = searchEl ? searchEl.value.toLowerCase() : '';
        var cat  = catEl    ? catEl.value : '';
        var diff = diffEl   ? diffEl.value : '';
        var visible = 0;

        cards.forEach(function(card) {
            var matchQ    = !q    || card.dataset.title.includes(q);
            var matchCat  = !cat  || card.dataset.category === cat;
            var matchDiff = !diff || card.dataset.difficulty === diff;
            var show = matchQ && matchCat && matchDiff;
            card.style.display = show ? '' : 'none';
            if (show) visible++;
        });

        if (noResults) noResults.style.display = visible === 0 ? 'block' : 'none';
    }

    if (searchEl) searchEl.addEventListener('input', filterCatalog);
    if (catEl)    catEl.addEventListener('change', filterCatalog);
    if (diffEl)   diffEl.addEventListener('change', filterCatalog);
});
</script>
{% endif %}

