                {% if enrolleeCount > 0 %}
                <tr id="enrollees_{{ c.id }}" style="display:none">
                    <td colspan="10" style="padding:0">
                        <div style="background:var(--bg-tertiary);border-top:1px solid var(--glass-border);padding:.75rem 1rem">
                            <table style="width:100%;border-collapse:collapse;font-size:.8rem">
                                <thead>
                                    <tr style="color:var(--text-muted)">
                                        <th style="text-align:left;padding:.3rem .5rem;font-weight:500">Employee</th>
                                        <th style="text-align:left;padding:.3rem .5rem;font-weight:500">Status</th>
                                        <th style="text-align:left;padding:.3rem .5rem;font-weight:500;width:160px">Progress</th>
                                        <th style="text-align:left;padding:.3rem .5rem;font-weight:500">Score</th>
                                        <th style="text-align:left;padding:.3rem .5rem;font-weight:500">Enrolled</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for enr in c.enrollments %}
                                    <tr>
                                        <td style="padding:.4rem .5rem">
                                            <span style="font-weight:600;color:var(--text-primary)">
                                                {{ enr.user.firstName ?? '' }} {{ enr.user.lastName ?? '' }}
                                            </span>
                                        </td>
                                        <td style="padding:.4rem .5rem">
                                            {% set es = {'ENROLLED':'blue','IN_PROGRESS':'orange','COMPLETED':'green','DROPPED':'red'} %}
                                            <span class="badge badge--{{ es[enr.status] ?? 'blue' }}" style="font-size:.7rem">{{ enr.status }}</span>
                                        </td>
                                        <td style="padding:.4rem .5rem">
                                            <div style="display:flex;align-items:center;gap:.5rem">
                                                <div style="flex:1;height:6px;background:var(--glass-border);border-radius:3px;overflow:hidden">
                                                    <div style="height:100%;width:{{ enr.progress ?? 0 }}%;background:{{ accentColor }};border-radius:3px"></div>
                                                </div>
                                                <span style="font-size:.72rem;color:var(--text-muted);white-space:nowrap">{{ enr.progress ?? 0 }}%</span>
                                            </div>
                                        </td>
                                        <td style="padding:.4rem .5rem">
                                            {% if enr.score is not null %}
                                                <span style="color:{{ enr.score >= 70 ? '#10b981' : '#ef4444' }};font-weight:600">{{ enr.score|number_format(0) }}%</span>
                                            {% else %}—{% endif %}
                                        </td>
                                        <td style="padding:.4rem .5rem;color:var(--text-muted)">
                                            {{ enr.enrolledAt ? enr.enrolledAt|date('M j, Y') : '—' }}
                                        </td>
                                    </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </td>
                </tr>
                {% endif %}
                {% endfor %}
            </tbody>
        </table>
    </div>
    {% else %}
    <div style="text-align:center;padding:3rem">
        <div style="font-size:2.5rem;margin-bottom:.75rem">📚</div>
        <p class="text-muted">No courses created yet.</p>
        <div style="display:flex;gap:.75rem;justify-content:center;margin-top:1rem;flex-wrap:wrap">
            <a href="{{ path('app_training_new') }}" class="btn btn-primary">+ Create Course</a>
            <button onclick="document.getElementById('aiGenModal').style.display='flex'" class="btn btn-secondary">🤖 Generate with AI</button>
        </div>
    </div>
    {% endif %}
</div>

<script>
function toggleEnrollees(courseId) {
    var row = document.getElementById('enrollees_' + courseId);
    var tog = document.getElementById('tog_' + courseId);
    if (!row) return;
    var open = row.style.display !== 'none';
    row.style.display = open ? 'none' : 'table-row';
    tog.style.transform = open ? '' : 'rotate(90deg)';
}
</script>

{% else %}
<div class="card" style="text-align:center;padding:3rem">
    <p class="text-muted">This section is restricted to HR and Admin users.</p>
</div>
{% endif %}
{% endif %}
{% endblock %}
