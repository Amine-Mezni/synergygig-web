{# Signature Modal for HR/Admin #}
{% if is_granted('ROLE_HR') %}
<div id="signModal" style="display:none;position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,.6);backdrop-filter:blur(4px);align-items:center;justify-content:center">
    <div class="card" style="width:520px;max-width:95vw;padding:var(--space-lg)">
        <h3 style="margin:0 0 var(--space-md);color:var(--text-primary)">✍️ Sign Certificate</h3>
        <p style="font-size:.85rem;color:var(--text-muted);margin-bottom:var(--space-md)">Draw your signature below</p>
        <canvas id="signCanvas" width="460" height="140" style="border:2px dashed var(--glass-border);border-radius:var(--radius-md);cursor:crosshair;background:rgba(255,255,255,.05);display:block;width:100%"></canvas>
        <div style="display:flex;gap:.5rem;margin-top:var(--space-md);justify-content:flex-end">
            <button type="button" class="btn btn-ghost btn-sm" id="signClear">Clear</button>
            <button type="button" class="btn btn-ghost btn-sm" id="signCancel">Cancel</button>
            <button type="button" class="btn btn-primary btn-sm" id="signConfirm">Confirm & Sign</button>
        </div>
        <form id="signForm" method="post" style="display:none">
            <input type="hidden" name="_token" id="signToken">
            <input type="hidden" name="signature_data" id="signData">
        </form>
    </div>
</div>
<script>
document.addEventListener('DOMContentLoaded', function(){
    var modal = document.getElementById('signModal');
    var canvas = document.getElementById('signCanvas');
    var ctx = canvas.getContext('2d');
    var drawing = false;
    var currentCertId = null;

    document.querySelectorAll('.sign-cert-btn').forEach(function(btn){
        btn.addEventListener('click', function(){
            currentCertId = this.dataset.certId;
            document.getElementById('signForm').action = '/training/certificate/' + currentCertId + '/sign';
            // Generate proper CSRF token via a hidden field
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            modal.style.display = 'flex';
        });
    });

    canvas.addEventListener('mousedown', function(e){ drawing = true; ctx.beginPath(); ctx.moveTo(e.offsetX, e.offsetY); });
    canvas.addEventListener('mousemove', function(e){ if(!drawing) return; ctx.lineWidth = 2; ctx.strokeStyle = '#fff'; ctx.lineCap = 'round'; ctx.lineTo(e.offsetX, e.offsetY); ctx.stroke(); });
    canvas.addEventListener('mouseup', function(){ drawing = false; });
    canvas.addEventListener('mouseleave', function(){ drawing = false; });

    document.getElementById('signClear').addEventListener('click', function(){ ctx.clearRect(0, 0, canvas.width, canvas.height); });
    document.getElementById('signCancel').addEventListener('click', function(){ modal.style.display = 'none'; });
    document.getElementById('signConfirm').addEventListener('click', function(){
        document.getElementById('signData').value = canvas.toDataURL('image/png');
        document.getElementById('signToken').value = document.querySelector('meta[name="csrf-token"]')?.content || '';
        document.getElementById('signForm').submit();
    });
});
</script>
{% endif %}
{% endif %}

