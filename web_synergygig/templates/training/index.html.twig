<script>
function saveProgress(enrollmentId, csrfToken) {
    var slider = document.getElementById('progSlider_' + enrollmentId);
    if (!slider) return;
    var progress = parseInt(slider.value, 10);
    var btn = slider.nextElementSibling;
    btn.textContent = '…';
    btn.disabled = true;

    var fd = new FormData();
    fd.append('_token', csrfToken);
    fd.append('progress', progress);

    fetch('/training/enrollment/' + enrollmentId + '/progress', { method: 'POST', body: fd })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (data.ok) {
                btn.textContent = '✅';
                document.getElementById('progLabel_' + enrollmentId).textContent = data.progress + '% progress';
                document.getElementById('progBar_' + enrollmentId).style.width = data.progress + '%';
                setTimeout(function(){ btn.textContent = '✓'; btn.disabled = false; }, 1500);
            } else {
                btn.textContent = '✕';
                btn.disabled = false;
            }
        })
        .catch(function() { btn.textContent = '✕'; btn.disabled = false; });
}
</script>
{% endif %}

