{% extends 'layouts/auth.html.twig' %}

{% block title %}Reset Password | SynergyGig{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .strength-bar { height: 4px; border-radius: 2px; background: var(--bg-tertiary); margin-top: 8px; overflow: hidden; }
        .strength-bar__fill { height: 100%; width: 0; border-radius: 2px; transition: width .3s, background .3s; }
        .strength-label { font-size: 0.7rem; margin-top: 4px; color: var(--text-muted); transition: color .3s; }
        .pwd-checks {
            display: grid; grid-template-columns: 1fr 1fr; gap: 2px var(--space-md);
            font-size: 0.75rem; margin: var(--space-sm) 0 var(--space-md);
        }
        .pwd-checks span { transition: color .2s; }
        .pwd-checks .pass { color: #16a34a; }
        .pwd-checks .fail { color: var(--text-muted); }
    </style>
{% endblock %}

{% block auth_body %}
    <div style="text-align:center;margin-bottom:var(--space-xl)">
        <div style="width:56px;height:56px;margin:0 auto var(--space-md);background:linear-gradient(135deg,rgba(16,163,127,.12),rgba(59,130,246,.12));border-radius:50%;display:flex;align-items:center;justify-content:center">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#10a37f" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
        </div>
        <h2 style="font-family:var(--font-heading);margin:0 0 var(--space-xs)">New Password</h2>
        <p style="color:var(--text-secondary);font-size:0.875rem;margin:0">Choose a strong password for your account</p>
    </div>

    <form method="post" action="{{ path('app_reset_password') }}" novalidate id="resetForm">
        <div class="form-group">
            <label class="form-label" for="password">New Password</label>
            <div style="position:relative">
                <input type="password" id="password" name="password" class="form-control" placeholder="••••••••" autocomplete="new-password" autofocus style="padding-right:2.5rem">
                <button type="button" class="pwd-toggle" data-target="password" style="position:absolute;right:.5rem;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;padding:4px;color:var(--text-muted)" aria-label="Toggle password visibility">
                    <svg class="eye-off" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
                    <svg class="eye-on" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:none"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                </button>
            </div>
            <div class="strength-bar"><div class="strength-bar__fill" id="strengthFill"></div></div>
            <div class="strength-label" id="strengthLabel">&nbsp;</div>
        </div>

        <div class="form-group">
            <label class="form-label" for="password_confirm">Confirm Password</label>
            <div style="position:relative">
                <input type="password" id="password_confirm" name="password_confirm" class="form-control" placeholder="••••••••" autocomplete="new-password" style="padding-right:2.5rem">
                <button type="button" class="pwd-toggle" data-target="password_confirm" style="position:absolute;right:.5rem;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;padding:4px;color:var(--text-muted)" aria-label="Toggle password visibility">
                    <svg class="eye-off" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
                    <svg class="eye-on" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:none"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                </button>
            </div>
        </div>

        <div class="pwd-checks" id="pwdChecks">
            <span id="chkLen" class="fail">✗ Min 8 characters</span>
            <span id="chkUpper" class="fail">✗ 1 uppercase letter</span>
            <span id="chkLower" class="fail">✗ 1 lowercase letter</span>
            <span id="chkDigit" class="fail">✗ 1 digit</span>
            <span id="chkMatch" class="fail">✗ Passwords match</span>
        </div>

        <button type="submit" class="btn btn-primary" id="resetBtn" style="width:100%">Reset Password</button>
    </form>

    <script>
    (function() {
        // Toggle visibility
        document.querySelectorAll('.pwd-toggle').forEach(function(btn) {
            btn.addEventListener('click', function() {
                var inp = document.getElementById(btn.dataset.target);
                var v = inp.type === 'password';
                inp.type = v ? 'text' : 'password';
                btn.querySelector('.eye-off').style.display = v ? 'none' : '';
                btn.querySelector('.eye-on').style.display = v ? '' : 'none';
            });
        });

        var p1 = document.getElementById('password');
        var p2 = document.getElementById('password_confirm');
        var fill = document.getElementById('strengthFill');
        var label = document.getElementById('strengthLabel');
        var checks = {
            len: document.getElementById('chkLen'),
            upper: document.getElementById('chkUpper'),
            lower: document.getElementById('chkLower'),
            digit: document.getElementById('chkDigit'),
            match: document.getElementById('chkMatch')
        };

        function update() {
            var v = p1.value, v2 = p2.value;
            var hasLen = v.length >= 8;
            var hasUpper = /[A-Z]/.test(v);
            var hasLower = /[a-z]/.test(v);
            var hasDigit = /\d/.test(v);
            var hasMatch = v.length > 0 && v === v2;

            set(checks.len, hasLen, '✓ Min 8 characters', '✗ Min 8 characters');
            set(checks.upper, hasUpper, '✓ 1 uppercase letter', '✗ 1 uppercase letter');
            set(checks.lower, hasLower, '✓ 1 lowercase letter', '✗ 1 lowercase letter');
            set(checks.digit, hasDigit, '✓ 1 digit', '✗ 1 digit');
            set(checks.match, hasMatch, '✓ Passwords match', '✗ Passwords match');

            // Strength bar
            var score = 0;
            if (v.length > 0) score++;
            if (hasLen) score++;
            if (hasUpper && hasLower) score++;
            if (hasDigit) score++;
            if (/[^A-Za-z0-9]/.test(v)) score++;

            var pct = (score / 5) * 100;
            var colors = ['#ef4444', '#f97316', '#eab308', '#22c55e', '#10b981'];
            var labels = ['Very Weak', 'Weak', 'Fair', 'Strong', 'Very Strong'];
            fill.style.width = pct + '%';
            fill.style.background = score > 0 ? colors[score - 1] : 'transparent';
            label.textContent = score > 0 ? labels[score - 1] : '';
            label.style.color = score > 0 ? colors[score - 1] : 'var(--text-muted)';
        }

        function set(el, ok, yes, no) {
            el.textContent = ok ? yes : no;
            el.className = ok ? 'pass' : 'fail';
        }

        p1.addEventListener('input', update);
        p2.addEventListener('input', update);

        document.getElementById('resetForm').addEventListener('submit', function(e) {
            var v = p1.value, v2 = p2.value;
            if (v.length < 8 || v !== v2) {
                e.preventDefault();
                if (v.length < 8) p1.focus();
                else p2.focus();
            }
        });
    })();
    </script>
{% endblock %}

{% block footer_links %}
    <a href="{{ path('app_login') }}">← Back to Sign In</a>
{% endblock %}
