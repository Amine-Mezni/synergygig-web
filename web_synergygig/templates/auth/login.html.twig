{% extends 'layouts/auth.html.twig' %}

{% block title %}Sign In | SynergyGig{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .auth-divider {
            margin: var(--space-lg) 0;
            text-align: center;
            color: var(--text-secondary);
            font-size: 0.8rem;
            position: relative;
        }
        .auth-divider::before,
        .auth-divider::after {
            content: '';
            position: absolute;
            top: 50%;
            width: 40%;
            height: 1px;
            background: var(--border-primary);
        }
        .auth-divider::before { left: 0; }
        .auth-divider::after { right: 0; }

        .login-icon {
            width: 56px; height: 56px; margin: 0 auto var(--space-md);
            background: linear-gradient(135deg, rgba(139,92,246,.12), rgba(59,130,246,.12));
            border-radius: 50%; display: flex; align-items: center; justify-content: center;
        }

        .form-group .form-label {
            display: flex; align-items: center; gap: 6px;
        }
        .form-group .form-label svg { color: var(--text-muted); }

        .forgot-link {
            display: block; text-align: right; font-size: 0.8rem; margin-top: 6px;
            color: var(--accent-blue); font-weight: 500; text-decoration: none;
        }
        .forgot-link:hover { color: var(--accent-purple); text-decoration: underline; }

        .btn-face {
            display: flex; align-items: center; justify-content: center; gap: 8px;
            width: 100%; padding: 0.65rem; border-radius: var(--radius-md);
            border: 1.5px solid var(--border-primary); background: transparent;
            color: var(--text-primary); font-size: 0.875rem; font-weight: 500;
            cursor: pointer; transition: border-color .2s, background .2s;
        }
        .btn-face:hover { border-color: var(--accent-purple); background: rgba(139,92,246,.06); }
        .btn-face svg { color: var(--accent-purple); }

        .face-modal {
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, 0.65);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 9999;
            padding: 1rem;
        }
        .face-modal__card {
            width: min(460px, 95vw);
            border: 1px solid var(--glass-border);
            background: var(--bg-secondary);
            border-radius: 14px;
            box-shadow: var(--shadow-xl);
            padding: 1rem;
        }
        .face-modal__video-wrap {
            position: relative;
            width: 100%;
            aspect-ratio: 4 / 3;
            border-radius: 10px;
            overflow: hidden;
            background: #000;
            margin-bottom: 0.75rem;
        }
        .face-modal__video,
        .face-modal__preview {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transform: scaleX(-1);
        }
        .face-modal__preview { display: none; transform: none; }
        .face-modal__guide {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 55%;
            height: 75%;
            border: 2px dashed rgba(45, 189, 196, 0.7);
            border-radius: 50%;
            pointer-events: none;
        }
        .face-modal__status {
            font-size: 0.82rem;
            color: var(--text-secondary);
            margin-bottom: 0.75rem;
        }
        .face-modal__fallback {
            margin-bottom: 0.75rem;
            padding: 0.6rem;
            border: 1px dashed var(--border-primary);
            border-radius: 8px;
            font-size: 0.8rem;
            color: var(--text-secondary);
            display: none;
        }
        .face-modal__fallback input {
            margin-top: 0.45rem;
            width: 100%;
        }
        .face-modal__actions {
            display: flex;
            gap: 0.5rem;
            justify-content: flex-end;
        }
    </style>
{% endblock %}

{% block auth_body %}
    <div style="text-align:center;margin-bottom:var(--space-xl)">
        <div class="login-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--accent-purple)" stroke-width="2"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/></svg>
        </div>
        <h2 style="font-family:var(--font-heading);margin:0 0 var(--space-xs)">Welcome Back</h2>
        <p style="color:var(--text-secondary);font-size:0.875rem;margin:0">Sign in to your workspace</p>
    </div>

    {% if error %}
        <div class="alert alert--danger" style="margin-bottom: var(--space-lg);">
            {{ error.messageKey|trans(error.messageData, 'security') }}
        </div>
    {% endif %}

    {% if app.session.get('oauth_error') %}
        <div class="alert alert--danger" style="margin-bottom: var(--space-lg);">
            {{ app.session.get('oauth_error') }}
            {% do app.session.remove('oauth_error') %}
        </div>
    {% endif %}

    <form method="post" action="{{ path('app_login') }}" novalidate id="loginForm">
        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
        <div class="form-group">
            <label class="form-label" for="email">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                Work Email
            </label>
            <input type="email" id="email" name="_username" class="form-control" placeholder="name@company.com" autocomplete="email" autofocus value="{{ last_username }}">
            <div class="field-error" id="emailError" style="display:none;color:#ef4444;font-size:.75rem;margin-top:4px"></div>
        </div>

        <div class="form-group">
            <label class="form-label" for="password">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                Password
            </label>
            <div style="position:relative">
                <input type="password" id="password" name="_password" class="form-control" autocomplete="current-password" placeholder="••••••••" style="padding-right:2.5rem">
                <button type="button" id="togglePwd" style="position:absolute;right:.5rem;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;padding:4px;color:var(--text-muted)" aria-label="Toggle password visibility">
                    <svg id="eyeOff" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
                    <svg id="eyeOn" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:none"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                </button>
            </div>
            <div class="field-error" id="pwdError" style="display:none;color:#ef4444;font-size:.75rem;margin-top:4px"></div>
            <a href="{{ path('app_forgot_password') }}" class="forgot-link">Forgot password?</a>
        </div>

        <button type="submit" class="btn btn-primary">Sign In</button>
    </form>

    <script>
    (function(){
        var t=document.getElementById('togglePwd'),p=document.getElementById('password'),a=document.getElementById('eyeOff'),b=document.getElementById('eyeOn');
        t.addEventListener('click',function(){var v=p.type==='password';p.type=v?'text':'password';a.style.display=v?'none':'';b.style.display=v?'':'none';});

        document.getElementById('loginForm').addEventListener('submit',function(e){
            var email=document.getElementById('email'),pwd=document.getElementById('password');
            var emailErr=document.getElementById('emailError'),pwdErr=document.getElementById('pwdError');
            var ok=true;
            emailErr.style.display='none'; pwdErr.style.display='none';
            if(!email.value.trim()){emailErr.textContent='Email is required.';emailErr.style.display='block';ok=false;}
            if(!pwd.value){pwdErr.textContent='Password is required.';pwdErr.style.display='block';ok=false;}
            else if(pwd.value.length<8){pwdErr.textContent='Password must be at least 8 characters.';pwdErr.style.display='block';ok=false;}
            if(!ok)e.preventDefault();
        });
    })();
    </script>

    <div class="auth-divider">or continue with</div>
    <div style="display:flex;gap:0.75rem;margin-bottom:0.5rem">
        <a href="{{ path('connect_google') }}" class="btn-face" style="flex:1;text-decoration:none">
            {# Google G logo #}
            <svg width="18" height="18" viewBox="0 0 48 48"><path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.02 17.74 9.5 24 9.5z"/><path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/><path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/><path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.18 1.48-4.97 2.31-8.16 2.31-6.26 0-11.57-3.52-13.47-8.41l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/></svg>
            Google
        </a>
        <a href="{{ path('connect_github') }}" class="btn-face" style="flex:1;text-decoration:none">
            {# GitHub mark #}
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.385-1.335-1.755-1.335-1.755-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23A11.52 11.52 0 0 1 12 6.82c1.02.005 2.047.138 3.006.404 2.29-1.552 3.297-1.23 3.297-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.605-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 21.795 24 17.295 24 12c0-6.63-5.37-12-12-12z"/></svg>
            GitHub
        </a>
    </div>

    <div class="auth-divider">or</div>
    <button type="button" class="btn-face" id="faceLoginBtn">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="1" width="22" height="22" rx="3"/><circle cx="12" cy="10" r="3"/><path d="M7 20v-1a5 5 0 0 1 10 0v1"/></svg>
        Sign in with Face ID
    </button>

    <div class="face-modal" id="faceModal" aria-hidden="true">
        <div class="face-modal__card">
            <div style="font-weight:600;margin-bottom:0.5rem">Face ID Login</div>
            <div class="face-modal__video-wrap" id="faceVideoWrap">
                <video id="faceVideo" class="face-modal__video" autoplay playsinline muted></video>
                <img id="facePreview" class="face-modal__preview" alt="Captured face">
                <div class="face-modal__guide"></div>
            </div>
            <div class="face-modal__status" id="faceStatus">Starting camera...</div>
            <div class="face-modal__fallback" id="faceFallbackWrap">
                Camera unavailable. You can upload a selfie image instead.
                <input type="file" id="faceUploadInput" accept="image/*">
            </div>
            <form id="faceLoginForm" method="post" action="{{ path('app_login_face') }}">
                <input type="hidden" name="face_image" id="faceImageInput">
                <input type="hidden" name="email" id="faceEmailInput">
                <div class="face-modal__actions">
                    <button type="button" class="btn btn-ghost btn-sm" id="faceCloseBtn">Cancel</button>
                    <button type="button" class="btn btn-secondary btn-sm" id="faceCaptureBtn" disabled>Capture</button>
                    <button type="submit" class="btn btn-primary btn-sm" id="faceSubmitBtn" style="display:none">Sign In</button>
                </div>
            </form>
        </div>
    </div>

{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
    (function() {
        var openBtn = document.getElementById('faceLoginBtn');
        var modal = document.getElementById('faceModal');
        var closeBtn = document.getElementById('faceCloseBtn');
        var captureBtn = document.getElementById('faceCaptureBtn');
        var submitBtn = document.getElementById('faceSubmitBtn');
        var statusEl = document.getElementById('faceStatus');
        var video = document.getElementById('faceVideo');
        var preview = document.getElementById('facePreview');
        var faceImageInput = document.getElementById('faceImageInput');
        var faceEmailInput = document.getElementById('faceEmailInput');
        var emailInput = document.getElementById('email');
        var fallbackWrap = document.getElementById('faceFallbackWrap');
        var uploadInput = document.getElementById('faceUploadInput');
        var form = document.getElementById('faceLoginForm');
        var stream = null;
        var cameraReady = false;
        var requestTimeoutId = null;

        function setStatus(text, isError) {
            statusEl.textContent = text;
            statusEl.style.color = isError ? 'var(--danger,#E53E3E)' : 'var(--text-secondary)';
        }

        function stopCamera() {
            if (stream) {
                stream.getTracks().forEach(function(track) { track.stop(); });
            }
            stream = null;
            cameraReady = false;
        }

        function closeModal() {
            modal.style.display = 'none';
            modal.setAttribute('aria-hidden', 'true');
            stopCamera();
            if (requestTimeoutId) {
                clearTimeout(requestTimeoutId);
                requestTimeoutId = null;
            }
            faceImageInput.value = '';
            faceEmailInput.value = '';
            uploadInput.value = '';
            fallbackWrap.style.display = 'none';
            preview.style.display = 'none';
            video.style.display = '';
            captureBtn.style.display = '';
            captureBtn.disabled = true;
            submitBtn.style.display = 'none';
            submitBtn.disabled = false;
            submitBtn.textContent = 'Sign In';
        }

        function startCamera() {
            setStatus('Starting camera...', false);
            if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) {
                setStatus('Camera is not available in this browser. Use upload fallback.', true);
                fallbackWrap.style.display = 'block';
                submitBtn.style.display = '';
                return;
            }
            navigator.mediaDevices.getUserMedia({ video: { width: 640, height: 480, facingMode: 'user' } })
                .then(function(s) {
                    stream = s;
                    video.srcObject = s;
                    video.onloadedmetadata = function() {
                        video.play();
                    };
                    video.onplaying = function() {
                        cameraReady = true;
                        captureBtn.disabled = false;
                        setStatus('Camera ready. Capture your face.', false);
                    };
                })
                .catch(function(err) {
                    setStatus('Could not access camera: ' + (err.message || err.name || 'Unknown error'), true);
                    fallbackWrap.style.display = 'block';
                    submitBtn.style.display = '';
                });
        }

        openBtn.addEventListener('click', function() {
            var emailValue = (emailInput.value || '').trim();
            faceEmailInput.value = emailValue;

            modal.style.display = 'flex';
            modal.setAttribute('aria-hidden', 'false');
            startCamera();
        });

        closeBtn.addEventListener('click', closeModal);

        modal.addEventListener('click', function(e) {
            if (e.target === modal) {
                closeModal();
            }
        });

        captureBtn.addEventListener('click', function() {
            if (!cameraReady || video.videoWidth === 0) {
                setStatus('Camera is not ready yet. Please wait.', true);
                return;
            }
            var canvas = document.createElement('canvas');
            canvas.width = video.videoWidth;
            canvas.height = video.videoHeight;
            canvas.getContext('2d').drawImage(video, 0, 0);
            var dataUrl = canvas.toDataURL('image/png');
            faceImageInput.value = dataUrl;
            preview.src = dataUrl;
            preview.style.display = 'block';
            video.style.display = 'none';
            captureBtn.style.display = 'none';
            submitBtn.style.display = '';
            setStatus('Face captured. Click Sign In.', false);
            stopCamera();
        });

        uploadInput.addEventListener('change', function() {
            var file = uploadInput.files && uploadInput.files[0];
            if (!file) {
                return;
            }
            var reader = new FileReader();
            reader.onload = function(ev) {
                var result = ev.target && ev.target.result ? String(ev.target.result) : '';
                faceImageInput.value = result;
                preview.src = result;
                preview.style.display = 'block';
                video.style.display = 'none';
                captureBtn.style.display = 'none';
                submitBtn.style.display = '';
                setStatus('Image loaded. Click Sign In.', false);
            };
            reader.onerror = function() {
                setStatus('Could not read uploaded image.', true);
            };
            reader.readAsDataURL(file);
        });

        form.addEventListener('submit', function(e) {
            e.preventDefault();
            if (!faceImageInput.value) {
                setStatus('Capture your face before signing in.', true);
                return;
            }

            faceEmailInput.value = (emailInput.value || '').trim();

            submitBtn.disabled = true;
            submitBtn.textContent = 'Signing in...';
            setStatus('Verifying face...', false);

            var payload = new FormData(form);
            var controller = new AbortController();
            requestTimeoutId = setTimeout(function() {
                controller.abort();
            }, 20000);

            fetch(form.action, {
                method: 'POST',
                body: payload,
                signal: controller.signal,
                headers: {
                    'X-Requested-With': 'XMLHttpRequest'
                }
            })
            .then(function(resp) {
                return resp.text().then(function(text) {
                    var data;
                    try {
                        data = JSON.parse(text);
                    } catch (e) {
                        data = {
                            success: false,
                            message: resp.ok ? 'Invalid server response.' : 'Face login request failed (' + resp.status + ').'
                        };
                    }
                    data.__httpOk = resp.ok;
                    return data;
                });
            })
            .then(function(data) {
                if (requestTimeoutId) {
                    clearTimeout(requestTimeoutId);
                    requestTimeoutId = null;
                }
                if (data.success && data.__httpOk) {
                    setStatus(data.message || 'Face recognized. Redirecting...', false);
                    window.location.href = data.redirect || '{{ path('app_dashboard') }}';
                    return;
                }

                setStatus(data.message || 'Face login failed.', true);
                submitBtn.disabled = false;
                submitBtn.textContent = 'Sign In';
            })
            .catch(function(err) {
                if (requestTimeoutId) {
                    clearTimeout(requestTimeoutId);
                    requestTimeoutId = null;
                }
                if (err && err.name === 'AbortError') {
                    setStatus('Face verification timed out. Try again with better lighting.', true);
                } else {
                    setStatus('Network error during face login.', true);
                }
                submitBtn.disabled = false;
                submitBtn.textContent = 'Sign In';
            });
        });

        window.addEventListener('beforeunload', stopCamera);
    })();
    </script>
{% endblock %}

{% block footer_links %}
    Don't have an account? <a href="{{ path('app_signup') }}">Apply Now</a>
{% endblock %}
