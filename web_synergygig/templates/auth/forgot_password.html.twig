{% extends 'layouts/auth.html.twig' %}

{% block title %}Forgot Password | SynergyGig{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .otp-sent-icon {
            width: 64px; height: 64px; margin: 0 auto var(--space-md);
            background: linear-gradient(135deg, rgba(139,92,246,.15), rgba(59,130,246,.15));
            border-radius: 50%; display: flex; align-items: center; justify-content: center;
        }
        .otp-sent-icon svg { color: var(--accent-purple); }
        .email-highlight {
            font-weight: 600; color: var(--accent-blue);
        }
        .resend-row {
            display: flex; align-items: center; justify-content: center;
            gap: var(--space-xs); margin-top: var(--space-md);
            font-size: 0.8rem; color: var(--text-secondary);
        }
        .resend-row button {
            background: none; border: none; color: var(--accent-blue);
            font-weight: 500; cursor: pointer; font-size: 0.8rem; padding: 0;
        }
        .resend-row button:disabled { color: var(--text-muted); cursor: default; }
    </style>
{% endblock %}

{% block auth_body %}
    {% if not email_sent %}
        <div style="text-align:center;margin-bottom:var(--space-xl)">
            <div style="width:56px;height:56px;margin:0 auto var(--space-md);background:linear-gradient(135deg,rgba(139,92,246,.12),rgba(59,130,246,.12));border-radius:50%;display:flex;align-items:center;justify-content:center">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--accent-purple)" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            </div>
            <h2 style="font-family:var(--font-heading);margin:0 0 var(--space-xs)">Forgot Password?</h2>
            <p style="color:var(--text-secondary);font-size:0.875rem;margin:0">Enter your email and we'll send you a 6-digit reset code</p>
        </div>

        <form method="post" action="{{ path('app_forgot_password') }}" novalidate id="forgotForm">
            <div class="form-group">
                <label class="form-label" for="email">Work Email</label>
                <input type="email" id="email" name="email" class="form-control" placeholder="name@company.com" autocomplete="email" autofocus required>
                <div class="field-error" id="emailError" style="display:none;color:#ef4444;font-size:.75rem;margin-top:4px"></div>
            </div>
            <button type="submit" class="btn btn-primary" id="sendBtn">
                <span id="sendText">Send Reset Code</span>
                <span id="sendSpinner" style="display:none">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="animation:spin .8s linear infinite"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>
                </span>
            </button>
        </form>

        <script>
        document.getElementById('forgotForm').addEventListener('submit', function(e) {
            var email = document.getElementById('email');
            var err = document.getElementById('emailError');
            err.style.display = 'none';
            if (!email.value.trim()) {
                err.textContent = 'Email is required.';
                err.style.display = 'block';
                e.preventDefault();
                return;
            }
            if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email.value.trim())) {
                err.textContent = 'Please enter a valid email address.';
                err.style.display = 'block';
                e.preventDefault();
                return;
            }
            document.getElementById('sendText').style.display = 'none';
            document.getElementById('sendSpinner').style.display = 'inline-flex';
            document.getElementById('sendBtn').disabled = true;
        });
        </script>
        <style>@keyframes spin { to { transform: rotate(360deg); } }</style>

    {% else %}
        {# Email sent → show success + link to verify #}
        <div style="text-align:center">
            <div class="otp-sent-icon">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            </div>
            <h2 style="font-family:var(--font-heading);margin:0 0 var(--space-xs)">Check Your Email</h2>
            <p style="color:var(--text-secondary);font-size:0.875rem;margin:0 0 var(--space-lg)">
                We've sent a 6-digit code to<br><span class="email-highlight">{{ sent_email }}</span>
            </p>
            <a href="{{ path('app_verify_otp') }}" class="btn btn-primary" style="width:100%">Enter Reset Code</a>

            <div class="resend-row">
                <span>Didn't receive the code?</span>
                <form method="post" action="{{ path('app_forgot_password') }}" style="display:inline">
                    <input type="hidden" name="email" value="{{ sent_email }}">
                    <button type="submit" id="resendBtn">Resend</button>
                </form>
            </div>
        </div>
    {% endif %}
{% endblock %}

{% block footer_links %}
    <a href="{{ path('app_login') }}">← Back to Sign In</a>
{% endblock %}
