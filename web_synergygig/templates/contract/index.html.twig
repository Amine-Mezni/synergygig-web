{% extends 'layouts/admin.html.twig' %}

{% block page_title %}Contracts{% endblock %}

{% block header_actions %}
    {% if is_granted('ROLE_HR') %}
    <a href="{{ path('app_contract_new') }}" class="btn btn-primary btn-sm">+ New Contract</a>
    {% endif %}
{% endblock %}

{% block content %}
{# Filter bar #}
<div class="card" style="padding:var(--space-md) var(--space-lg);margin-bottom:var(--space-lg);display:flex;align-items:center;gap:var(--space-md)">
    <form method="get" action="{{ path('app_contract_index') }}" style="flex:1;display:flex;align-items:center;gap:var(--space-md)">
        <select name="status" class="form-control form-select" style="width:auto;min-width:140px">
            <option value="">All Status</option>
            <option value="DRAFT" {{ app.request.query.get('status') == 'DRAFT' ? 'selected' }}>Draft</option>
            <option value="NEGOTIATING" {{ app.request.query.get('status') == 'NEGOTIATING' ? 'selected' }}>Negotiating</option>
            <option value="SIGNED" {{ app.request.query.get('status') == 'SIGNED' ? 'selected' }}>Signed</option>
            <option value="EXPIRED" {{ app.request.query.get('status') == 'EXPIRED' ? 'selected' }}>Expired</option>
        </select>
        <button type="submit" class="btn btn-secondary btn-sm">Filter</button>
    </form>
</div>

<div class="card">
    {% if contracts|length > 0 %}
    <div class="table-wrap">
        <table class="table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Offer</th>
                    <th>Applicant</th>
                    <th>Owner</th>
                    <th>Amount</th>
                    <th>Period</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for c in contracts %}
                <tr>
                    <td class="text-muted">{{ c.id }}</td>
                    <td>{% if c.offer %}<a href="{{ path('app_offer_show', {id: c.offer.id}) }}" style="color:var(--accent-blue)">{{ c.offer.title }}</a>{% else %}—{% endif %}</td>
                    <td>
                        {% if c.applicant %}
                            <div style="display:flex;align-items:center;gap:0.5rem">
                                <div class="avatar avatar--sm">{{ c.applicant.firstName|first }}{{ c.applicant.lastName|first }}</div>
                                {{ c.applicant.firstName }} {{ c.applicant.lastName }}
                            </div>
                        {% else %}—{% endif %}
                    </td>
                    <td>{% if c.owner %}{{ c.owner.firstName }} {{ c.owner.lastName }}{% else %}—{% endif %}</td>
                    <td>{% if c.amount %}{{ c.amount|number_format(2) }} {{ c.currency }}{% else %}—{% endif %}</td>
                    <td>
                        {% if c.startDate %}{{ c.startDate|date('M d, Y') }}{% endif %}
                        {% if c.startDate and c.endDate %} → {% endif %}
                        {% if c.endDate %}{{ c.endDate|date('M d, Y') }}{% endif %}
                        {% if not c.startDate and not c.endDate %}—{% endif %}
                    </td>
                    <td>
                        {% set sc = {'DRAFT': 'blue', 'PENDING_SIGNATURE': 'orange', 'ACTIVE': 'green', 'COMPLETED': 'green', 'TERMINATED': 'red', 'DISPUTED': 'purple'} %}
                        <span class="badge badge--{{ sc[c.status] ?? 'blue' }}">{{ c.status ?? 'N/A' }}</span>
                    </td>
                    <td>
                        <details class="crud-actions-menu">
                            <summary class="btn btn-ghost btn-sm" title="Actions"><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="5" r="2"/><circle cx="12" cy="12" r="2"/><circle cx="12" cy="19" r="2"/></svg></summary>
                            <div class="crud-actions-dropdown">
                                <a href="{{ path('app_contract_show', {id: c.id}) }}" class="crud-action-item"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg> View</a>
                                {% if is_granted('ROLE_HR') %}
                                <a href="{{ path('app_contract_edit', {id: c.id}) }}" class="crud-action-item"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg> Edit</a>
                                <form method="post" action="{{ path('app_contract_delete', {id: c.id}) }}" onsubmit="return confirm('Delete this contract?')">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ c.id) }}">
                                    <button type="submit" class="crud-action-item crud-action-danger"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg> Delete</button>
                                </form>
                                {% endif %}
                            </div>
                        </details>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    {% else %}
    <div style="text-align:center;padding:3rem">
        <p class="text-muted">No contracts yet.</p>
        <a href="{{ path('app_contract_new') }}" class="btn btn-primary" style="margin-top:1rem">+ Create Contract</a>
    </div>
    {% endif %}
</div>

{% if pagination is defined %}{% include 'components/_pagination.html.twig' %}{% endif %}
{% endblock %}
