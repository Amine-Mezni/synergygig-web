{% extends 'layouts/admin.html.twig' %}

{% block page_title %}Contract #{{ contract.id }}{% endblock %}

{% block header_actions %}
    {% if is_granted('ROLE_HR') %}
    <a href="{{ path('app_contract_edit', {id: contract.id}) }}" class="btn btn-primary btn-sm">Edit</a>
    {% endif %}
    <a href="{{ path('app_contract_index') }}" class="btn btn-ghost btn-sm">Back</a>
{% endblock %}

{% block content %}
{# Stat cards #}
<div class="bento-grid" style="grid-template-columns:repeat(4,1fr);gap:1rem;margin-bottom:1.5rem">
    <div class="card" style="padding:1.25rem;text-align:center">
        <div class="text-muted" style="font-size:0.75rem;margin-bottom:0.25rem">Status</div>
        {% set sc = {'DRAFT': 'blue', 'PENDING_REVIEW': 'orange', 'COUNTER_PROPOSED': 'purple', 'PENDING_SIGNATURE': 'orange', 'ACTIVE': 'green', 'COMPLETED': 'green', 'TERMINATED': 'red', 'DISPUTED': 'purple'} %}
        <span class="badge badge--{{ sc[contract.status] ?? 'blue' }}">{{ contract.status ?? 'N/A' }}</span>
    </div>
    <div class="card" style="padding:1.25rem;text-align:center">
        <div class="text-muted" style="font-size:0.75rem;margin-bottom:0.25rem">Amount</div>
        <div style="font-size:1.25rem;font-weight:700;color:var(--accent-blue)">{% if contract.amount %}{{ contract.amount|number_format(2) }} {{ contract.currency }}{% else %}—{% endif %}</div>
    </div>
    <div class="card" style="padding:1.25rem;text-align:center">
        <div class="text-muted" style="font-size:0.75rem;margin-bottom:0.25rem">Applicant</div>
        <div style="font-weight:600;color:var(--text-primary)">{% if contract.applicant %}{{ contract.applicant.firstName }} {{ contract.applicant.lastName }}{% else %}—{% endif %}</div>
    </div>
    <div class="card" style="padding:1.25rem;text-align:center">
        <div class="text-muted" style="font-size:0.75rem;margin-bottom:0.25rem">Risk Score</div>
        <div style="font-size:1.25rem;font-weight:700;{% if contract.riskScore and contract.riskScore > 70 %}color:var(--color-danger){% elseif contract.riskScore and contract.riskScore > 40 %}color:var(--color-warning){% else %}color:var(--color-success){% endif %}">{{ contract.riskScore ?? '—' }}</div>
    </div>
</div>

{# Terms #}
{% if contract.terms %}
<div class="card" style="margin-bottom:1.5rem">
    <div class="card__header"><h4>Contract Terms</h4></div>
    <div class="card__body"><p style="white-space:pre-wrap">{{ contract.terms }}</p></div>
</div>
{% endif %}

{# Details table #}
<div class="card" style="margin-bottom:1.5rem">
    <div class="card__header"><h4>Details</h4></div>
    <div class="table-wrap">
        <table class="table">
            <tr><td class="text-muted" style="width:200px">Offer</td><td>{% if contract.offer %}<a href="{{ path('app_offer_show', {id: contract.offer.id}) }}" style="color:var(--accent-blue)">{{ contract.offer.title }}</a>{% else %}—{% endif %}</td></tr>
            <tr><td class="text-muted">Owner</td><td>{% if contract.owner %}{{ contract.owner.firstName }} {{ contract.owner.lastName }}{% else %}—{% endif %}</td></tr>
            <tr><td class="text-muted">Start Date</td><td>{{ contract.startDate ? contract.startDate|date('M d, Y') : '—' }}</td></tr>
            <tr><td class="text-muted">End Date</td><td>{{ contract.endDate ? contract.endDate|date('M d, Y') : '—' }}</td></tr>
            <tr><td class="text-muted">Signed At</td><td>{{ contract.signedAt ? contract.signedAt|date('M d, Y H:i') : '—' }}</td></tr>
            <tr><td class="text-muted">Blockchain Hash</td><td style="font-family:monospace;font-size:0.8rem;word-break:break-all">{{ contract.blockchainHash ?? '—' }}</td></tr>
            <tr><td class="text-muted">Created</td><td>{{ contract.createdAt ? contract.createdAt|date('M d, Y H:i') : '—' }}</td></tr>
        </table>
    </div>
</div>

{# ── Negotiation section ── #}
<div class="card" style="margin-bottom:1.5rem">
    <div class="card__header"><h4>🤝 Negotiation</h4></div>
    <div class="card__body">
        {% if contract.negotiationRound %}
            <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;margin-bottom:1rem">
                <div>
                    <div class="text-muted" style="font-size:0.75rem;margin-bottom:0.25rem">Round</div>
                    <div style="font-size:1.25rem;font-weight:700;color:var(--accent-blue)">{{ contract.negotiationRound }}</div>
                </div>
                {% if contract.counterAmount %}
                <div>
                    <div class="text-muted" style="font-size:0.75rem;margin-bottom:0.25rem">Counter Amount</div>
                    <div style="font-size:1.25rem;font-weight:700;color:var(--color-warning)">{{ contract.counterAmount|number_format(2) }} {{ contract.currency }}</div>
                </div>
                {% endif %}
                <div>
                    <div class="text-muted" style="font-size:0.75rem;margin-bottom:0.25rem">Status</div>
                    <span class="badge badge--{{ contract.status == 'COUNTER_PROPOSED' ? 'purple' : 'green' }}">{{ contract.status }}</span>
                </div>
            </div>
            {% if contract.counterTerms %}
                <div style="margin-bottom:1rem">
                    <div class="text-muted" style="font-size:0.75rem;margin-bottom:0.25rem">Counter Terms</div>
                    <div style="background:var(--bg-secondary);border-radius:var(--radius-md);padding:1rem;white-space:pre-wrap;color:var(--text-primary)">{{ contract.counterTerms }}</div>
                </div>
            {% endif %}
            {% if contract.negotiationNotes %}
                <div>
                    <div class="text-muted" style="font-size:0.75rem;margin-bottom:0.25rem">Notes</div>
                    <div style="background:var(--bg-secondary);border-radius:var(--radius-md);padding:1rem;white-space:pre-wrap;color:var(--text-primary)">{{ contract.negotiationNotes }}</div>
                </div>
            {% endif %}
        {% endif %}

        {% if contract.status not in ['ACTIVE', 'COMPLETED', 'TERMINATED'] and is_granted('ROLE_HR') %}
        <div style="margin-top:1.5rem;border-top:1px solid var(--glass-border);padding-top:1.5rem">
            <h5 style="margin-bottom:1rem;color:var(--text-primary)">Submit Counter-Proposal</h5>
            <form method="post" action="{{ path('app_contract_negotiate', {id: contract.id}) }}" novalidate>
                <input type="hidden" name="_token" value="{{ csrf_token('negotiate' ~ contract.id) }}">

                <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem">
                    <div class="form-group">
                        <label class="form-label">Counter Amount ({{ contract.currency ?? 'USD' }})</label>
                        <input type="number" name="counter_amount" class="form-control" step="0.01" placeholder="Enter proposed amount">
                    </div>
                    <div class="form-group">
                        <label class="form-label">Current Offer</label>
                        <input type="text" class="form-control" value="{{ contract.amount ? contract.amount|number_format(2) ~ ' ' ~ contract.currency : '—' }}" disabled>
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">Counter Terms</label>
                    <textarea name="counter_terms" class="form-control" rows="4" placeholder="Propose alternative terms... (min 10 chars)"></textarea>
                </div>

                <div class="form-group">
                    <label class="form-label">Notes</label>
                    <textarea name="negotiation_notes" class="form-control" rows="2" placeholder="Additional notes..."></textarea>
                </div>

                <button type="submit" class="btn btn-secondary">Submit Counter-Proposal</button>
            </form>
        </div>
        {% endif %}
    </div>
</div>

{# ── Signature section ── #}
<div class="card" style="margin-bottom:1.5rem">
    <div class="card__header"><h4>✍️ Digital Signature</h4></div>
    <div class="card__body">
        {% if contract.signatureData %}
            <div style="text-align:center;margin-bottom:1rem">
                <div class="text-muted" style="font-size:0.75rem;margin-bottom:0.5rem">Signature on file</div>
                <div style="background:#fff;border-radius:var(--radius-md);display:inline-block;padding:1rem">
                    <img src="{{ contract.signatureData }}" alt="Signature" style="max-width:400px;max-height:150px">
                </div>
                <div style="margin-top:0.5rem;font-size:0.8rem;color:var(--text-muted)">
                    Signed {{ contract.signedAt ? contract.signedAt|date('M d, Y \\a\\t H:i') : '' }}
                </div>
            </div>
            {% if contract.blockchainHash %}
            <div style="background:var(--bg-secondary);border-radius:var(--radius-md);padding:1rem;margin-top:1rem">
                <div class="text-muted" style="font-size:0.75rem;margin-bottom:0.25rem">Verification Hash (SHA-256)</div>
                <code style="font-size:0.75rem;color:var(--accent-blue);word-break:break-all">{{ contract.blockchainHash }}</code>
            </div>
            {% endif %}
        {% else %}
            {% if contract.status in ['DRAFT', 'PENDING_REVIEW', 'COUNTER_PROPOSED', 'PENDING_SIGNATURE'] %}
            <p style="color:var(--text-secondary);margin-bottom:1rem">Draw your signature below to sign this contract.</p>
            <form method="post" action="{{ path('app_contract_sign', {id: contract.id}) }}" id="signForm">
                <input type="hidden" name="_token" value="{{ csrf_token('sign' ~ contract.id) }}">
                <input type="hidden" name="signature_data" id="signatureDataInput">

                <div style="position:relative;border:2px dashed var(--glass-border);border-radius:var(--radius-md);background:#fff;margin-bottom:1rem">
                    <canvas id="signatureCanvas" width="600" height="200" style="display:block;width:100%;cursor:crosshair"></canvas>
                </div>

                <div style="display:flex;gap:0.5rem">
                    <button type="button" id="clearSignature" class="btn btn-ghost btn-sm">Clear</button>
                    <button type="submit" class="btn btn-primary">Sign Contract</button>
                </div>
            </form>
            {% else %}
                <p class="text-muted">Contract is {{ contract.status|lower }} — signature not applicable.</p>
            {% endif %}
        {% endif %}
    </div>
</div>

{# Risk factors #}
{% if contract.riskFactors %}
<div class="card" style="margin-bottom:1.5rem">
    <div class="card__header"><h4>⚠️ Risk Factors</h4></div>
    <div class="card__body">
        <div style="display:flex;align-items:center;gap:1rem;margin-bottom:1rem">
            <div style="width:60px;height:60px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:1.25rem;font-weight:700;
                {% if contract.riskScore > 70 %}background:rgba(220,38,38,0.15);color:var(--color-danger)
                {% elseif contract.riskScore > 40 %}background:rgba(251,191,36,0.15);color:var(--color-warning)
                {% else %}background:rgba(16,185,129,0.15);color:var(--color-success){% endif %}">
                {{ contract.riskScore }}
            </div>
            <div>
                <div style="font-weight:600;color:var(--text-primary)">
                    {% if contract.riskScore > 70 %}High Risk
                    {% elseif contract.riskScore > 40 %}Medium Risk
                    {% else %}Low Risk{% endif %}
                </div>
                <div style="font-size:0.8rem;color:var(--text-muted)">Score out of 100</div>
            </div>
        </div>
        <p style="white-space:pre-wrap;color:var(--text-secondary)">{{ contract.riskFactors }}</p>
    </div>
</div>
{% endif %}

{# Delete #}
{% if is_granted('ROLE_HR') %}
<div style="margin-top:2rem">
    <form method="post" action="{{ path('app_contract_delete', {id: contract.id}) }}" onsubmit="return confirm('Delete this contract?')">
        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ contract.id) }}">
        <button class="btn btn-danger btn-sm">Delete Contract</button>
    </form>
</div>
{% endif %}
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
(function(){
    var canvas = document.getElementById('signatureCanvas');
    if (!canvas) return;
    var ctx = canvas.getContext('2d');
    var drawing = false;
    var hasDrawn = false;

    function getPos(e) {
        var r = canvas.getBoundingClientRect();
        var scaleX = canvas.width / r.width;
        var scaleY = canvas.height / r.height;
        if (e.touches) {
            return { x: (e.touches[0].clientX - r.left) * scaleX, y: (e.touches[0].clientY - r.top) * scaleY };
        }
        return { x: (e.clientX - r.left) * scaleX, y: (e.clientY - r.top) * scaleY };
    }

    function startDraw(e) {
        e.preventDefault();
        drawing = true;
        hasDrawn = true;
        var p = getPos(e);
        ctx.beginPath();
        ctx.moveTo(p.x, p.y);
    }
    function draw(e) {
        if (!drawing) return;
        e.preventDefault();
        var p = getPos(e);
        ctx.lineWidth = 2.5;
        ctx.lineCap = 'round';
        ctx.lineJoin = 'round';
        ctx.strokeStyle = '#111';
        ctx.lineTo(p.x, p.y);
        ctx.stroke();
    }
    function stopDraw() { drawing = false; }

    canvas.addEventListener('mousedown', startDraw);
    canvas.addEventListener('mousemove', draw);
    canvas.addEventListener('mouseup', stopDraw);
    canvas.addEventListener('mouseleave', stopDraw);
    canvas.addEventListener('touchstart', startDraw, {passive: false});
    canvas.addEventListener('touchmove', draw, {passive: false});
    canvas.addEventListener('touchend', stopDraw);

    document.getElementById('clearSignature').addEventListener('click', function() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        hasDrawn = false;
    });

    document.getElementById('signForm').addEventListener('submit', function(e) {
        if (!hasDrawn) {
            e.preventDefault();
            alert('Please draw your signature first.');
            return;
        }
        document.getElementById('signatureDataInput').value = canvas.toDataURL('image/png');
    });
})();
</script>
{% endblock %}
