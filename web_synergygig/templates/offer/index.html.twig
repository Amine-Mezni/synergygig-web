{% extends 'layouts/admin.html.twig' %}

{% block page_title %}Job Offers{% endblock %}

{% block header_actions %}
    {% if is_granted('ROLE_HR') %}
    <a href="{{ path('app_offer_new') }}" class="btn btn-primary btn-sm">+ New Offer</a>
    {% endif %}
{% endblock %}

{% block content %}
{# Search & Filter bar #}
<div class="card" style="padding:var(--space-md) var(--space-lg);margin-bottom:var(--space-lg);display:flex;align-items:center;gap:var(--space-md)">
    <form method="get" action="{{ path('app_offer_index') }}" style="flex:1;display:flex;align-items:center;gap:var(--space-md);flex-wrap:wrap">
        <div style="position:relative;flex:1;min-width:180px">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--text-muted)" stroke-width="2" style="position:absolute;left:.75rem;top:50%;transform:translateY(-50%)"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <input type="text" name="q" value="{{ app.request.query.get('q') }}" placeholder="Search offers..." class="form-control" style="padding-left:2.25rem">
        </div>
        <select name="status" class="form-control form-select" style="width:auto;min-width:120px">
            <option value="">All Status</option>
            <option value="DRAFT" {{ app.request.query.get('status') == 'DRAFT' ? 'selected' }}>Draft</option>
            <option value="OPEN" {{ app.request.query.get('status') == 'OPEN' ? 'selected' }}>Open</option>
            <option value="CLOSED" {{ app.request.query.get('status') == 'CLOSED' ? 'selected' }}>Closed</option>
            <option value="CANCELLED" {{ app.request.query.get('status') == 'CANCELLED' ? 'selected' }}>Cancelled</option>
        </select>
        <select name="type" class="form-control form-select" style="width:auto;min-width:120px">
            <option value="">All Types</option>
            <option value="FULL_TIME" {{ app.request.query.get('type') == 'FULL_TIME' ? 'selected' }}>Full Time</option>
            <option value="PART_TIME" {{ app.request.query.get('type') == 'PART_TIME' ? 'selected' }}>Part Time</option>
            <option value="FREELANCE" {{ app.request.query.get('type') == 'FREELANCE' ? 'selected' }}>Freelance</option>
            <option value="INTERNSHIP" {{ app.request.query.get('type') == 'INTERNSHIP' ? 'selected' }}>Internship</option>
            <option value="CONTRACT" {{ app.request.query.get('type') == 'CONTRACT' ? 'selected' }}>Contract</option>
        </select>
        <select name="sort" class="form-control form-select" style="width:auto;min-width:120px">
            <option value="recent" {{ app.request.query.get('sort','recent') == 'recent' ? 'selected' }}>Most Recent</option>
            <option value="oldest" {{ app.request.query.get('sort') == 'oldest' ? 'selected' }}>Oldest</option>
            <option value="budget_desc" {{ app.request.query.get('sort') == 'budget_desc' ? 'selected' }}>Budget ↓</option>
            <option value="budget_asc" {{ app.request.query.get('sort') == 'budget_asc' ? 'selected' }}>Budget ↑</option>
        </select>
        <button type="submit" class="btn btn-secondary btn-sm">Filter</button>
    </form>
</div>

<div class="card">
    {% if offers|length > 0 %}
    <div class="table-wrap">
        <table class="table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Title</th>
                    <th>Type</th>
                    <th>Department</th>
                    <th>Location</th>
                    <th>Amount</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for o in offers %}
                <tr>
                    <td class="text-muted">{{ o.id }}</td>
                    <td><a href="{{ path('app_offer_show', {id: o.id}) }}" style="color:var(--accent-blue);font-weight:600">{{ o.title }}</a></td>
                    <td>
                        {% set tc = {'FULL_TIME': 'green', 'PART_TIME': 'blue', 'FREELANCE': 'purple', 'INTERNSHIP': 'orange', 'CONTRACT': 'blue'} %}
                        <span class="badge badge--{{ tc[o.offerType] ?? 'blue' }}">{{ o.offerType ?? '—' }}</span>
                    </td>
                    <td>{% if o.department %}{{ o.department.name }}{% else %}—{% endif %}</td>
                    <td>{{ o.location ?? '—' }}</td>
                    <td>{% if o.amount %}{{ o.amount|number_format(2) }} {{ o.currency }}{% else %}—{% endif %}</td>
                    <td>
                        {% set sc = {'DRAFT': 'blue', 'OPEN': 'green', 'CLOSED': 'red', 'CANCELLED': 'orange'} %}
                        <span class="badge badge--{{ sc[o.status] ?? 'blue' }}">{{ o.status ?? 'N/A' }}</span>
                        {% if appliedOfferIds is defined and o.id in appliedOfferIds %}
                            <span class="badge badge--purple" style="margin-left:.25rem">Applied</span>
                        {% endif %}
                    </td>
                    <td>
                        <details class="crud-actions-menu">
                            <summary class="btn btn-ghost btn-sm" title="Actions"><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="5" r="2"/><circle cx="12" cy="12" r="2"/><circle cx="12" cy="19" r="2"/></svg></summary>
                            <div class="crud-actions-dropdown">
                                <a href="{{ path('app_offer_show', {id: o.id}) }}" class="crud-action-item"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg> View</a>
                                {% if o.status == 'OPEN' and (appliedOfferIds is not defined or o.id not in appliedOfferIds) %}
                                <a href="{{ path('app_offer_apply', {id: o.id}) }}" class="crud-action-item" style="color:var(--color-success)"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 2L11 13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg> Apply</a>
                                {% endif %}
                                {% if is_granted('ROLE_HR') %}
                                {% if o.status == 'DRAFT' %}
                                <a href="{{ path('app_offer_publish', {id: o.id}) }}" class="crud-action-item" style="color:var(--color-success)"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg> Publish</a>
                                {% elseif o.status == 'OPEN' %}
                                <a href="{{ path('app_offer_close', {id: o.id}) }}" class="crud-action-item" style="color:var(--color-warning)"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="9" y1="9" x2="15" y2="15"/><line x1="15" y1="9" x2="9" y2="15"/></svg> Close</a>
                                {% endif %}
                                <a href="{{ path('app_offer_edit', {id: o.id}) }}" class="crud-action-item"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg> Edit</a>
                                <form method="post" action="{{ path('app_offer_delete', {id: o.id}) }}" onsubmit="return confirm('Delete this offer?')">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ o.id) }}">
                                    <button type="submit" class="crud-action-item crud-action-danger"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg> Delete</button>
                                </form>
                                {% endif %}
                            </div>
                        </details>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    {% else %}
    <div style="text-align:center;padding:3rem">
        <p class="text-muted">No job offers yet.</p>
        <a href="{{ path('app_offer_new') }}" class="btn btn-primary" style="margin-top:1rem">+ Create Offer</a>
    </div>
    {% endif %}
</div>

{% if pagination is defined %}{% include 'components/_pagination.html.twig' %}{% endif %}
{% endblock %}
