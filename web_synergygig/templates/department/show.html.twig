{% extends 'layouts/admin.html.twig' %}

{% block title %}{{ department.name }} | SynergyGig{% endblock %}

{% block page_title %}{{ department.name }}{% endblock %}

{% block breadcrumb %}
    <nav class="breadcrumb">
        <a href="{{ path('app_dashboard') }}">Home</a>
        <span class="sep">/</span>
        <a href="{{ path('app_department_index') }}">Departments</a>
        <span class="sep">/</span>
        <span>{{ department.name }}</span>
    </nav>
{% endblock %}

{% block header_actions %}
    <a href="{{ path('app_department_edit', {id: department.id}) }}" class="btn btn-secondary">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
        Edit
    </a>
{% endblock %}

{% block content %}
    <div class="bento-grid bento-grid--stats" style="margin-bottom: var(--space-2xl);">
        <div class="card card--glow-purple">
            <div class="card-title" style="margin-bottom: var(--space-sm);">Department Name</div>
            <div class="card-value" style="font-size: 1.5rem;">{{ department.name }}</div>
        </div>
        <div class="card card--glow-blue">
            <div class="card-title" style="margin-bottom: var(--space-sm);">Manager</div>
            <div style="display: flex; align-items: center; gap: var(--space-sm); margin-top: var(--space-sm);">
                {% if department.manager %}
                    <div class="avatar">{{ department.manager.first_name|first|upper }}{{ department.manager.last_name|first|upper }}</div>
                    <div>
                        <div style="font-weight: 500;">{{ department.manager.first_name }} {{ department.manager.last_name }}</div>
                        <div class="text-muted" style="font-size: 0.8125rem;">{{ department.manager.email }}</div>
                    </div>
                {% else %}
                    <span class="text-muted">No manager assigned</span>
                {% endif %}
            </div>
        </div>
        <div class="card card--glow-green">
            <div class="card-title" style="margin-bottom: var(--space-sm);">Budget</div>
            <div class="card-value" style="font-size: 1.5rem;">
                {% if department.allocated_budget %}
                    ${{ department.allocated_budget|number_format(2, '.', ',') }}
                {% else %}
                    <span class="text-muted">—</span>
                {% endif %}
            </div>
        </div>
    </div>

    {% if department.description %}
    <div class="card" style="margin-bottom: var(--space-2xl);">
        <h3 style="margin-bottom: var(--space-md); font-size: 1rem;">Description</h3>
        <p>{{ department.description }}</p>
    </div>
    {% endif %}

    <div class="card">
        <div class="card-header">
            <h3 style="margin: 0; font-size: 1rem;">Details</h3>
        </div>
        <div class="table-wrapper">
            <table class="table">
                <tbody>
                    <tr>
                        <td class="text-muted" style="width: 200px;">ID</td>
                        <td>{{ department.id }}</td>
                    </tr>
                    <tr>
                        <td class="text-muted">Created</td>
                        <td>{{ department.created_at|date('F d, Y \\a\\t H:i') }}</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    {# ── Members List ── #}
    <div class="card" style="margin-top:1.5rem">
        <div class="card-header" style="display:flex;align-items:center;justify-content:space-between">
            <h3 style="margin:0;font-size:1rem">
                Members
                <span class="badge badge--blue" style="margin-left:.5rem">{{ members|length }}</span>
            </h3>
            {% if is_granted('ROLE_HR') and available_employees|length > 0 %}
            <button type="button" class="btn btn-primary btn-sm" onclick="document.getElementById('addMemberModal').style.display='flex'">+ Add Employee</button>
            {% endif %}
        </div>
        {% if members|length > 0 %}
        <div class="table-wrapper">
            <table class="table">
                <thead><tr><th>Employee</th><th>Email</th><th>Role</th>{% if is_granted('ROLE_HR') %}<th style="width:180px">Actions</th>{% endif %}</tr></thead>
                <tbody>
                {% for member in members %}
                <tr>
                    <td>
                        <div style="display:flex;align-items:center;gap:.5rem">
                            <div class="avatar avatar--sm">{{ member.first_name|first|upper }}{{ member.last_name|first|upper }}</div>
                            {{ member.first_name }} {{ member.last_name }}
                        </div>
                    </td>
                    <td class="text-muted">{{ member.email }}</td>
                    <td><span class="badge badge--blue">{{ member.role ?? 'EMPLOYEE' }}</span></td>
                    {% if is_granted('ROLE_HR') %}
                    <td>
                        <div style="display:flex;gap:.4rem;flex-wrap:wrap">
                            {# Move to another dept #}
                            <button type="button" class="btn btn-ghost btn-sm"
                                onclick="openMoveModal({{ member.id }}, '{{ (member.first_name ~ ' ' ~ member.last_name)|e('html_attr') }}')"
                                title="Move to another department">⇄ Move</button>
                            {# Remove from dept #}
                            <form method="post" action="{{ path('app_department_remove_employee', {id: department.id, userId: member.id}) }}" onsubmit="return confirm('Remove {{ (member.first_name ~ ' ' ~ member.last_name)|e('html_attr') }} from this department?')">
                                <input type="hidden" name="_token" value="{{ csrf_token('remove-' ~ department.id ~ '-' ~ member.id) }}">
                                <button type="submit" class="btn btn-sm" style="background:var(--danger);color:#fff">✕ Remove</button>
                            </form>
                        </div>
                    </td>
                    {% endif %}
                </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
        {% else %}
        <div class="empty-state" style="padding:2rem;text-align:center">
            <p class="text-muted">No employees assigned to this department yet.</p>
        </div>
        {% endif %}
    </div>

    {# ── Add Employee Modal ── #}
    {% if is_granted('ROLE_HR') %}
    <div id="addMemberModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:9000;align-items:center;justify-content:center">
        <div style="background:var(--bg-card,#1a1a1d);border-radius:1rem;padding:2rem;max-width:440px;width:90%;box-shadow:0 20px 60px rgba(0,0,0,.4)">
            <h3 style="margin:0 0 1.25rem;color:var(--text-primary)">Add Employee to {{ department.name }}</h3>
            <form method="post" action="{{ path('app_department_assign_employee', {id: department.id, userId: 0})|replace({'/0': ''}) }}" id="addMemberForm">
                <input type="hidden" name="_token" value="{{ csrf_token('assign-' ~ department.id) }}">
                <div class="form-group" style="margin-bottom:1.25rem">
                    <label class="form-label">Select Employee</label>
                    <select name="user_id" id="addMemberSelect" class="form-control form-select" required>
                        <option value="">-- Choose employee --</option>
                        {% for emp in available_employees %}
                        <option value="{{ emp.id }}">{{ emp.first_name }} {{ emp.last_name }} ({{ emp.email }})</option>
                        {% endfor %}
                    </select>
                </div>
                <div style="display:flex;gap:.75rem;justify-content:flex-end">
                    <button type="button" class="btn btn-ghost" onclick="document.getElementById('addMemberModal').style.display='none'">Cancel</button>
                    <button type="submit" class="btn btn-primary" id="addMemberSubmitBtn" disabled>Add to Department</button>
                </div>
            </form>
        </div>
    </div>

    {# ── Move Employee Modal ── #}
    <div id="moveMemberModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:9000;align-items:center;justify-content:center">
        <div style="background:var(--bg-card,#1a1a1d);border-radius:1rem;padding:2rem;max-width:440px;width:90%;box-shadow:0 20px 60px rgba(0,0,0,.4)">
            <h3 style="margin:0 0 .5rem;color:var(--text-primary)">Move Employee</h3>
            <p id="moveMemberName" class="text-muted" style="margin:0 0 1.25rem;font-size:.875rem"></p>
            <form id="moveMemberForm" method="post" action="">
                <input type="hidden" name="_token" id="moveMemberToken" value="">
                <div class="form-group" style="margin-bottom:1.25rem">
                    <label class="form-label">Destination Department</label>
                    <select name="target_department_id" class="form-control form-select" required>
                        <option value="">-- Select department --</option>
                        {% for dept in all_departments %}
                        {% if dept.id != department.id %}
                        <option value="{{ dept.id }}">{{ dept.name }}</option>
                        {% endif %}
                        {% endfor %}
                    </select>
                </div>
                <div style="display:flex;gap:.75rem;justify-content:flex-end">
                    <button type="button" class="btn btn-ghost" onclick="document.getElementById('moveMemberModal').style.display='none'">Cancel</button>
                    <button type="submit" class="btn btn-primary">Move</button>
                </div>
            </form>
        </div>
    </div>

    <script>
    document.getElementById('addMemberSelect').addEventListener('change', function() {
        document.getElementById('addMemberSubmitBtn').disabled = !this.value;
        if (this.value) {
            document.getElementById('addMemberForm').action = '/departments/{{ department.id }}/assign/' + this.value;
        }
    });

    function openMoveModal(userId, userName) {
        document.getElementById('moveMemberName').textContent = 'Moving: ' + userName;
        document.getElementById('moveMemberForm').action = '/departments/{{ department.id }}/move/' + userId;
        document.getElementById('moveMemberToken').value = ''; {# CSRF injected per user below #}
        document.getElementById('moveMemberModal').style.display = 'flex';
    }
    // CSRF tokens for move
    const moveTokens = {
        {% for member in members %}
        {{ member.id }}: '{{ csrf_token('move-' ~ member.id) }}'{% if not loop.last %},{% endif %}
        {% endfor %}
    };
    function openMoveModal(userId, userName) {
        document.getElementById('moveMemberName').textContent = 'Moving: ' + userName;
        document.getElementById('moveMemberForm').action = '/departments/{{ department.id }}/move/' + userId;
        document.getElementById('moveMemberToken').value = moveTokens[userId] || '';
        document.getElementById('moveMemberModal').style.display = 'flex';
    }
    // Close modals on overlay click
    document.querySelectorAll('#addMemberModal,#moveMemberModal').forEach(function(el) {
        el.addEventListener('click', function(e) { if (e.target === el) el.style.display = 'none'; });
    });
    </script>
    {% endif %}
{% endblock %}
