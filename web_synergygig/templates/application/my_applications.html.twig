{% extends 'layouts/admin.html.twig' %}

{% block page_title %}My Applications{% endblock %}

{% block header_actions %}
    <a href="{{ path('app_offer_index') }}" class="btn btn-primary btn-sm">Browse Offers</a>
{% endblock %}

{% block content %}
{# Status stats #}
<div class="bento-grid" style="grid-template-columns:repeat(4,1fr);gap:1rem;margin-bottom:1.5rem">
    <a href="{{ path('app_my_applications') }}" class="card" style="padding:1.25rem;text-align:center;text-decoration:none;{{ currentStatus is null ? 'outline:2px solid var(--accent-blue);outline-offset:-2px' : '' }}">
        <div class="text-muted" style="font-size:.75rem;margin-bottom:.25rem">Total</div>
        <div style="font-size:1.75rem;font-weight:700;color:var(--text-primary)">{{ totalCount }}</div>
    </a>
    <a href="{{ path('app_my_applications', {status: 'PENDING'}) }}" class="card" style="padding:1.25rem;text-align:center;text-decoration:none;{{ currentStatus == 'PENDING' ? 'outline:2px solid var(--color-warning);outline-offset:-2px' : '' }}">
        <div class="text-muted" style="font-size:.75rem;margin-bottom:.25rem">Pending</div>
        <div style="font-size:1.75rem;font-weight:700;color:var(--color-warning)">{{ pendingCount }}</div>
    </a>
    <a href="{{ path('app_my_applications', {status: 'ACCEPTED'}) }}" class="card" style="padding:1.25rem;text-align:center;text-decoration:none;{{ currentStatus == 'ACCEPTED' ? 'outline:2px solid var(--color-success);outline-offset:-2px' : '' }}">
        <div class="text-muted" style="font-size:.75rem;margin-bottom:.25rem">Accepted</div>
        <div style="font-size:1.75rem;font-weight:700;color:var(--color-success)">{{ acceptedCount }}</div>
    </a>
    <a href="{{ path('app_my_applications', {status: 'REJECTED'}) }}" class="card" style="padding:1.25rem;text-align:center;text-decoration:none;{{ currentStatus == 'REJECTED' ? 'outline:2px solid var(--color-danger);outline-offset:-2px' : '' }}">
        <div class="text-muted" style="font-size:.75rem;margin-bottom:.25rem">Rejected</div>
        <div style="font-size:1.75rem;font-weight:700;color:var(--color-danger)">{{ rejectedCount }}</div>
    </a>
</div>

{# Filter bar #}
<div class="card" style="padding:var(--space-md) var(--space-lg);margin-bottom:var(--space-lg);display:flex;align-items:center;gap:var(--space-md)">
    {% if currentStatus %}
        <a href="{{ path('app_my_applications') }}" class="btn btn-ghost btn-sm">Clear Filter</a>
    {% endif %}
</div>

{# Applications list #}
<div class="card">
    {% if applications|length > 0 %}
    <div class="table-wrap">
        <table class="table">
            <thead>
                <tr>
                    <th>Offer</th>
                    <th>Status</th>
                    <th>AI Score</th>
                    <th>Applied</th>
                    <th>Reviewed</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for a in applications %}
                <tr>
                    <td>
                        {% if a.offer %}
                            <a href="{{ path('app_offer_show', {id: a.offer.id}) }}" style="color:var(--accent-blue);font-weight:500">{{ a.offer.title }}</a>
                            {% if a.offer.offerType %}<div class="text-muted" style="font-size:.75rem">{{ a.offer.offerType|replace({'_': ' '}) }}</div>{% endif %}
                        {% else %}
                            <span class="text-muted">Deleted Offer</span>
                        {% endif %}
                    </td>
                    <td>
                        {% set sc = {'PENDING': 'orange', 'REVIEWED': 'blue', 'SHORTLISTED': 'purple', 'ACCEPTED': 'green', 'REJECTED': 'red', 'WITHDRAWN': 'red'} %}
                        <span class="badge badge--{{ sc[a.status] ?? 'blue' }}">{{ a.status ?? 'N/A' }}</span>
                    </td>
                    <td>
                        {% if a.aiScore is not null %}
                            <span style="font-weight:600;{% if a.aiScore >= 70 %}color:var(--color-success){% elseif a.aiScore >= 40 %}color:var(--color-warning){% else %}color:var(--color-danger){% endif %}">{{ a.aiScore }}%</span>
                        {% else %}—{% endif %}
                    </td>
                    <td>{{ a.appliedAt ? a.appliedAt|date('M d, Y') : '—' }}</td>
                    <td>{{ a.reviewedAt ? a.reviewedAt|date('M d, Y') : '—' }}</td>
                    <td>
                        <a href="{{ path('app_application_show', {id: a.id}) }}" class="btn btn-ghost btn-sm" title="View">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                        </a>
                        {% if a.status == 'ACCEPTED' and interviews[a.id] is defined %}
                            <a href="{{ path('app_interview_show', {id: interviews[a.id].id}) }}" class="btn btn-sm" style="background:var(--color-success);color:#fff;padding:.25rem .5rem" title="View Interview">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                            </a>
                        {% endif %}
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    {% else %}
    <div style="text-align:center;padding:3rem">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--text-tertiary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/></svg>
        <p class="text-muted" style="margin-top:1rem">{{ currentStatus ? 'No ' ~ currentStatus|lower ~ ' applications.' : 'You haven\'t applied to any offers yet.' }}</p>
        <a href="{{ path('app_offer_index') }}" class="btn btn-primary" style="margin-top:1rem">Browse Offers</a>
    </div>
    {% endif %}
</div>
{% endblock %}
