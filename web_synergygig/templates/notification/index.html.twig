{% extends 'layouts/admin.html.twig' %}

{% block page_title %}Notifications{% endblock %}

{% block header_actions %}
    {% if unreadCount > 0 %}
    <form method="post" action="{{ path('app_notification_read_all') }}" style="display:inline">
        <button type="submit" class="btn btn-secondary btn-sm">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
            Mark all as read ({{ unreadCount }})
        </button>
    </form>
    {% endif %}
{% endblock %}

{% block content %}
<div class="card">
    {% if notifications|length > 0 %}
    <div style="padding:0">
        {% for n in notifications %}
        <div style="display:flex;align-items:flex-start;gap:1rem;padding:1rem 1.25rem;border-bottom:1px solid var(--border-primary);{% if not n.isRead %}background:rgba(144,221,240,0.04){% endif %}">
            {# Icon by type #}
            {% set type_map = {
                'MESSAGE': 'var(--accent-blue)',
                'VOICE_CALL': 'var(--color-success)',
                'VIDEO_CALL': 'var(--color-success)',
                'MISSED_CALL': 'var(--color-danger)',
                'TASK': 'var(--color-warning)',
                'INTERVIEW': '#a78bfa',
                'CONTRACT': '#f59e0b',
                'SUCCESS': 'var(--color-success)',
                'WARNING': 'var(--color-warning)',
                'ERROR': 'var(--color-danger)',
                'INFO': 'var(--accent-blue)'
            } %}
            {% set iconColor = type_map[n.type] ?? 'var(--accent-blue)' %}
            <div style="flex-shrink:0;width:36px;height:36px;border-radius:8px;display:flex;align-items:center;justify-content:center;background:{{ iconColor }}22;color:{{ iconColor }}">
                {% if n.type == 'MESSAGE' %}
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                {% elseif n.type in ['VOICE_CALL', 'VIDEO_CALL'] %}
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.79 19.79 0 0 1 2.12 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                {% elseif n.type == 'MISSED_CALL' %}
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="1" y1="1" x2="23" y2="23"/><path d="M16.72 11.06A10.94 10.94 0 0 1 19 12.55"/><path d="M5 12.55a10.94 10.94 0 0 1 5.17-2.39"/></svg>
                {% elseif n.type == 'TASK' %}
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
                {% elseif n.type == 'INTERVIEW' %}
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                {% elseif n.type == 'CONTRACT' %}
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                {% elseif n.type == 'SUCCESS' %}
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                {% elseif n.type == 'WARNING' %}
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                {% elseif n.type == 'ERROR' %}
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
                {% else %}
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
                {% endif %}
            </div>
            <div style="flex:1;min-width:0">
                <div style="display:flex;align-items:center;justify-content:space-between;gap:0.5rem;margin-bottom:0.25rem">
                    <strong style="color:var(--text-primary);font-size:0.9rem">{{ n.title ?? 'Notification' }}</strong>
                    <span class="text-muted" style="font-size:0.75rem;white-space:nowrap">{{ n.createdAt ? n.createdAt|date('M d, H:i') : '' }}</span>
                </div>
                <p style="color:var(--text-secondary);font-size:0.85rem;margin:0;line-height:1.4">{{ n.body ?? '' }}</p>
                {% if n.referenceType %}
                    <span class="text-muted" style="font-size:0.75rem">{{ n.referenceType }}{% if n.referenceId %} #{{ n.referenceId }}{% endif %}</span>
                {% endif %}
            </div>
            {# Actions #}
            <div style="flex-shrink:0;display:flex;align-items:center;gap:0.5rem">
                {% if not n.isRead %}
                    <form method="post" action="{{ path('app_notification_read', {id: n.id}) }}">
                        <button type="submit" class="btn btn-ghost btn-sm" title="Mark as read" style="padding:0.3rem">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                        </button>
                    </form>
                {% endif %}
                <form method="post" action="{{ path('app_notification_delete', {id: n.id}) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ n.id) }}">
                    <button type="submit" class="btn btn-ghost btn-sm" title="Delete" style="padding:0.3rem;color:var(--color-danger)">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                    </button>
                </form>
            </div>
        </div>
        {% endfor %}
    </div>
    {% else %}
    <div style="text-align:center;padding:3rem">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--text-muted)" stroke-width="1.5" style="margin-bottom:1rem"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
        <p class="text-muted">No notifications.</p>
    </div>
    {% endif %}
</div>
{% endblock %}
