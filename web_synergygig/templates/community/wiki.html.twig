{% extends 'layouts/admin.html.twig' %}

{% block page_title %}Wikipedia{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/community.css') }}">
{% endblock %}

{% block content %}
<div class="community-layout">
    {% include 'community/_sidebar.html.twig' %}

    <main class="community-main">
        <h2 style="color:var(--text-primary);font-size:1.125rem;margin:0 0 1.25rem">Wikipedia Search</h2>

        {# Search Form #}
        <form action="{{ path('app_community_wiki') }}" method="get" class="wiki-search-form" style="margin-bottom:1.5rem">
            <div class="people-search-wrap">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#8E8E99" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                <input type="text" name="q" class="people-search" placeholder="Search Wikipedia..." value="{{ query|default('') }}" autocomplete="off">
            </div>
        </form>

        {% if article %}
        <article class="wiki-article post-card">
            {% if article.thumbnail %}
            <div class="wiki-thumbnail" style="margin-bottom:1rem">
                <img src="{{ article.thumbnail }}" alt="{{ article.title }}" style="width:100%;max-height:300px;object-fit:cover;border-radius:10px">
            </div>
            {% endif %}

            <h2 class="wiki-title" style="color:var(--text-primary);font-size:1.25rem;margin:0 0 .25rem">{{ article.title }}</h2>

            {% if article.description %}
            <p style="color:var(--accent-primary);font-size:.85rem;margin:0 0 1rem;font-style:italic">{{ article.description }}</p>
            {% endif %}

            <div class="wiki-extract" style="color:var(--text-secondary);font-size:.9rem;line-height:1.7;white-space:pre-wrap">{{ article.extract }}</div>

            <div style="margin-top:1.25rem;padding-top:1rem;border-top:1px solid #2A2A3C">
                <a href="{{ article.url }}" target="_blank" rel="noopener" class="btn-publish" style="display:inline-flex;align-items:center;gap:.4rem;text-decoration:none">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                    Read on Wikipedia
                </a>
            </div>
        </article>
        {% elseif query %}
        <div class="empty-state">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--accent-primary)" stroke-width="1.5"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <h3>No results found</h3>
            <p style="color:var(--text-muted)">Try a different search term.</p>
        </div>
        {% else %}
        <div class="empty-state">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--accent-primary)" stroke-width="1.5"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
            <h3>Explore Wikipedia</h3>
            <p style="color:var(--text-muted)">Search for any topic to learn more.</p>
        </div>
        {% endif %}
    </main>
</div>

{% endblock %}
