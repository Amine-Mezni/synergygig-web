{% extends 'layouts/admin.html.twig' %}

{% block page_title %}Attendance{% endblock %}

{% block header_actions %}
    {% if is_granted('ROLE_HR') %}
    <a href="{{ path('app_export_attendance_csv') }}" class="btn btn-ghost btn-sm" title="Export CSV">📥 CSV</a>
    <a href="{{ path('app_attendance_new') }}" class="btn btn-primary btn-sm">+ New Record</a>
    {% endif %}
{% endblock %}

{% block content %}
{# Search & Filter bar #}
<div class="card" style="padding:var(--space-md) var(--space-lg);margin-bottom:var(--space-lg);display:flex;align-items:center;gap:var(--space-md)">
    <form method="get" action="{{ path('app_attendance_index') }}" style="flex:1;display:flex;align-items:center;gap:var(--space-md);flex-wrap:wrap">
        <select name="status" class="form-control form-select" style="width:auto;min-width:120px">
            <option value="">All Status</option>
            <option value="PRESENT" {{ app.request.query.get('status') == 'PRESENT' ? 'selected' }}>Present</option>
            <option value="LATE" {{ app.request.query.get('status') == 'LATE' ? 'selected' }}>Late</option>
            <option value="ABSENT" {{ app.request.query.get('status') == 'ABSENT' ? 'selected' }}>Absent</option>
        </select>
        <input type="date" name="date_from" value="{{ app.request.query.get('date_from') }}" class="form-control" style="width:auto" placeholder="From">
        <input type="date" name="date_to" value="{{ app.request.query.get('date_to') }}" class="form-control" style="width:auto" placeholder="To">
        <button type="submit" class="btn btn-secondary btn-sm">Filter</button>
        {% if app.request.query.get('status') or app.request.query.get('date_from') or app.request.query.get('date_to') %}
        <a href="{{ path('app_attendance_index') }}" class="btn btn-ghost btn-sm" style="color:var(--color-danger)">✕ Clear</a>
        {% endif %}
    </form>
</div>

<div class="card">
    {% if records|length > 0 %}
    <div class="table-wrap">
        <table class="table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Employee</th>
                    <th>Date</th>
                    <th>Check In</th>
                    <th>Check Out</th>
                    <th>Status</th>
                    <th>Approval</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for r in records %}
                <tr>
                    <td class="text-muted">{{ r.id }}</td>
                    <td>
                        {% if r.user %}
                            <div style="display:flex;align-items:center;gap:0.5rem">
                                <div class="avatar avatar--sm">{{ r.user.firstName|first }}{{ r.user.lastName|first }}</div>
                                {{ r.user.firstName }} {{ r.user.lastName }}
                            </div>
                        {% else %}
                            <span class="text-muted">—</span>
                        {% endif %}
                    </td>
                    <td>{{ r.date ? r.date|date('M d, Y') : '—' }}</td>
                    <td>{{ r.checkIn ? r.checkIn|date('H:i') : '—' }}</td>
                    <td>{{ r.checkOut ? r.checkOut|date('H:i') : '—' }}</td>
                    <td>
                        {% set status_colors = {'PRESENT': 'green', 'ABSENT': 'red', 'LATE': 'orange', 'HALF_DAY': 'blue'} %}
                        <span class="badge badge--{{ status_colors[r.status] ?? 'blue' }}">{{ r.status ?? 'N/A' }}</span>
                    </td>
                    <td>
                        {% set approvalStatus = r.approvalStatus ?? 'PENDING' %}
                        {% if approvalStatus == 'APPROVED' %}
                            <span class="badge badge--green">✓ Approved</span>
                        {% elseif approvalStatus == 'REJECTED' %}
                            <span class="badge badge--red" title="{{ r.rejectionReason }}">✕ Rejected</span>
                        {% else %}
                            {% if is_granted('ROLE_HR') %}
                                <button type="button"
                                    class="badge badge--orange" style="cursor:pointer;border:none;background:none;padding:0.2rem 0.5rem"
                                    ondblclick="openReviewModal({{ r.id }}, '{{ (r.user ? r.user.firstName~' '~r.user.lastName : 'Unknown')|e('js') }}', '{{ r.checkIn ? r.checkIn|date('H:i') : '--:--' }}', '{{ r.status ?? '' }}')"
                                    title="Double-click to review">⏳ Pending</button>
                            {% else %}
                                <span class="badge badge--orange">⏳ Pending</span>
                            {% endif %}
                        {% endif %}
                    </td>
                    <td>
                        <details class="crud-actions-menu">
                            <summary class="btn btn-ghost btn-sm" title="Actions"><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="5" r="2"/><circle cx="12" cy="12" r="2"/><circle cx="12" cy="19" r="2"/></svg></summary>
                            <div class="crud-actions-dropdown">
                                <a href="{{ path('app_attendance_show', {id: r.id}) }}" class="crud-action-item"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg> View</a>
                                {% if is_granted('ROLE_HR') %}
                                <a href="{{ path('app_attendance_edit', {id: r.id}) }}" class="crud-action-item"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg> Edit</a>
                                {% if (r.approvalStatus ?? 'PENDING') == 'PENDING' %}
                                <button type="button" class="crud-action-item" style="border:none;background:none;width:100%;text-align:left;cursor:pointer"
                                    onclick="openReviewModal({{ r.id }}, '{{ (r.user ? r.user.firstName~' '~r.user.lastName : 'Unknown')|e('js') }}', '{{ r.checkIn ? r.checkIn|date('H:i') : '--:--' }}', '{{ r.status ?? '' }}')">✅ Review Check-in</button>
                                {% endif %}
                                <form method="post" action="{{ path('app_attendance_delete', {id: r.id}) }}" onsubmit="return confirm('Delete this record?')">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ r.id) }}">
                                    <button type="submit" class="crud-action-item crud-action-danger"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg> Delete</button>
                                </form>
                                {% endif %}
                            </div>
                        </details>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    {% else %}
    <div style="text-align:center;padding:3rem">
        <p class="text-muted">No attendance records yet.</p>
        <a href="{{ path('app_attendance_new') }}" class="btn btn-primary" style="margin-top:1rem">+ Add First Record</a>
    </div>
    {% endif %}
</div>

{% if pagination is defined %}{% include 'components/_pagination.html.twig' %}{% endif %}

{# ── HR Approval Modal ── #}
{% if is_granted('ROLE_HR') %}
{# Hidden CSRF tokens per pending row #}
{% for r in records %}
{% if (r.approvalStatus ?? 'PENDING') == 'PENDING' %}
<span id="approve-token-{{ r.id }}" style="display:none">{{ csrf_token('approve' ~ r.id) }}</span>
<span id="reject-token-{{ r.id }}"  style="display:none">{{ csrf_token('reject'  ~ r.id) }}</span>
{% endif %}
{% endfor %}

<div id="reviewModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:9000;align-items:center;justify-content:center">
    <div style="background:var(--color-surface,#fff);border-radius:1rem;padding:2rem;max-width:480px;width:90%;box-shadow:0 20px 60px rgba(0,0,0,.2)">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.5rem">
            <h3 style="margin:0;font-size:1.125rem;font-weight:700">Review Check-in</h3>
            <button type="button" onclick="closeReviewModal()" style="background:none;border:none;font-size:1.5rem;cursor:pointer;color:var(--color-text-muted,#888)">&times;</button>
        </div>
        <div id="reviewInfo" style="background:var(--color-bg,#f5f5f5);border-radius:.75rem;padding:1rem;margin-bottom:1.5rem;display:grid;grid-template-columns:1fr 1fr;gap:.5rem 1rem;font-size:.875rem"></div>
        <form id="approveForm" method="post" style="display:inline">
            <input type="hidden" name="_token" id="approveToken">
            <button type="submit" class="btn btn-primary" style="width:48%">✅ Approve</button>
        </form>
        <button type="button" class="btn btn-ghost" style="width:48%;margin-left:4%;color:var(--color-danger,#ef4444);border-color:var(--color-danger,#ef4444)" onclick="showRejectPanel()">✕ Reject</button>
        <div id="rejectPanel" style="display:none;margin-top:1rem">
            <form id="rejectForm" method="post">
                <input type="hidden" name="_token" id="rejectToken">
                <label style="font-size:.875rem;font-weight:600;display:block;margin-bottom:.35rem">Reason (optional)</label>
                <textarea name="rejection_reason" id="rejectReasonInput" rows="2" class="form-control" style="width:100%;margin-bottom:.75rem" placeholder="e.g. System error, incorrect location…"></textarea>
                <button type="submit" class="btn btn-danger" style="width:100%">Confirm Rejection</button>
            </form>
        </div>
    </div>
</div>
{% endif %}
{% endblock %}

{% block javascripts %}
{{ parent() }}
{% if is_granted('ROLE_HR') %}
<script>
var _reviewId = null;
function openReviewModal(id, name, checkIn, status) {
    _reviewId = id;
    var sc = {PRESENT:'#10b981', LATE:'#f59e0b', ABSENT:'#ef4444'};
    document.getElementById('reviewInfo').innerHTML =
        '<div><span style="color:#888;font-size:.75rem;text-transform:uppercase">Employee</span><br><strong>' + name + '</strong></div>' +
        '<div><span style="color:#888;font-size:.75rem;text-transform:uppercase">Check-in</span><br><strong>' + checkIn + '</strong></div>' +
        '<div><span style="color:#888;font-size:.75rem;text-transform:uppercase">Work Status</span><br><strong style="color:' + (sc[status]||'#888') + '">' + (status||'N/A') + '</strong></div>' +
        '<div><span style="color:#888;font-size:.75rem;text-transform:uppercase">Approval</span><br><span style="color:#f59e0b;font-weight:600">Pending</span></div>';
    document.getElementById('approveForm').action = '/attendance/' + id + '/approve';
    document.getElementById('approveToken').value = (document.getElementById('approve-token-' + id)||{}).textContent || '';
    document.getElementById('rejectForm').action  = '/attendance/' + id + '/reject';
    document.getElementById('rejectToken').value  = (document.getElementById('reject-token-'  + id)||{}).textContent || '';
    document.getElementById('rejectPanel').style.display = 'none';
    document.getElementById('rejectReasonInput').value = '';
    document.getElementById('reviewModal').style.display = 'flex';
}
function closeReviewModal() {
    document.getElementById('reviewModal').style.display = 'none';
    _reviewId = null;
}
function showRejectPanel() {
    document.getElementById('rejectPanel').style.display = 'block';
}
document.getElementById('reviewModal').addEventListener('click', function(e) {
    if (e.target === this) closeReviewModal();
});
</script>
{% endif %}
{% endblock %}
