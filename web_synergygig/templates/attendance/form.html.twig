{% extends 'layouts/admin.html.twig' %}

{% block page_title %}{{ is_edit ? 'Edit Attendance' : 'New Attendance Record' }}{% endblock %}

{% block content %}
<div class="card" style="max-width:640px">
    <div class="card-header">
        <h3>{{ is_edit ? 'Edit Record' : 'Record Attendance' }}</h3>
    </div>
    <div class="card-body">
        {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
            <div class="form-group">
                {{ form_label(form.user) }}
                {{ form_widget(form.user) }}
                {{ form_errors(form.user) }}
            </div>
            <div class="form-group">
                {{ form_label(form.date) }}
                {{ form_widget(form.date) }}
                {{ form_errors(form.date) }}
            </div>
            <div class="form-row" style="display:grid;grid-template-columns:1fr 1fr;gap:1rem">
                <div class="form-group">
                    {{ form_label(form.check_in) }}
                    {{ form_widget(form.check_in) }}
                    {{ form_errors(form.check_in) }}
                </div>
                <div class="form-group">
                    {{ form_label(form.check_out) }}
                    {{ form_widget(form.check_out) }}
                    {{ form_errors(form.check_out) }}
                </div>
            </div>
            <div class="form-group">
                {{ form_label(form.status) }}
                {{ form_widget(form.status) }}
                {{ form_errors(form.status) }}
            </div>
            <div class="form-actions" style="display:flex;gap:0.75rem;margin-top:1.5rem">
                <a href="{{ path('app_attendance_index') }}" class="btn btn-ghost">Cancel</a>
                <button type="submit" class="btn btn-primary">{{ is_edit ? 'Update' : 'Save' }}</button>
            </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
