{% extends 'layouts/admin.html.twig' %}

{% block title %}{{ user.first_name }} {{ user.last_name }} | SynergyGig{% endblock %}

{% block page_title %}{{ user.first_name }} {{ user.last_name }}{% endblock %}

{% block breadcrumb %}
    <nav class="breadcrumb">
        <a href="{{ path('app_dashboard') }}">Home</a>
        <span class="sep">/</span>
        <a href="{{ path('app_user_index') }}">Users</a>
        <span class="sep">/</span>
        <span>{{ user.first_name }} {{ user.last_name }}</span>
    </nav>
{% endblock %}

{% block header_actions %}
    <a href="{{ path('app_user_edit', {id: user.id}) }}" class="btn btn-secondary">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
        Edit
    </a>
{% endblock %}

{% block content %}
    {# Profile Header #}
    <div class="card" style="margin-bottom: var(--space-2xl);">
        <div style="display: flex; align-items: center; gap: var(--space-xl);">
            <div class="avatar avatar--lg">{{ user.first_name|first|upper }}{{ user.last_name|first|upper }}</div>
            <div>
                <h2 style="margin: 0 0 var(--space-xs);">{{ user.first_name }} {{ user.last_name }}</h2>
                <p style="margin: 0; color: var(--text-secondary);">{{ user.email }}</p>
                <div style="display: flex; gap: var(--space-sm); margin-top: var(--space-sm);">
                    {% set role_color = {
                        'ADMIN': 'red',
                        'HR': 'purple',
                        'MANAGER': 'blue',
                        'EMPLOYEE': 'green'
                    } %}
                    <span class="badge badge--{{ role_color[user.role] ?? 'blue' }}">{{ user.role ?? 'Employee' }}</span>
                    {% if user.is_active %}
                        <span class="badge badge--green">Active</span>
                    {% else %}
                        <span class="badge badge--red">Inactive</span>
                    {% endif %}
                    {% if user.is_verified %}
                        <span class="badge badge--blue">Verified</span>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>

    {# Stats Cards #}
    <div class="bento-grid bento-grid--stats" style="margin-bottom: var(--space-2xl);">
        <div class="card card--glow-blue">
            <div class="card-title" style="margin-bottom: var(--space-sm);">Department</div>
            <div style="font-weight: 600; font-size: 1.125rem;">
                {% if user.department %}
                    {{ user.department.name }}
                {% else %}
                    <span class="text-muted">Unassigned</span>
                {% endif %}
            </div>
        </div>
        <div class="card card--glow-green">
            <div class="card-title" style="margin-bottom: var(--space-sm);">Monthly Salary</div>
            <div class="card-value" style="font-size: 1.5rem;">
                {% if user.monthly_salary %}
                    ${{ user.monthly_salary|number_format(2, '.', ',') }}
                {% else %}
                    <span class="text-muted">—</span>
                {% endif %}
            </div>
        </div>
        <div class="card card--glow-purple">
            <div class="card-title" style="margin-bottom: var(--space-sm);">Hourly Rate</div>
            <div class="card-value" style="font-size: 1.5rem;">
                {% if user.hourly_rate %}
                    ${{ user.hourly_rate|number_format(2, '.', ',') }}/hr
                {% else %}
                    <span class="text-muted">—</span>
                {% endif %}
            </div>
        </div>
    </div>

    {# Bio & Details #}
    {% if user.bio %}
    <div class="card" style="margin-bottom: var(--space-2xl);">
        <h3 style="margin-bottom: var(--space-md); font-size: 1rem;">Bio</h3>
        <p>{{ user.bio }}</p>
    </div>
    {% endif %}

    {# Face ID Card (only shown to the profile owner) #}
    {% if app.user.id == user.id %}
    <div class="card" style="margin-bottom: var(--space-2xl);">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:var(--space-md)">
            <h3 style="margin:0;font-size:1rem;display:flex;align-items:center;gap:0.5rem">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="1" width="22" height="22" rx="3"/><circle cx="12" cy="10" r="3"/><path d="M7 20v-1a5 5 0 0 1 10 0v1"/></svg>
                Face ID
            </h3>
            {% if user.faceEncoding %}
                <span class="badge badge--green">ON</span>
            {% else %}
                <span class="badge badge--red">OFF</span>
            {% endif %}
        </div>
        <p class="text-muted" style="font-size:0.85rem;margin-bottom:var(--space-md)">
            {% if user.faceEncoding %}
                Face ID is enrolled. You can use it for quick authentication.
            {% else %}
                Face ID is not enrolled. Enroll your face for quick login.
            {% endif %}
        </p>
        <div style="display:flex;gap:var(--space-sm)">
            <a href="{{ path('app_face_enroll') }}" class="btn btn-primary btn-sm">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
                {{ user.faceEncoding ? 'Re-enroll Face' : 'Enroll Face' }}
            </a>
            {% if user.faceEncoding %}
            <form method="post" action="{{ path('app_face_remove') }}" style="display:inline">
                <input type="hidden" name="_token" value="{{ csrf_token('face_remove') }}">
                <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Remove Face ID?')">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                    Remove Face
                </button>
            </form>
            {% endif %}
        </div>
    </div>
    {% endif %}

    <div class="card">
        <div class="card-header">
            <h3 style="margin: 0; font-size: 1rem;">Account Details</h3>
        </div>
        <div class="table-wrapper">
            <table class="table">
                <tbody>
                    <tr>
                        <td class="text-muted" style="width: 200px;">User ID</td>
                        <td>{{ user.id }}</td>
                    </tr>
                    <tr>
                        <td class="text-muted">Email</td>
                        <td>{{ user.email }}</td>
                    </tr>
                    <tr>
                        <td class="text-muted">Online</td>
                        <td>
                            {% if user.is_online %}
                                <span class="badge badge--green">Online</span>
                            {% else %}
                                <span class="badge badge--red">Offline</span>
                            {% endif %}
                        </td>
                    </tr>
                    <tr>
                        <td class="text-muted">Joined</td>
                        <td>{{ user.created_at|date('F d, Y \\a\\t H:i') }}</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    {# Freeze / Unfreeze & Delete Actions #}
    <div class="card" style="margin-top:var(--space-2xl)">
        <div class="card-header"><h3 style="margin:0;font-size:1rem">Account Actions</h3></div>
        <div class="card-body" style="display:flex;gap:1rem;flex-wrap:wrap;align-items:center">
            <form method="post" action="{{ path('app_user_toggle_freeze', {id: user.id}) }}" onsubmit="return confirm('{{ user.is_active ? 'Freeze (deactivate) this user?' : 'Unfreeze (reactivate) this user?' }}')">
                <input type="hidden" name="_token" value="{{ csrf_token('freeze-' ~ user.id) }}">
                {% if user.is_active %}
                    <button type="submit" class="btn" style="background:var(--warning);color:#fff;padding:0.5rem 1.25rem">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:middle;margin-right:0.4rem"><circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/></svg>
                        Freeze Account
                    </button>
                {% else %}
                    <button type="submit" class="btn btn-primary" style="padding:0.5rem 1.25rem">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:middle;margin-right:0.4rem"><polyline points="20 6 9 17 4 12"/></svg>
                        Unfreeze Account
                    </button>
                {% endif %}
            </form>
            <form method="post" action="{{ path('app_user_delete', {id: user.id}) }}" onsubmit="return confirm('Permanently delete this user? This cannot be undone. Consider freezing instead.')">
                <input type="hidden" name="_token" value="{{ csrf_token('delete-' ~ user.id) }}">
                <button type="submit" class="btn btn-danger btn-sm">Permanently Delete</button>
            </form>
        </div>
    </div>
{% endblock %}
