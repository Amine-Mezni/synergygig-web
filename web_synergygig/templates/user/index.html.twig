{% extends 'layouts/admin.html.twig' %}

{% block title %}User Management | SynergyGig{% endblock %}
{% block page_title %}User Management{% endblock %}

{% block header_actions %}{% endblock %}

{% block content %}
    <p class="text-muted" style="margin-bottom:var(--space-lg)">Manage all platform users</p>

    {# ── Search & Filter Bar ── #}
    <div class="card" style="padding:var(--space-md) var(--space-lg);margin-bottom:var(--space-lg);display:flex;align-items:center;gap:var(--space-md)">
        <form method="get" action="{{ path('app_user_index') }}" style="flex:1;display:flex;align-items:center;gap:var(--space-md)">
            <div style="position:relative;flex:1">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--text-muted)" stroke-width="2" style="position:absolute;left:.75rem;top:50%;transform:translateY(-50%)"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                <input type="text" name="q" value="{{ app.request.query.get('q') }}" placeholder="Search by name or email..." class="form-control" style="padding-left:2.25rem">
            </div>
            <select name="role" class="form-control form-select" style="width:auto;min-width:120px">
                <option value="">ALL</option>
                <option value="ADMIN" {{ app.request.query.get('role') == 'ADMIN' ? 'selected' }}>ADMIN</option>
                <option value="HR" {{ app.request.query.get('role') == 'HR' ? 'selected' }}>HR</option>
                <option value="MANAGER" {{ app.request.query.get('role') == 'MANAGER' ? 'selected' }}>MANAGER</option>
                <option value="EMPLOYEE" {{ app.request.query.get('role') == 'EMPLOYEE' ? 'selected' }}>EMPLOYEE</option>
                <option value="FREELANCER" {{ app.request.query.get('role') == 'FREELANCER' ? 'selected' }}>FREELANCER</option>
            </select>
            <button type="submit" class="btn btn-secondary btn-sm">Refresh</button>
        </form>
    </div>

    <p class="text-muted" style="font-size:.8125rem;margin-bottom:var(--space-lg)">{{ pagination is defined ? pagination.totalItemCount : users|length }} users</p>

    {# ── Card Grid (matching Java) ── #}
    {% if users is not empty %}
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:var(--space-lg)">
            {% for user in users %}
            <div class="card" style="padding:0;overflow:hidden;position:relative">
                {# 3-dot menu #}
                <details class="crud-actions-menu" style="position:absolute;top:var(--space-sm);right:var(--space-sm)">
                    <summary class="btn btn-ghost btn-sm" title="Actions" style="padding:4px">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="5" r="2"/><circle cx="12" cy="12" r="2"/><circle cx="12" cy="19" r="2"/></svg>
                    </summary>
                    <div class="crud-actions-dropdown" style="right:0;left:auto">
                        <a href="{{ path('app_user_show', {id: user.id}) }}" class="crud-action-item">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                            View
                        </a>
                        <a href="{{ path('app_user_edit', {id: user.id}) }}" class="crud-action-item">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                            Edit
                        </a>
                        <form method="post" action="{{ path('app_user_toggle_freeze', {id: user.id}) }}" onsubmit="return confirm('{{ user.is_active ? 'Freeze this user account?' : 'Unfreeze this user account?' }}')">
                            <input type="hidden" name="_token" value="{{ csrf_token('freeze-' ~ user.id) }}">
                            <button type="submit" class="crud-action-item {{ user.is_active ? 'crud-action-danger' : '' }}">
                                {% if user.is_active %}
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/></svg>
                                Freeze
                                {% else %}
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                                Unfreeze
                                {% endif %}
                            </button>
                        </form>
                    </div>
                </details>

                {# Card Header #}
                <div style="padding:var(--space-lg)">
                    <div style="font-weight:600;color:var(--text-primary)">{{ user.first_name }} {{ user.last_name }}</div>
                    <div class="text-muted" style="font-size:.75rem">{{ user.email }}</div>

                    <div style="display:flex;align-items:center;gap:.75rem;margin:var(--space-md) 0">
                        <div class="avatar avatar--lg" style="width:52px;height:52px;font-size:1.25rem">{{ user.first_name|first|upper }}{{ user.last_name|first|upper }}</div>
                        <div>
                            {% set role_color = { 'ADMIN': 'red', 'HR': 'purple', 'MANAGER': 'blue', 'EMPLOYEE': 'green', 'FREELANCER': 'orange' } %}
                            <span class="badge badge--{{ role_color[user.role] ?? 'blue' }}">{{ user.role ?? 'EMPLOYEE' }}</span>
                            <div class="text-muted" style="font-size:.75rem;margin-top:4px">Joined {{ user.created_at ? user.created_at|date('M d, Y') : '—' }}</div>
                        </div>
                    </div>

                    <div class="text-muted" style="font-size:.8125rem;margin-bottom:var(--space-xs)">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:middle;margin-right:4px"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
                        ID: {{ user.id }}
                    </div>

                    {% if user.is_active %}
                        <span style="color:var(--color-success);font-size:.8125rem;font-weight:500">● Active</span>
                    {% else %}
                        <span style="color:var(--color-danger);font-size:.8125rem;font-weight:500">● Inactive</span>
                    {% endif %}
                </div>
            </div>
            {% endfor %}
        </div>
    {% else %}
        <div class="card">
            <div class="empty-state">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                <h3>No users yet</h3>
                <p>Users are added automatically when they sign up.</p>
            </div>
        </div>
    {% endif %}

    {% if pagination is defined %}{% include 'components/_pagination.html.twig' %}{% endif %}
{% endblock %}
