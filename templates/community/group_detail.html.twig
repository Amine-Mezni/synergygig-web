{% extends 'layouts/admin.html.twig' %}

{% block page_title %}{{ group.name }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/community.css') }}">
{% endblock %}

{% block content %}
<div class="community-layout">
    {% include 'community/_sidebar.html.twig' %}

    <main class="community-main">
        {# ── Flash Messages ── #}
        {% for type, messages in app.flashes %}
            {% for msg in messages %}
                <div class="flash-toast" data-type="{{ type }}">{{ msg }}</div>
            {% endfor %}
        {% endfor %}

        {# ── Back ── #}
        <a href="{{ path('app_community_groups') }}" style="display:inline-flex;align-items:center;gap:.4rem;color:#8E8E99;font-size:.85rem;margin-bottom:1rem;text-decoration:none">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
            Back to Groups
        </a>

        {# ── Group Info Card ── #}
        <div class="post-card" style="margin-bottom:1.25rem">
            <div style="display:flex;align-items:center;gap:1rem;padding:0 0 1rem">
                <div class="group-icon" style="width:56px;height:56px;font-size:1.5rem">{{ group.name|first|upper }}</div>
                <div style="flex:1">
                    <h2 style="color:#E4E4E8;font-size:1.25rem;margin:0">{{ group.name }}</h2>
                    <div style="color:#8E8E99;font-size:.85rem;margin-top:.25rem">
                        <span class="group-privacy {{ group.privacy|default('PUBLIC') == 'PRIVATE' ? 'private' : '' }}">{{ group.privacy|default('PUBLIC') }}</span>
                        · {{ group.member_count ?? 0 }} members
                        {% if group.creator %} · Created by {{ group.creator.firstName }} {{ group.creator.lastName }}{% endif %}
                    </div>
                    {% if group.description %}
                    <p style="color:#C8C8CC;font-size:.875rem;margin:.75rem 0 0;line-height:1.5">{{ group.description }}</p>
                    {% endif %}
                </div>
                {% if myRole %}
                    {% if myRole == 'ADMIN' %}
                        <span class="btn-admin">Admin</span>
                    {% else %}
                        <form action="{{ path('app_community_leave_group', {id: group.id}) }}" method="post">
                            <button type="submit" class="btn-leave">Leave Group</button>
                        </form>
                    {% endif %}
                {% else %}
                    <form action="{{ path('app_community_join_group', {id: group.id}) }}" method="post">
                        <button type="submit" class="btn-join">Join Group</button>
                    </form>
                {% endif %}
            </div>
        </div>

        {# ── Post Composer (for members) ── #}
        {% if myRole %}
        <div class="post-card post-composer" style="margin-bottom:1.25rem">
            <details class="composer-details">
                <summary class="post-composer-toggle">
                    <div class="composer-avatar">{{ app.user.firstName|default('U')|first|upper }}</div>
                    <span class="composer-placeholder">Post something in {{ group.name }}...</span>
                </summary>
                <div class="post-form-body">
                    <form action="{{ path('app_community_new') }}" method="post" novalidate>
                        <input type="hidden" name="group_id" value="{{ group.id }}">
                        <input type="hidden" name="redirect" value="{{ path('app_community_group_detail', {id: group.id}) }}">
                        <textarea name="content" rows="3" placeholder="Write something..."></textarea>
                        <div class="composer-footer">
                            <select name="visibility" class="visibility-select">
                                <option value="PUBLIC">🌍 Public</option>
                                <option value="PRIVATE">🔒 Members Only</option>
                            </select>
                            <button type="submit" class="btn-publish">Publish</button>
                        </div>
                    </form>
                </div>
            </details>
        </div>
        {% endif %}

        {# ── Group Posts ── #}
        {% for post in posts %}
        {% set r = reactions[post.id]|default({counts:{}, userReaction:null, total:0}) %}
        <article class="post-card" data-post-id="{{ post.id }}">
            <div class="post-header">
                <div class="post-avatar">{{ post.author ? post.author.firstName|first|upper : '?' }}</div>
                <div class="post-meta">
                    <strong class="post-author">{{ post.author ? post.author.firstName ~ ' ' ~ post.author.lastName : 'Unknown' }}</strong>
                    <span class="post-time">{{ post.createdAt ? post.createdAt|date('M d, Y \\a\\t H:i') : '' }}</span>
                </div>
            </div>
            <div class="post-content">
                <p>{{ post.content|nl2br }}</p>
            </div>

            {# Reactions (Twemoji) #}
            <div class="reactions-strip">
                {% for type, info in emojiMap %}
                    {% set count = r.counts[type]|default(0) %}
                    {% if count > 0 %}
                    <form method="post" action="{{ path('app_community_react', {id: post.id}) }}" style="display:inline">
                        <input type="hidden" name="type" value="{{ type }}">
                        <input type="hidden" name="from" value="index">
                        <button type="submit" class="reaction-pill {{ r.userReaction == type ? 'active' : '' }}">
                            <img src="{{ twemojiCdn }}{{ info.hex }}.png" alt="{{ info.label }}" class="twemoji-icon"> {{ count }}
                        </button>
                    </form>
                    {% endif %}
                {% endfor %}
                <details class="reaction-picker-details">
                    <summary class="reaction-add" title="Add reaction">+</summary>
                    <div class="reaction-picker">
                        {% for key, info in emojiMap %}
                            <form method="post" action="{{ path('app_community_react', {id: post.id}) }}" style="display:inline">
                                <input type="hidden" name="type" value="{{ key }}">
                                <input type="hidden" name="from" value="index">
                                <button type="submit" class="reaction-emoji" title="{{ key }}">
                                    <img src="{{ twemojiCdn }}{{ info.hex }}.png" alt="{{ info.label }}" class="twemoji-icon-lg">
                                </button>
                            </form>
                        {% endfor %}
                    </div>
                </details>
            </div>

            <div class="engagement-bar">
                <a href="{{ path('app_community_show', {id: post.id}) }}" class="engagement-btn">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                    {{ post.commentsCount ?? 0 }} Comments
                </a>
                <details class="share-details">
                    <summary class="engagement-btn">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
                        Share
                    </summary>
                    <div class="share-dropdown">
                        <a href="https://www.facebook.com/sharer/sharer.php?u={{ url('app_community_show', {id: post.id})|url_encode }}" target="_blank" rel="noopener" class="share-option">
                            <span class="share-icon" style="background:#1877F2">f</span>
                            <span>Facebook</span>
                        </a>
                        <a href="https://twitter.com/intent/tweet?url={{ url('app_community_show', {id: post.id})|url_encode }}" target="_blank" rel="noopener" class="share-option">
                            <span class="share-icon" style="background:#1DA1F2">𝕏</span>
                            <span>Twitter</span>
                        </a>
                        <span class="share-option share-url-row">
                            <span class="share-icon" style="background:#2C666E">🔗</span>
                            <input type="text" readonly value="{{ url('app_community_show', {id: post.id}) }}" class="share-url-input" title="Select and copy">
                        </span>
                    </div>
                </details>
                <form method="post" action="{{ path('app_community_bookmark', {id: post.id}) }}" style="display:inline">
                    <input type="hidden" name="from" value="index">
                    <button type="submit" class="engagement-btn btn-save {{ post.id in bookmarkedIds ? 'saved' : '' }}">
                        <svg class="bookmark-icon" width="16" height="16" viewBox="0 0 24 24" fill="{{ post.id in bookmarkedIds ? 'currentColor' : 'none' }}" stroke="currentColor" stroke-width="2"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg>
                        <span class="bookmark-label">{{ post.id in bookmarkedIds ? 'Saved' : 'Save' }}</span>
                    </button>
                </form>
            </div>
        </article>
        {% else %}
            <div class="empty-state">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#2C666E" stroke-width="1.5"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                <h3>No posts in this group yet</h3>
                <p style="color:#8E8E99">{% if myRole %}Be the first to post!{% else %}Join the group to start posting.{% endif %}</p>
            </div>
        {% endfor %}
    </main>
</div>

{% endblock %}
