{% extends 'admin/base_admin.html.twig' %}

{% block title %}Liste des utilisateurs{% endblock %}

{% block admin_content %}
<div class="container-fluid pt-4 px-4">
    <div class="bg-secondary rounded p-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="text-white mb-1">Liste des utilisateurs</h2>
                <p class="text-light mb-0">Gestion des comptes utilisateurs</p>
            </div>
        </div>

        {% if users is not empty %}
            <div class="table-responsive">
                <table class="table text-white align-middle mb-0">
                    <thead>
                        <tr>
                            <th class="text-white">ID</th>
                            <th class="text-white">Nom complet</th>
                            <th class="text-white">Email</th>
                            <th class="text-white">Rôle</th>
                            <th class="text-white">Date de création</th>
                            <th class="text-white text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for user in users %}
                            <tr>
                                <td>{{ user.id }}</td>
                                <td>{{ user.full_name }}</td>
                                <td>{{ user.email }}</td>
                                <td>
                                    {% if user.role == 'ADMIN' %}
                                        <span class="badge bg-danger">Admin</span>
                                    {% elseif user.role == 'HR' %}
                                        <span class="badge bg-primary">HR</span>
                                    {% elseif user.role == 'EMPLOYEE' %}
                                        <span class="badge bg-secondary">Employee</span>
                                    {% elseif user.role == 'GIG_WORKER' %}
                                        <span class="badge bg-success">Gig Worker</span>
                                    {% else %}
                                        <span class="badge bg-dark">{{ user.role }}</span>
                                    {% endif %}
                                </td>
                                <td>{{ user.created_at|date('d/m/Y H:i') }}</td>
                                <td class="text-end">
                                   <a href="{{ path('app_admin_user_show', {'id': user.id}) }}" class="btn btn-sm btn-primary rounded-pill px-3">
    Voir
</a>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% else %}
            <div class="text-center py-4">
                <h4 class="text-white mb-2">Aucun utilisateur</h4>
                <p class="text-light mb-0">La base ne contient encore aucun utilisateur.</p>
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}