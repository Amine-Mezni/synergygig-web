{% block javascripts %}
    {{ parent() }}
    <script>
    (function () {
        var visual = document.getElementById('heroVisual');
        var canvas = document.getElementById('heroGlobeCanvas');
        var meterBar = document.getElementById('scrollMeterBar');
        if (!visual || !canvas) {
            return;
        }

        var items = visual.querySelectorAll('.orbit-item, .hero-chip');
        var reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        function initGlobe() {
            var dpr = Math.min(window.devicePixelRatio || 1, 2);
            var rect = canvas.getBoundingClientRect();
            var width = Math.max(1, Math.floor(rect.width));
            var height = Math.max(1, Math.floor(rect.height));
            canvas.width = width * dpr;
            canvas.height = height * dpr;
            var ctx = canvas.getContext('2d');
            if (!ctx) {
                return;
            }
            ctx.setTransform(dpr, 0, 0, dpr, 0, 0);

            var points = [];
            var total = 240;
            for (var i = 0; i < total; i++) {
                var phi = Math.acos(1 - (2 * (i + 0.5) / total));
                var theta = Math.PI * (1 + Math.sqrt(5)) * (i + 0.5);
                points.push({
                    x: Math.sin(phi) * Math.cos(theta),
                    y: Math.cos(phi),
                    z: Math.sin(phi) * Math.sin(theta)
                });
            }

            var angleX = 0;
            var angleY = 0;
            var mouseX = 0;
            var mouseY = 0;
            var rafId = 0;

            function rotate(point, ax, ay) {
                var cosX = Math.cos(ax);
                var sinX = Math.sin(ax);
                var cosY = Math.cos(ay);
                var sinY = Math.sin(ay);

                var y = point.y * cosX - point.z * sinX;
                var z = point.y * sinX + point.z * cosX;
                var x = point.x * cosY + z * sinY;
                z = -point.x * sinY + z * cosY;

                return { x: x, y: y, z: z };
            }

            function draw() {
                ctx.clearRect(0, 0, width, height);

                var centerX = width / 2;
                var centerY = height / 2;
                var radius = Math.min(width, height) * 0.3;
                var perspective = radius * 2.1;

                var projected = [];
                for (var i = 0; i < points.length; i++) {
                    var p = rotate(points[i], angleX + mouseY, angleY + mouseX);
                    var depth = (p.z + 1) / 2;
                    var scale = perspective / (perspective - p.z * radius * 0.9);
                    projected.push({
                        x: centerX + p.x * radius * scale,
                        y: centerY + p.y * radius * scale,
                        z: p.z,
                        depth: depth,
                        scale: scale
                    });
                }

                for (var a = 0; a < projected.length; a++) {
                    for (var b = a + 1; b < projected.length; b++) {
                        var dx = projected[a].x - projected[b].x;
                        var dy = projected[a].y - projected[b].y;
                        var dist = Math.sqrt(dx * dx + dy * dy);
                        if (dist < 46) {
                            var alpha = (1 - dist / 46) * 0.23 * (projected[a].depth + projected[b].depth);
                            ctx.strokeStyle = 'rgba(176, 168, 255,' + alpha.toFixed(3) + ')';
                            ctx.beginPath();
                            ctx.moveTo(projected[a].x, projected[a].y);
                            ctx.lineTo(projected[b].x, projected[b].y);
                            ctx.stroke();
                        }
                    }
                }

                projected.sort(function (p1, p2) { return p1.z - p2.z; });
                for (var j = 0; j < projected.length; j++) {
                    var pt = projected[j];
                    var dotSize = 0.9 + pt.depth * 2.2;
                    var c1 = Math.floor(120 + 100 * pt.depth);
                    var c2 = Math.floor(90 + 140 * pt.depth);
                    var c3 = Math.floor(170 + 70 * (1 - pt.depth));
                    ctx.fillStyle = 'rgba(' + c1 + ',' + c2 + ',' + c3 + ',0.92)';
                    ctx.beginPath();
                    ctx.arc(pt.x, pt.y, dotSize, 0, Math.PI * 2);
                    ctx.fill();
                }

                angleY += 0.0036;
                angleX += 0.0012;

                if (!reduceMotion) {
                    rafId = window.requestAnimationFrame(draw);
                }
            }

            if (!reduceMotion) {
                draw();
            } else {
                draw();
                if (rafId) {
                    window.cancelAnimationFrame(rafId);
                }
            }

            visual.addEventListener('mousemove', function (event) {
                var r = visual.getBoundingClientRect();
                var nx = ((event.clientX - r.left) / r.width) - 0.5;
                var ny = ((event.clientY - r.top) / r.height) - 0.5;
                mouseX = nx * 0.3;
                mouseY = ny * 0.3;
            });

            visual.addEventListener('mouseleave', function () {
                mouseX = 0;
                mouseY = 0;
            });

            window.addEventListener('resize', function () {
                if (rafId) {
                    window.cancelAnimationFrame(rafId);
                }
                initGlobe();
            }, { once: true });
        }

        initGlobe();

        var revealTargets = document.querySelectorAll(
            '.hero__content, .hero-visual, .hero__loading, .narr__eyebrow, .narr__heading, .narr__block, .narr__stat, .narr__stat-label, .features__eyebrow, .features__heading, .feat-card, .principles__eyebrow, .principles__heading, .princ, .s-cta__inner, .lf__top, .lf__bottom'
        );

        revealTargets.forEach(function (el, idx) {
            el.classList.add('reveal-on-scroll');
            if (el.classList.contains('feat-card') || el.classList.contains('princ')) {
                el.classList.add('reveal-hard');
            } else {
                el.classList.add('reveal-soft');
            }
            var groupIndex = idx % 6;
            el.style.setProperty('--reveal-delay', String(groupIndex * 55) + 'ms');
        });

        function applyInView(entries) {
            entries.forEach(function (entry) {
                if (entry.isIntersecting) {
                    entry.target.classList.add('is-inview');
                } else {
                    entry.target.classList.remove('is-inview');
                }
            });
        }

        var observer = new IntersectionObserver(applyInView, {
            threshold: 0.18,
            rootMargin: '-6% 0px -10% 0px'
        });

        revealTargets.forEach(function (el) { observer.observe(el); });

        var auroras = document.querySelectorAll('.aurora');

        function onScroll() {
            var doc = document.documentElement;
            var maxScroll = Math.max(1, doc.scrollHeight - window.innerHeight);
            var ratio = Math.min(1, Math.max(0, window.scrollY / maxScroll));

            if (meterBar) {
                meterBar.style.width = (ratio * 100).toFixed(2) + '%';
            }

            auroras.forEach(function (blob, index) {
                var depth = (index % 2 === 0) ? 0.14 : 0.08;
                var y = window.scrollY * depth;
                blob.style.transform = 'translate3d(0,' + y.toFixed(2) + 'px,0)';
            });
        }

        window.addEventListener('scroll', onScroll, { passive: true });
        onScroll();

        var maskEls = document.querySelectorAll('.mask-reveal, .mask-reveal-text, .mask-reveal-diamond');

        function updateMasks() {
            var viewH = window.innerHeight;
            maskEls.forEach(function (el) {
                var rect = el.getBoundingClientRect();
                var start = viewH * 0.9;
                var end = viewH * 0.3;
                var progress = 0;
                if (rect.top < start) {
                    progress = Math.min(1, Math.max(0, (start - rect.top) / (start - end)));
                }
                var eased = 1 - Math.pow(1 - progress, 3);
                el.style.setProperty('--mask-progress', eased.toFixed(4));
            });
        }

        window.addEventListener('scroll', updateMasks, { passive: true });
        window.addEventListener('resize', updateMasks, { passive: true });
        updateMasks();

        if (window.matchMedia('(max-width: 500px)').matches) {
            return;
        }

        visual.addEventListener('mousemove', function (event) {
            var rect = visual.getBoundingClientRect();
            var x = (event.clientX - rect.left) / rect.width - 0.5;
            var y = (event.clientY - rect.top) / rect.height - 0.5;
            var mx = Math.max(-1, Math.min(1, x)) * 24;
            var my = Math.max(-1, Math.min(1, y)) * 24;
            visual.style.setProperty('--mx', mx.toFixed(2) + 'px');
            visual.style.setProperty('--my', my.toFixed(2) + 'px');

            items.forEach(function (item) {
                var depth = Number(item.getAttribute('data-depth') || 12);
                var tx = (mx * depth) / 24;
                var ty = (my * depth) / 24;
                item.style.transform = 'translate3d(' + tx.toFixed(2) + 'px, ' + ty.toFixed(2) + 'px, 0)';
            });
        });

        visual.addEventListener('mouseleave', function () {
            visual.style.setProperty('--mx', '0px');
            visual.style.setProperty('--my', '0px');
            items.forEach(function (item) {
                item.style.transform = 'translate3d(0,0,0)';
            });
        });
    })();
    </script>
{% endblock %}