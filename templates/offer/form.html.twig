{% extends 'layouts/admin.html.twig' %}

{% block page_title %}{{ offer is defined and offer.id ? 'Edit Offer' : 'New Offer' }}{% endblock %}

{% block content %}
<div class="card" style="max-width:900px">
    <div class="card__header">
        <h3>{{ offer is defined and offer.id ? 'Edit Offer' : 'Create Offer' }}</h3>
    </div>
    <div class="card__body">
        {{ form_start(form, {'attr': {'class': 'form', 'novalidate': 'novalidate'}}) }}

        <div class="form-grid" style="display:grid;grid-template-columns:1fr 1fr;gap:1rem">
            <div class="form-group" style="grid-column:1/-1">
                {{ form_label(form.title) }}
                {{ form_widget(form.title, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.title) }}
            </div>

            <div class="form-group">
                {{ form_label(form.offer_type) }}
                {{ form_widget(form.offer_type, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.offer_type) }}
            </div>
            <div class="form-group">
                {{ form_label(form.status) }}
                {{ form_widget(form.status, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.status) }}
            </div>

            <div class="form-group">
                {{ form_label(form.department) }}
                {{ form_widget(form.department, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.department) }}
            </div>
            <div class="form-group">
                {{ form_label(form.owner) }}
                {{ form_widget(form.owner, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.owner) }}
            </div>

            <div class="form-group">
                {{ form_label(form.location) }}
                {{ form_widget(form.location, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.location) }}
            </div>
            <div class="form-group">
                {{ form_label(form.required_skills) }}
                {{ form_widget(form.required_skills, {'attr': {'class': 'form-control', 'placeholder': 'PHP, Symfony, MySQL...'}}) }}
                {{ form_errors(form.required_skills) }}
            </div>

            <div class="form-group">
                {{ form_label(form.amount) }}
                {{ form_widget(form.amount, {'attr': {'class': 'form-control', 'step': '0.01'}}) }}
                {{ form_errors(form.amount) }}
            </div>
            <div class="form-group">
                {{ form_label(form.currency) }}
                {{ form_widget(form.currency, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.currency) }}
            </div>

            <div class="form-group">
                {{ form_label(form.start_date) }}
                {{ form_widget(form.start_date, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.start_date) }}
            </div>
            <div class="form-group">
                {{ form_label(form.end_date) }}
                {{ form_widget(form.end_date, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.end_date) }}
            </div>

            <div class="form-group" style="grid-column:1/-1">
                {{ form_label(form.description) }}
                {{ form_widget(form.description, {'attr': {'class': 'form-control', 'rows': '4'}}) }}
                {{ form_errors(form.description) }}
            </div>
        </div>

        <div style="display:flex;gap:0.5rem;margin-top:1.5rem">
            <button type="submit" class="btn btn-primary">Save Offer</button>
            <a href="{{ path('app_offer_index') }}" class="btn btn-ghost">Cancel</a>
        </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
