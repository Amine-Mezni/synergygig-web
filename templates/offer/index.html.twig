{% extends 'front/base_front.html.twig' %}

{% block title %}Offres disponibles{% endblock %}

{% block body %}
<section class="offers-hero" id="hero">
    <div class="container text-center">
        <span class="offers-badge">SynergyGig Marketplace</span>
        <h1>Offres disponibles</h1>
        <p>Découvrez les gigs publiés par nos clients et trouvez votre prochaine mission avec une expérience moderne, claire et intelligente.</p>
    </div>
</section>

<section class="offers-list-section">
    <div class="container">

        <div class="offers-toolbar-card mb-5">
            <form method="get" action="{{ path('app_front_offers') }}" class="offers-toolbar-form">

                <div class="offers-toolbar-top">
                    <input
                        type="text"
                        name="q"
                        class="form-control offers-filter-input offers-search-input"
                        placeholder="Rechercher une offre, une mission, une compétence..."
                        value="{{ currentSearch|default('') }}"
                    >
                </div>

                <div class="offers-toolbar-bottom">
                    <div class="offers-toolbar-filters">

                        <div class="offers-filter-group">
                            <label class="offers-filter-label">Type</label>
                            <select name="type" class="form-select offers-filter-input">
                                <option value="">Tous les types</option>
                                <option value="GIG" {{ currentType is defined and currentType == 'GIG' ? 'selected' : '' }}>Gig</option>
                                <option value="INTERNAL" {{ currentType is defined and currentType == 'INTERNAL' ? 'selected' : '' }}>Internal</option>
                            </select>
                        </div>

                        <div class="offers-filter-group">
                            <label class="offers-filter-label">Tri</label>
                            <select name="sort" class="form-select offers-filter-input">
                                <option value="recent" {{ currentSort is defined and currentSort == 'recent' ? 'selected' : '' }}>Plus récentes</option>
                                <option value="oldest" {{ currentSort is defined and currentSort == 'oldest' ? 'selected' : '' }}>Plus anciennes</option>
                                <option value="budget_asc" {{ currentSort is defined and currentSort == 'budget_asc' ? 'selected' : '' }}>Budget croissant</option>
                                <option value="budget_desc" {{ currentSort is defined and currentSort == 'budget_desc' ? 'selected' : '' }}>Budget décroissant</option>
                            </select>
                        </div>

                        <div class="offers-filter-actions">
                            <button type="submit" class="offers-filter-btn">
                                <i class="bi bi-search me-2"></i>
                                Rechercher
                            </button>

                            <a href="{{ path('app_front_offers') }}" class="offers-reset-btn">
                                Réinitialiser
                            </a>
                        </div>
                    </div>

                    <div class="offers-results-box">
                        <span class="offers-results-label">Résultats trouvés</span>
                        <strong>{{ offersCount|default(offers|length) }}</strong>
                        <p class="mb-0">Offres publiées correspondant à vos critères actuels.</p>
                    </div>
                </div>
            </form>
        </div>

        <div class="offers-top-tags mb-4">
            <span class="top-tag">Web Development</span>
            <span class="top-tag">Frontend Development</span>
            <span class="top-tag">Backend Development</span>
            <span class="top-tag">UI/UX Design</span>
            <span class="top-tag">Graphic Design</span>
            <span class="top-tag">SEO / Analytics</span>
        </div>

        {% if offers is not empty %}
            <div class="offers-grid">
                {% for offer in offers %}
                    <article class="offer-card h-100 d-flex flex-column">
                        <div class="offer-card-image">
                            {% if loop.index <= 2 %}
                                <div class="offer-featured-badge">Featured</div>
                            {% endif %}

                            {% if offer.id in appliedOfferIds %}
                                <div class="offer-applied-badge">Déjà postulé</div>
                            {% endif %}

                            {% if offer.imageUrl %}
                                <img src="{{ asset('uploads/offers/' ~ offer.imageUrl) }}" alt="{{ offer.title }}">
                            {% else %}
                                <img src="{{ asset('front/img/blog/blog-1.jpg') }}" alt="{{ offer.title }}">
                            {% endif %}

                            <div class="offer-type-badge">{{ offer.type }}</div>
                        </div>

                        <div class="offer-card-body d-flex flex-column">
                            <div class="offer-meta">
                                <span><i class="bi bi-cash-stack"></i> {{ offer.amount ?? '---' }} $</span>
                                <span><i class="bi bi-patch-check"></i> Publiée</span>
                            </div>

                            <h3 class="offer-card-title">{{ offer.title }}</h3>

                            <div class="offer-mini-badges">
                                <span class="offer-mini-badge badge-skill">Web / Digital</span>
                                <span class="offer-mini-badge badge-ai">AI Scored</span>
                            </div>

                            <p class="offer-card-description">
                                {{ offer.description|length > 140 ? offer.description|slice(0, 140) ~ '...' : offer.description }}
                            </p>

                            <div class="offer-card-footer mt-auto pt-3">
                                <a href="{{ path('app_front_offer_show', {'id': offer.id}) }}" class="offer-apply-btn">
                                    <span>Voir l’offre</span>
                                    <i class="bi bi-arrow-right"></i>
                                </a>
                            </div>
                        </div>
                    </article>
                {% endfor %}
            </div>
        {% else %}
            <div class="offers-empty text-center">
                <h3>Aucune offre publiée pour le moment</h3>
                <p>Aucun résultat ne correspond à vos critères. Essayez avec une autre recherche ou un autre filtre.</p>
                <a href="{{ path('app_front_offers') }}" class="offers-reset-btn mt-3 d-inline-flex">
                    Réinitialiser les filtres
                </a>
            </div>
        {% endif %}

    </div>
</section>
{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
.container {
    max-width: 1200px !important;
    margin: 0 auto !important;
    padding-left: 18px;
    padding-right: 18px;
}

.offers-hero {
    padding: 150px 0 70px;
    background:
        radial-gradient(circle at top left, rgba(14, 165, 164, 0.16), transparent 28%),
        radial-gradient(circle at bottom right, rgba(34, 211, 238, 0.10), transparent 30%),
        linear-gradient(135deg, #020617 0%, #081120 45%, #0f172a 100%);
    text-align: center;
}

.offers-badge {
    display: inline-block;
    padding: 8px 18px;
    border-radius: 999px;
    background: rgba(14, 165, 164, 0.12);
    border: 1px solid rgba(14, 165, 164, 0.28);
    color: #67e8f9;
    font-weight: 600;
    margin-bottom: 16px;
}

.offers-hero h1 {
    color: #fff;
    font-size: 2.8rem;
    font-weight: 800;
    margin-bottom: 12px;
}

.offers-hero p {
    color: rgba(255, 255, 255, 0.75);
    max-width: 760px;
    margin: 0 auto;
}

.offers-list-section {
    padding: 70px 0 90px;
    background: linear-gradient(180deg, #020617 0%, #0b1220 100%);
}

/* toolbar */
.offers-toolbar-card {
    padding: 28px;
    border-radius: 28px;
    background: linear-gradient(145deg, rgba(15,23,42,0.96), rgba(2,6,23,0.96));
    border: 1px solid rgba(255,255,255,0.06);
    box-shadow: 0 18px 40px rgba(0,0,0,0.28);
}

.offers-toolbar-form {
    display: flex;
    flex-direction: column;
    gap: 24px;
}

.offers-toolbar-top {
    width: 100%;
}

.offers-search-input {
    width: 100%;
    height: 58px;
    padding: 0 20px !important;
}

.offers-toolbar-bottom {
    display: grid;
    grid-template-columns: minmax(0, 2fr) 320px;
    gap: 24px;
    align-items: stretch;
}

.offers-toolbar-filters {
    display: grid;
    grid-template-columns: 220px 260px 1fr;
    gap: 16px;
    align-items: end;
}

.offers-filter-group {
    min-width: 0;
}

.offers-filter-label {
    display: block;
    margin-bottom: 10px;
    color: rgba(255,255,255,0.72);
    font-size: 0.92rem;
    font-weight: 600;
}

.offers-filter-input {
    width: 100%;
    height: 54px;
    padding: 0 18px !important;
    border-radius: 16px !important;
    background: linear-gradient(145deg, rgba(15,23,42,0.96), rgba(2,6,23,0.96)) !important;
    border: 1px solid rgba(255,255,255,0.10) !important;
    color: #fff !important;
    box-shadow: none !important;
}

.offers-filter-input::placeholder {
    color: rgba(255,255,255,0.45);
}

.offers-filter-input:focus {
    border-color: rgba(14, 165, 164, 0.60) !important;
    box-shadow: 0 0 0 0.2rem rgba(14, 165, 164, 0.12) !important;
    background: rgba(255, 255, 255, 0.08) !important;
}

select.offers-filter-input option {
    background: #0f172a;
    color: #fff;
}

.offers-filter-actions {
    display: flex;
    gap: 14px;
    align-items: end;
    flex-wrap: wrap;
}

.offers-filter-btn,
.offers-reset-btn {
    min-width: 170px;
    height: 54px;
    padding: 0 24px;
    border-radius: 16px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    text-decoration: none;
    transition: all 0.25s ease;
}

.offers-filter-btn {
    background: linear-gradient(90deg, #0ea5a4, #22d3ee);
    color: #fff;
    border: none;
    box-shadow: 0 10px 24px rgba(14, 165, 164, 0.22);
}

.offers-reset-btn {
    background: rgba(255,255,255,0.06);
    color: #fff;
    border: 1px solid rgba(255,255,255,0.10);
}

.offers-filter-btn:hover,
.offers-reset-btn:hover {
    transform: translateY(-2px);
    color: #fff;
}

.offers-results-box {
    height: 100%;
    min-height: 170px;
    padding: 24px;
    border-radius: 22px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    display: flex;
    flex-direction: column;
    justify-content: center;
}

.offers-results-label {
    color: rgba(255,255,255,0.64);
    margin-bottom: 8px;
    font-size: 0.92rem;
}

.offers-results-box strong {
    color: #fff;
    font-size: 2.4rem;
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 8px;
}

.offers-results-box p {
    color: rgba(255,255,255,0.72);
    line-height: 1.7;
}

/* tags */
.offers-top-tags {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 28px;
}

.top-tag {
    padding: 10px 14px;
    border-radius: 999px;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.08);
    color: rgba(255,255,255,0.78);
    font-size: 0.84rem;
    font-weight: 600;
}

/* cards */
.offers-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
}

.offer-card {
    background: linear-gradient(145deg, rgba(15,23,42,0.98), rgba(2,6,23,0.96));
    border: 1px solid rgba(14, 165, 164, 0.10);
    border-radius: 24px;
    overflow: hidden;
    box-shadow: 0 15px 40px rgba(0,0,0,0.35);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
}

.offer-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 22px 50px rgba(0,0,0,0.42);
}

.offer-card-image {
    position: relative;
    height: 220px;
    overflow: hidden;
    background: #111827;
}

.offer-card-image::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(14,165,164,0.08), rgba(0,0,0,0.15));
    z-index: 1;
    pointer-events: none;
}

.offer-card-image::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.55), rgba(0,0,0,0.08));
    z-index: 2;
    pointer-events: none;
}

.offer-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
}

.offer-card:hover .offer-card-image img {
    transform: scale(1.05);
}

.offer-featured-badge {
    position: absolute;
    top: 16px;
    left: 16px;
    z-index: 3;
    background: rgba(0,0,0,0.55);
    color: #fff;
    border: 1px solid rgba(255,255,255,0.12);
    padding: 7px 12px;
    border-radius: 999px;
    font-size: 0.78rem;
    font-weight: 700;
}

.offer-applied-badge {
    position: absolute;
    left: 16px;
    bottom: 16px;
    z-index: 3;
    background: rgba(14, 165, 164, 0.18);
    color: #99f6e4;
    border: 1px solid rgba(14, 165, 164, 0.35);
    padding: 7px 12px;
    border-radius: 999px;
    font-size: 0.78rem;
    font-weight: 700;
}

.offer-type-badge {
    position: absolute;
    top: 16px;
    right: 16px;
    z-index: 3;
    background: linear-gradient(90deg, #0ea5a4, #22d3ee);
    color: #fff;
    padding: 8px 14px;
    border-radius: 999px;
    font-size: 0.85rem;
    font-weight: 700;
}

.offer-card-body {
    padding: 24px;
}

.offer-meta {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    margin-bottom: 14px;
    color: rgba(255,255,255,0.68);
    font-size: 0.92rem;
}

.offer-meta i {
    color: #22d3ee;
    margin-right: 6px;
}

.offer-card-title {
    color: #fff;
    font-size: 1.35rem;
    font-weight: 700;
    line-height: 1.4;
    margin-bottom: 12px;
}

.offer-mini-badges {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin-bottom: 14px;
}

.offer-mini-badge {
    padding: 7px 12px;
    border-radius: 999px;
    font-size: 0.78rem;
    font-weight: 700;
}

.badge-skill {
    background: rgba(255,255,255,0.05);
    color: rgba(255,255,255,0.78);
    border: 1px solid rgba(255,255,255,0.08);
}

.badge-ai {
    background: rgba(34, 211, 238, 0.14);
    color: #a5f3fc;
    border: 1px solid rgba(34, 211, 238, 0.30);
}

.offer-card-description {
    color: rgba(255,255,255,0.72);
    line-height: 1.7;
    margin-bottom: 0;
}

.offer-apply-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    width: 100%;
    padding: 14px 22px;
    border-radius: 14px;
    background: transparent;
    border: 1px solid rgba(14, 165, 164, 0.30);
    color: #ffffff;
    text-decoration: none;
    font-weight: 700;
    transition: all 0.25s ease;
}

.offer-apply-btn:hover {
    background: linear-gradient(90deg, #0ea5a4, #22d3ee);
    border-color: transparent;
    color: #fff;
    box-shadow: 0 10px 24px rgba(14, 165, 164, 0.22);
}

.offers-empty {
    padding: 60px 30px;
    border-radius: 24px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.06);
    color: #fff;
}

@media (max-width: 992px) {
    .offers-toolbar-bottom {
        grid-template-columns: 1fr;
    }

    .offers-toolbar-filters {
        grid-template-columns: 1fr 1fr;
    }

    .offers-grid {
        grid-template-columns: repeat(2, 1fr);
    }
}

@media (max-width: 768px) {
    .offers-hero {
        padding: 130px 0 55px;
    }

    .offers-hero h1 {
        font-size: 2.1rem;
    }

    .offers-toolbar-card {
        padding: 20px;
    }

    .offer-card-image {
        height: 220px;
    }
}

@media (max-width: 576px) {
    .offers-toolbar-filters {
        grid-template-columns: 1fr;
    }

    .offers-filter-actions {
        flex-direction: column;
        align-items: stretch;
    }

    .offers-filter-btn,
    .offers-reset-btn {
        width: 100%;
    }

    .offers-grid {
        grid-template-columns: 1fr;
    }
}
</style>
{% endblock %}