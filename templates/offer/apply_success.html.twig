{% extends 'front/base_front.html.twig' %}

{% block title %}Intérêt enregistré - {{ offer.title }}{% endblock %}
{% block body_class %}offer-apply-success-page{% endblock %}

{% block body %}
<section class="apply-success-section">
    <div class="container">
        <div class="apply-success-card text-center">
            <div class="success-glow"></div>

            <div class="success-icon">
                <i class="bi bi-check2-circle"></i>
            </div>

            <span class="success-badge">SynergyGig</span>

           {% if alreadyApplied %}
    <h1>Vous avez déjà postulé</h1>
    <p class="success-text">
        Une candidature existe déjà pour l’offre
        <strong>“{{ offer.title }}”</strong>.
        Vous pouvez attendre la décision de l’administration ou consulter d’autres offres.
    </p>
{% else %}
    <h1>Postulation enregistrée avec succès</h1>
    <p class="success-text">
        Votre candidature pour l’offre
        <strong>“{{ offer.title }}”</strong>
        a bien été enregistrée. Elle est maintenant en attente de traitement par l’administration.
    </p>
{% endif %}

            <div class="success-offer-box">
                <div class="row g-0 align-items-center">
                    <div class="col-md-4">
                        <div class="success-offer-image-wrap">
                            {% if offer.imageUrl %}
                                <img src="{{ asset('uploads/offers/' ~ offer.imageUrl) }}" alt="{{ offer.title }}" class="success-offer-image">
                            {% else %}
                                <img src="{{ asset('front/img/blog/blog-1.jpg') }}" alt="{{ offer.title }}" class="success-offer-image">
                            {% endif %}
                        </div>
                    </div>

                    <div class="col-md-8">
                        <div class="success-offer-content">
                            <span class="success-offer-type">{{ offer.type }}</span>
                            <h3>{{ offer.title }}</h3>
                            <div class="success-offer-meta">
                                <span><i class="bi bi-cash-stack"></i> {{ offer.amount ?? '---' }} $</span>
                                <span><i class="bi bi-patch-check-fill"></i> Offre publiée</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="success-note">
                <i class="bi bi-info-circle-fill"></i>
                <span>
                    Dès l’intégration complète du module utilisateur, vous pourrez suivre vos candidatures, leur statut et les réponses de l’administration.
                </span>
            </div>

            <div class="success-actions">
                <a href="{{ path('app_front_offer_show', {'id': offer.id}) }}" class="success-primary-btn">
                    Retour à l’offre
                </a>

                <a href="{{ path('app_front_offers') }}" class="success-secondary-btn">
                    Voir les autres offres
                </a>
            </div>
        </div>
    </div>
</section>
{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
.apply-success-section {
    min-height: 100vh;
    padding: 150px 0 90px;
    background:
        radial-gradient(circle at top left, rgba(255, 0, 76, 0.16), transparent 28%),
        radial-gradient(circle at bottom right, rgba(255, 80, 80, 0.10), transparent 30%),
        linear-gradient(135deg, #050505 0%, #0b0b12 50%, #16070d 100%);
    display: flex;
    align-items: center;
}

.apply-success-card {
    position: relative;
    max-width: 860px;
    margin: 0 auto;
    padding: 48px 34px;
    border-radius: 30px;
    background: linear-gradient(145deg, rgba(18,18,24,0.98), rgba(10,10,14,0.96));
    border: 1px solid rgba(255, 0, 76, 0.10);
    box-shadow: 0 18px 45px rgba(0,0,0,0.35);
    overflow: hidden;
}

.success-glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at top center, rgba(255, 0, 76, 0.10), transparent 40%);
    pointer-events: none;
}

.success-icon {
    position: relative;
    z-index: 2;
    font-size: 4rem;
    color: #ff3b5c;
    margin-bottom: 16px;
}

.success-badge {
    position: relative;
    z-index: 2;
    display: inline-block;
    padding: 8px 18px;
    border-radius: 999px;
    background: rgba(255, 0, 76, 0.12);
    border: 1px solid rgba(255, 0, 76, 0.28);
    color: #ff4d6d;
    font-weight: 600;
    margin-bottom: 18px;
}

.apply-success-card h1 {
    position: relative;
    z-index: 2;
    color: #fff;
    font-size: 2.4rem;
    font-weight: 800;
    margin-bottom: 16px;
}

.success-text {
    position: relative;
    z-index: 2;
    color: rgba(255,255,255,0.76);
    line-height: 1.9;
    max-width: 700px;
    margin: 0 auto 30px;
}

.success-text strong {
    color: #fff;
}

.success-offer-box {
    position: relative;
    z-index: 2;
    padding: 0;
    border-radius: 24px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    margin-bottom: 24px;
    overflow: hidden;
    text-align: left;
}

.success-offer-image-wrap {
    height: 100%;
    min-height: 220px;
}

.success-offer-image {
    width: 100%;
    height: 100%;
    min-height: 220px;
    object-fit: cover;
    display: block;
}

.success-offer-content {
    padding: 26px;
}

.success-offer-type {
    display: inline-block;
    margin-bottom: 12px;
    padding: 6px 12px;
    border-radius: 999px;
    background: linear-gradient(90deg, #ff003c, #ff4d4d);
    color: #fff;
    font-size: 0.82rem;
    font-weight: 700;
}

.success-offer-content h3 {
    color: #fff;
    font-size: 1.5rem;
    font-weight: 800;
    margin-bottom: 14px;
}

.success-offer-meta {
    display: flex;
    gap: 18px;
    flex-wrap: wrap;
    color: rgba(255,255,255,0.72);
    font-size: 0.95rem;
}

.success-offer-meta i {
    color: #ff3b5c;
    margin-right: 6px;
}

.success-note {
    position: relative;
    z-index: 2;
    display: flex;
    gap: 12px;
    align-items: flex-start;
    padding: 18px 20px;
    border-radius: 18px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    color: rgba(255,255,255,0.78);
    margin-bottom: 28px;
    text-align: left;
}

.success-note i {
    color: #ff4d6d;
    font-size: 1.1rem;
    margin-top: 2px;
}

.success-actions {
    position: relative;
    z-index: 2;
    display: flex;
    justify-content: center;
    gap: 14px;
    flex-wrap: wrap;
}

.success-primary-btn,
.success-secondary-btn {
    display: inline-flex;
    justify-content: center;
    align-items: center;
    padding: 14px 22px;
    border-radius: 16px;
    text-decoration: none;
    font-weight: 700;
    transition: all 0.25s ease;
}

.success-primary-btn {
    background: linear-gradient(90deg, #ff003c, #ff4d4d);
    color: #fff;
    box-shadow: 0 10px 25px rgba(255, 0, 76, 0.25);
}

.success-primary-btn:hover {
    color: #fff;
    transform: translateY(-2px);
}

.success-secondary-btn {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.08);
    color: #fff;
}

.success-secondary-btn:hover {
    color: #fff;
    background: rgba(255,255,255,0.10);
}

@media (max-width: 768px) {
    .apply-success-section {
        padding: 130px 0 70px;
    }

    .apply-success-card {
        padding: 34px 22px;
    }

    .apply-success-card h1 {
        font-size: 1.9rem;
    }

    .success-offer-content {
        padding: 22px;
    }

    .success-offer-content h3 {
        font-size: 1.3rem;
    }
}
</style>
{% endblock %}