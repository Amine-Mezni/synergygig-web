{# ════════════════════════════════════════════════════════════════════════════ #}
{# ── JAVASCRIPT ───────────────────────────────────────────────────────────── #}
{# ════════════════════════════════════════════════════════════════════════════ #}
<script>
// ── Tab Switching ──
function switchHubTab(tab) {
    document.querySelectorAll('.hub-tab').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.hub-panel').forEach(p => p.classList.remove('active'));
    document.querySelector('.hub-tab[data-tab="'+tab+'"]').classList.add('active');
    const panel = document.getElementById('panel-'+tab);
    if (panel) panel.classList.add('active');
}

// ── Marketplace: Search Filter ──
function filterMarketplace() {
    const q = document.getElementById('marketplaceSearch').value.toLowerCase();
    const activeType = document.querySelector('.pill-filter.active[data-type]');
    const typeFilter = activeType ? activeType.dataset.type : '';

    // Internal offers
    const internalSection = document.getElementById('offersGrid');
    const extSection = document.querySelector('.ext-section-header');
    const extGrid = document.getElementById('extJobsGrid');

    if (typeFilter === 'EXTERNAL') {
        internalSection.style.display = 'none';
        if (extSection) extSection.style.display = '';
        if (extGrid) extGrid.style.display = '';
        if (q.length >= 2) {
            document.getElementById('extJobQuery').value = q;
            loadExternalJobs();
        }
        return;
    }

    internalSection.style.display = '';
    if (extSection) extSection.style.display = '';
    if (extGrid) extGrid.style.display = '';

    document.querySelectorAll('.offer-card[data-type]').forEach(card => {
        const title = card.dataset.title || '';
        const skills = card.dataset.skills || '';
        const location = card.dataset.location || '';
        const matchesSearch = !q || title.includes(q) || skills.includes(q) || location.includes(q);
        const matchesType = !typeFilter || card.dataset.type === typeFilter;
        card.style.display = (matchesSearch && matchesType) ? '' : 'none';
    });
}

// ── Marketplace: Pill Type Filter ──
function filterByType(btn) {
    document.querySelectorAll('#pillFilters .pill-filter').forEach(p => p.classList.remove('active'));
    btn.classList.add('active');
    filterMarketplace();
}

// ── Marketplace: Currency Conversion ──
let conversionCache = {};
function convertCurrency() {
    const target = document.getElementById('currencySelect').value;
    const cards = document.querySelectorAll('.offer-card');

    if (!target) {
        cards.forEach(card => {
            const orig = card.querySelector('.original-budget');
            const conv = card.querySelector('.converted-budget');
            if (orig) orig.style.display = '';
            if (conv) conv.style.display = 'none';
        });
        return;
    }

    cards.forEach(card => {
        const amount = parseFloat(card.dataset.amount);
        const from = card.dataset.currency || 'TND';
        const orig = card.querySelector('.original-budget');
        const conv = card.querySelector('.converted-budget');
        if (!amount || !orig || !conv) return;

        if (from === target) {
            orig.style.display = '';
            conv.style.display = 'none';
            return;
        }

        const cacheKey = from + '_' + target;
        if (conversionCache[cacheKey]) {
            showConverted(conv, orig, amount, conversionCache[cacheKey], target);
        } else {
            conv.textContent = 'Converting...';
            conv.style.display = '';
            fetch('{{ path("app_currency_convert") }}', {
                method: 'POST',
                headers: {'Content-Type':'application/json','X-Requested-With':'XMLHttpRequest'},
                body: JSON.stringify({amount: 1, from: from, to: target})
            })
            .then(r => r.json())
            .then(data => {
                if (data.result) {
                    conversionCache[cacheKey] = data.result;
                    showConverted(conv, orig, amount, data.result, target);
                } else {
                    conv.textContent = 'Rate unavailable';
                }
            })
            .catch(() => { conv.textContent = 'Error'; });
        }
    });
}

function showConverted(convEl, origEl, amount, rate, target) {
    const converted = (amount * rate).toFixed(2);
    convEl.textContent = '≈ ' + numberFormat(converted) + ' ' + target;
    convEl.style.display = '';
    origEl.style.display = '';
}

function numberFormat(n) {
    return parseFloat(n).toLocaleString(undefined, {minimumFractionDigits:2, maximumFractionDigits:2});
}

// ── Applications: Status Filter ──
function filterApps(btn) {
    document.querySelectorAll('#appPillFilters .pill-filter').forEach(p => p.classList.remove('active'));
    btn.classList.add('active');
    const status = btn.dataset.status;
    document.querySelectorAll('.app-row').forEach(row => {
        row.style.display = (!status || row.dataset.appStatus === status) ? '' : 'none';
    });
}

// ── Contracts: Status Filter ──
function filterContracts(btn) {
    document.querySelectorAll('#contractPillFilters .pill-filter').forEach(p => p.classList.remove('active'));
    btn.classList.add('active');
    const status = btn.dataset.cstatus;
    document.querySelectorAll('[data-contract-status]').forEach(row => {
        row.style.display = (!status || row.dataset.contractStatus === status) ? '' : 'none';
    });
}

// ── AI Assistant Actions ──
function aiAction(action) {
    const panels = ['aiConvertPanel','aiVerifyPanel','aiJobsPanel','aiTipsPanel'];
    panels.forEach(id => { const el = document.getElementById(id); if(el) el.style.display = 'none'; });

    const map = {convert:'aiConvertPanel', verify:'aiVerifyPanel', jobs:'aiJobsPanel', tips:'aiTipsPanel'};
    const panel = document.getElementById(map[action]);
    if (panel) panel.style.display = '';
}

function doConvert() {
    const amount = document.getElementById('aiConvertAmount').value;
    const from = document.getElementById('aiConvertFrom').value;
    const to = document.getElementById('aiConvertTo').value;
    const result = document.getElementById('aiConvertResult');
    result.style.display = '';
    result.textContent = 'Converting...';

    fetch('{{ path("app_currency_convert") }}', {
        method:'POST',
        headers:{'Content-Type':'application/json','X-Requested-With':'XMLHttpRequest'},
        body:JSON.stringify({amount:parseFloat(amount),from:from,to:to})
    })
    .then(r => r.json())
    .then(data => {
        if (data.result !== undefined) {
            result.innerHTML = '<strong>' + numberFormat(amount) + ' ' + from + '</strong> = <strong style="color:var(--accent-teal)">' + numberFormat(data.result) + ' ' + to + '</strong><br><span style="font-size:.75rem;color:var(--text-muted)">Rate: 1 ' + from + ' = ' + data.rate + ' ' + to + '</span>';
        } else {
            result.textContent = data.error || 'Conversion failed';
        }
    })
    .catch(() => { result.textContent = 'Error connecting to service'; });
}

{% if is_granted('ROLE_GIG_WORKER') %}
function doVerify() {
    const email = document.getElementById('aiVerifyEmail').value;
    const result = document.getElementById('aiVerifyResult');
    if (!email) { result.style.display=''; result.textContent='Please enter an email'; return; }
    result.style.display = '';
    result.textContent = 'Verifying...';

    fetch('{{ path("app_verify_email_hunter") }}', {
        method:'POST',
        headers:{'Content-Type':'application/json','X-Requested-With':'XMLHttpRequest'},
        body:JSON.stringify({email:email})
    })
    .then(r => r.json())
    .then(data => {
        if (data.result) {
            const r = data.result;
            const statusColors = {valid:'#10b981', invalid:'#ef4444', accept_all:'#f59e0b', unknown:'#9ca3af'};
            result.innerHTML = '<span style="color:'+(statusColors[r.result]||'#9ca3af')+'">● ' + (r.result||'unknown').toUpperCase() + '</span> — Score: ' + (r.score||'N/A') + '%' +
                (r.disposable ? '<br><span style="color:#ef4444">⚠ Disposable email</span>' : '') +
                (r.free ? '<br><span style="color:var(--text-muted)">Free email provider</span>' : '');
        } else {
            result.textContent = data.error || 'Verification failed';
        }
    })
    .catch(() => { result.textContent = 'Error connecting to service'; });
}

function doJobSearch() {
    const query = document.getElementById('aiJobQuery').value;
    const results = document.getElementById('aiJobResults');
    if (!query || query.length < 2) { results.style.display=''; results.innerHTML='<p style="color:var(--text-muted)">Enter at least 2 characters</p>'; return; }
    results.style.display = '';
    results.innerHTML = '<p style="color:var(--text-muted)">Searching across job boards...</p>';

    fetch('{{ path("app_external_jobs_search") }}', {
        method:'POST',
        headers:{'Content-Type':'application/json','X-Requested-With':'XMLHttpRequest'},
        body:JSON.stringify({query:query,source:'all'})
    })
    .then(r => r.json())
    .then(data => {
        if (data.results && data.results.length > 0) {
            let html = '<p style="color:var(--text-muted);font-size:.8rem;margin-bottom:.5rem">' + data.count + ' jobs found</p>';
            data.results.slice(0,8).forEach(job => {
                html += '<div style="padding:.75rem;background:var(--bg-tertiary);border-radius:var(--radius-md);margin-bottom:.375rem">' +
                    '<a href="'+job.url+'" target="_blank" rel="noopener" style="color:var(--accent-teal);font-weight:600;font-size:.9rem">'+escapeHtml(job.title)+'</a>' +
                    '<div style="font-size:.75rem;color:var(--text-muted);margin-top:.2rem">'+escapeHtml(job.company||'')+' · '+escapeHtml(job.source||'')+'</div></div>';
            });
            if (data.count > 8) html += '<a href="{{ path("app_external_jobs") }}" class="btn btn-ghost btn-sm" style="margin-top:.5rem">View all on External Jobs page →</a>';
            results.innerHTML = html;
        } else {
            results.innerHTML = '<p style="color:var(--text-muted)">No jobs found for "' + escapeHtml(query) + '"</p>';
        }
    })
    .catch(() => { results.innerHTML = '<p style="color:#ef4444">Error searching jobs</p>'; });
}
{% endif %}

// ── External Jobs in Marketplace ──
let extJobsLoaded = false;
function loadExternalJobs() {
    const query = document.getElementById('extJobQuery').value.trim();
    const source = document.getElementById('extJobSource').value;
    const grid = document.getElementById('extJobsGrid');
    const counter = document.getElementById('extJobCount');

    if (!query || query.length < 2) {
        grid.innerHTML = '<div class="empty-state" style="grid-column:1/-1"><p>Enter at least 2 characters to search external jobs.</p></div>';
        return;
    }

    grid.innerHTML = '<div class="ext-loading" style="grid-column:1/-1"><span class="spinner"></span> Searching across job boards...</div>';

    fetch('{{ path("app_external_jobs_search") }}', {
        method:'POST',
        headers:{'Content-Type':'application/json','X-Requested-With':'XMLHttpRequest'},
        body:JSON.stringify({query: query, source: source})
    })
    .then(r => {
        if (r.status === 403) throw new Error('forbidden');
        return r.json();
    })
    .then(data => {
        extJobsLoaded = true;
        if (data.results && data.results.length > 0) {
            counter.textContent = data.count;
            let html = '';
            data.results.forEach(job => {
                const sourceClass = (job.source||'').toLowerCase().replace(/[^a-z]/g,'');
                const tags = (job.tags || []).slice(0,4);
                html += '<div class="offer-card" style="position:relative">';
                html += '<span class="ext-source-badge ext-source-badge--' + sourceClass + '">' + escapeHtml(job.source || 'External') + '</span>';
                html += '<div class="offer-card-header"><div>';
                html += '<a href="' + escapeHtml(job.url) + '" target="_blank" rel="noopener" class="offer-card-title">' + escapeHtml(job.title) + '</a>';
                if (job.type) html += '<span class="badge badge--blue" style="font-size:.7rem">' + escapeHtml(job.type) + '</span>';
                html += '</div></div>';
                html += '<div class="offer-card-meta">';
                if (job.company) html += '<span><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 20a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V8l-7 5V8l-7 5V4a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2Z"/></svg> ' + escapeHtml(job.company) + '</span>';
                if (job.location) html += '<span><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg> ' + escapeHtml(job.location) + '</span>';
                if (job.date) html += '<span><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg> ' + escapeHtml(job.date.substring(0,10)) + '</span>';
                html += '</div>';
                if (tags.length > 0) {
                    html += '<div class="offer-card-skills">';
                    tags.forEach(t => { html += '<span class="skill-tag">' + escapeHtml(t) + '</span>'; });
                    html += '</div>';
                }
                if (job.description) {
                    const desc = job.description.length > 150 ? job.description.substring(0,150) + '…' : job.description;
                    html += '<p style="font-size:.8rem;color:var(--text-muted);margin:0 0 .75rem;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden">' + escapeHtml(desc) + '</p>';
                }
                html += '<div class="offer-card-footer"><div>';
                if (job.salary) html += '<div class="offer-budget">' + escapeHtml(job.salary) + '</div>';
                else html += '<span style="color:var(--text-muted);font-size:.85rem">See listing</span>';
                html += '</div>';
                html += '<a href="' + escapeHtml(job.url) + '" target="_blank" rel="noopener" class="btn btn-primary btn-sm">Apply ↗</a>';
                html += '</div></div>';
            });
            grid.innerHTML = html;
        } else {
            counter.textContent = '0';
            grid.innerHTML = '<div class="empty-state" style="grid-column:1/-1"><svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg><p>No external jobs found for "' + escapeHtml(query) + '"</p></div>';
        }
    })
    .catch(err => {
        if (err.message === 'forbidden') {
            grid.innerHTML = '<div class="empty-state" style="grid-column:1/-1"><p>External job search is not available for your role.</p></div>';
        } else {
            grid.innerHTML = '<div class="empty-state" style="grid-column:1/-1"><p style="color:#ef4444">Error loading external jobs. Try again later.</p></div>';
        }
    });
}

// Auto-load external jobs on page load
document.addEventListener('DOMContentLoaded', function() {
    setTimeout(function() { loadExternalJobs(); }, 500);
});

function escapeHtml(s) {
    const d = document.createElement('div');
    d.textContent = s;
    return d.innerHTML;
}

// ── Auto-open tab from URL hash ──
document.addEventListener('DOMContentLoaded', function() {
    const hash = window.location.hash.replace('#','');
    if (hash && document.getElementById('panel-'+hash)) {
        switchHubTab(hash);
    }
});
</script>
{% endblock %}
