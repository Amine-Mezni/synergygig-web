{% extends 'layouts/admin.html.twig' %}

{% block page_title %}Offers & Contracts{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        /* ── Hub Layout ── */
        .hub-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:var(--space-lg); flex-wrap:wrap; gap:var(--space-sm) }
        .hub-header h1 { font-size:1.5rem; font-weight:700; color:var(--text-primary); margin:0; display:flex; align-items:center; gap:.5rem }
        .hub-role-badge { font-size:.75rem; padding:.25rem .75rem; border-radius:var(--radius-full,999px); background:rgba(44,102,110,.2); color:var(--accent-teal,#2C666E); border:1px solid rgba(44,102,110,.3); font-weight:600 }

        /* ── Tab Bar ── */
        .hub-tabs { display:flex; gap:.25rem; padding:.25rem; background:var(--bg-tertiary,#161519); border-radius:var(--radius-lg,12px); margin-bottom:var(--space-lg); position:relative; overflow-x:auto }
        .hub-tab { padding:.625rem 1.25rem; border-radius:var(--radius-md,8px); border:none; background:transparent; color:var(--text-muted); font-weight:600; font-size:.875rem; cursor:pointer; transition:all .25s ease; white-space:nowrap; display:flex; align-items:center; gap:.5rem; position:relative; z-index:1 }
        .hub-tab:hover { color:var(--text-primary); background:rgba(255,255,255,.04) }
        .hub-tab.active { color:#fff; background:var(--accent-teal,#2C666E); box-shadow:0 2px 12px rgba(44,102,110,.4) }
        .hub-tab .tab-count { font-size:.7rem; padding:.1rem .45rem; border-radius:var(--radius-full,999px); background:rgba(255,255,255,.12); min-width:1.25rem; text-align:center }
        .hub-tab.active .tab-count { background:rgba(255,255,255,.25) }

        /* ── Tab Panels ── */
        .hub-panel { display:none; animation:fadeIn .3s ease }
        .hub-panel.active { display:block }
        @keyframes fadeIn { from { opacity:0; transform:translateY(6px) } to { opacity:1; transform:translateY(0) } }

        /* ── Pill Filters ── */
        .pill-filters { display:flex; gap:.375rem; flex-wrap:wrap; margin-bottom:var(--space-md) }
        .pill-filter { padding:.375rem .875rem; border-radius:var(--radius-full,999px); border:1px solid var(--glass-border,rgba(255,255,255,.08)); background:transparent; color:var(--text-muted); font-size:.8rem; font-weight:500; cursor:pointer; transition:all .2s }
        .pill-filter:hover { border-color:var(--accent-teal,#2C666E); color:var(--text-primary) }
        .pill-filter.active { background:var(--accent-teal,#2C666E); border-color:var(--accent-teal,#2C666E); color:#fff }

        /* ── Search + Currency Bar ── */
        .hub-toolbar { display:flex; align-items:center; gap:var(--space-md); margin-bottom:var(--space-md); flex-wrap:wrap }
        .hub-search-wrap { position:relative; flex:1; min-width:200px }
        .hub-search-wrap svg { position:absolute; left:.75rem; top:50%; transform:translateY(-50%); pointer-events:none }
        .hub-search-wrap input { width:100%; padding:.5rem .75rem .5rem 2.25rem; background:var(--bg-tertiary,#161519); border:1px solid var(--glass-border); border-radius:var(--radius-md,8px); color:var(--text-primary); font-size:.875rem }
        .hub-search-wrap input:focus { outline:none; border-color:var(--accent-teal,#2C666E) }
        .currency-select { padding:.5rem .75rem; background:var(--bg-tertiary,#161519); border:1px solid var(--glass-border); border-radius:var(--radius-md,8px); color:var(--text-primary); font-size:.8rem; cursor:pointer }
        .currency-select:focus { outline:none; border-color:var(--accent-teal,#2C666E) }

        /* ── Offer Cards Grid ── */
        .offers-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(320px,1fr)); gap:var(--space-md) }
        .offer-card { background:var(--bg-secondary,#0F0E11); border:1px solid var(--glass-border,rgba(255,255,255,.06)); border-radius:var(--radius-lg,12px); padding:1.25rem; transition:all .25s; position:relative }
        .offer-card:hover { border-color:var(--accent-teal,#2C666E); transform:translateY(-2px); box-shadow:0 8px 24px rgba(0,0,0,.3) }
        .offer-card-header { display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:.75rem }
        .offer-card-title { font-size:1rem; font-weight:700; color:var(--text-primary); text-decoration:none; display:block; margin-bottom:.25rem }
        .offer-card-title:hover { color:var(--accent-teal,#2C666E) }
        .offer-card-meta { display:flex; flex-wrap:wrap; gap:.375rem; margin-bottom:.75rem }
        .offer-card-meta span { font-size:.75rem; color:var(--text-muted); display:flex; align-items:center; gap:.25rem }
        .offer-card-skills { display:flex; flex-wrap:wrap; gap:.25rem; margin-bottom:.75rem }
        .skill-tag { font-size:.7rem; padding:.15rem .5rem; border-radius:var(--radius-full,999px); background:rgba(144,221,240,.08); color:var(--accent-cyan,#90DDF0); border:1px solid rgba(144,221,240,.15) }
        .offer-card-footer { display:flex; justify-content:space-between; align-items:center; padding-top:.75rem; border-top:1px solid var(--glass-border) }
        .offer-budget { font-size:1.1rem; font-weight:700; color:var(--accent-teal,#2C666E) }
        .offer-budget-converted { font-size:.75rem; color:var(--text-muted); margin-top:.125rem }

        /* ── Status Badges ── */
        .status-pill { display:inline-flex; align-items:center; padding:.2rem .6rem; border-radius:var(--radius-full,999px); font-size:.7rem; font-weight:600; gap:.25rem }
        .status-pill::before { content:''; width:6px; height:6px; border-radius:50% }
        .status-pill--draft { background:rgba(245,158,11,.1); color:#f59e0b } .status-pill--draft::before { background:#f59e0b }
        .status-pill--open { background:rgba(16,185,129,.1); color:#10b981 } .status-pill--open::before { background:#10b981 }
        .status-pill--closed { background:rgba(107,114,128,.15); color:#9ca3af } .status-pill--closed::before { background:#9ca3af }
        .status-pill--cancelled { background:rgba(239,68,68,.1); color:#ef4444 } .status-pill--cancelled::before { background:#ef4444 }
        .status-pill--pending { background:rgba(245,158,11,.1); color:#f59e0b } .status-pill--pending::before { background:#f59e0b }
        .status-pill--accepted { background:rgba(16,185,129,.1); color:#10b981 } .status-pill--accepted::before { background:#10b981 }
        .status-pill--rejected { background:rgba(239,68,68,.1); color:#ef4444 } .status-pill--rejected::before { background:#ef4444 }
        .status-pill--active { background:rgba(16,185,129,.1); color:#10b981 } .status-pill--active::before { background:#10b981 }
        .status-pill--counter_proposed { background:rgba(167,139,250,.1); color:#a78bfa } .status-pill--counter_proposed::before { background:#a78bfa }

        /* ── Applied Badge ── */
        .applied-badge { position:absolute; top:.75rem; right:.75rem; font-size:.65rem; padding:.2rem .5rem; border-radius:var(--radius-full,999px); background:rgba(167,139,250,.15); color:#a78bfa; font-weight:600; border:1px solid rgba(167,139,250,.25) }

        /* ── My Offers List ── */
        .my-offer-row { display:flex; align-items:center; justify-content:space-between; padding:1rem 1.25rem; background:var(--bg-secondary,#0F0E11); border:1px solid var(--glass-border); border-radius:var(--radius-lg,12px); margin-bottom:.5rem; transition:border-color .2s }
        .my-offer-row:hover { border-color:var(--accent-teal,#2C666E) }
        .my-offer-info { flex:1 }
        .my-offer-title { font-weight:700; color:var(--text-primary); font-size:.95rem }
        .my-offer-sub { font-size:.8rem; color:var(--text-muted); margin-top:.15rem }
        .my-offer-actions { display:flex; gap:.375rem }

        /* ── Application Rows ── */
        .app-row { display:flex; align-items:center; padding:1rem 1.25rem; background:var(--bg-secondary,#0F0E11); border:1px solid var(--glass-border); border-radius:var(--radius-lg,12px); margin-bottom:.5rem; gap:1rem; transition:border-color .2s }
        .app-row:hover { border-color:var(--accent-teal,#2C666E) }
        .app-info { flex:1 }
        .app-title { font-weight:700; color:var(--text-primary); font-size:.9rem }
        .app-sub { font-size:.8rem; color:var(--text-muted); margin-top:.15rem }

        /* ── Contract Table ── */
        .contract-table { width:100%; border-collapse:separate; border-spacing:0 .375rem }
        .contract-table thead th { padding:.5rem 1rem; font-size:.75rem; text-transform:uppercase; letter-spacing:.05em; color:var(--text-muted); font-weight:600; text-align:left }
        .contract-table tbody tr { background:var(--bg-secondary,#0F0E11); transition:all .2s }
        .contract-table tbody tr:hover { background:var(--bg-tertiary,#161519) }
        .contract-table tbody td { padding:.75rem 1rem; font-size:.875rem; color:var(--text-primary) }
        .contract-table tbody td:first-child { border-radius:var(--radius-md,8px) 0 0 var(--radius-md,8px) }
        .contract-table tbody td:last-child { border-radius:0 var(--radius-md,8px) var(--radius-md,8px) 0 }

        /* ── Stats Row ── */
        .stats-row { display:flex; gap:var(--space-md); margin-bottom:var(--space-lg); flex-wrap:wrap }
        .stat-card { flex:1; min-width:120px; padding:1rem 1.25rem; background:var(--bg-secondary,#0F0E11); border:1px solid var(--glass-border); border-radius:var(--radius-lg,12px); text-align:center }
        .stat-value { font-size:1.75rem; font-weight:800; color:var(--text-primary) }
        .stat-label { font-size:.75rem; color:var(--text-muted); text-transform:uppercase; letter-spacing:.05em; margin-top:.25rem }

        /* ── AI Panel ── */
        .ai-quick-actions { display:grid; grid-template-columns:repeat(auto-fill,minmax(160px,1fr)); gap:.5rem; margin-bottom:var(--space-lg) }
        .ai-action-btn { padding:.75rem 1rem; background:var(--bg-secondary,#0F0E11); border:1px solid var(--glass-border); border-radius:var(--radius-md,8px); color:var(--text-primary); font-size:.8rem; font-weight:600; cursor:pointer; transition:all .2s; text-align:left; display:flex; align-items:center; gap:.5rem }
        .ai-action-btn:hover { border-color:var(--accent-teal,#2C666E); background:rgba(44,102,110,.08) }
        .ai-result-box { background:var(--bg-secondary,#0F0E11); border:1px solid var(--glass-border); border-radius:var(--radius-lg,12px); padding:1.5rem; min-height:200px }

        /* ── Empty State ── */
        .empty-state { text-align:center; padding:3rem 1rem; color:var(--text-muted) }
        .empty-state svg { opacity:.4; margin-bottom:1rem }
        .empty-state p { font-size:.9rem }

        /* ── Responsive ── */
        @media(max-width:768px) {
            .offers-grid { grid-template-columns:1fr }
            .hub-tabs { gap:.125rem }
            .hub-tab { padding:.5rem .75rem; font-size:.8rem }
            .stats-row { gap:.5rem }
            .stat-card { min-width:80px; padding:.75rem }
        }

        /* ── External Job Cards ── */
        .ext-source-badge { position:absolute; top:.75rem; right:.75rem; font-size:.65rem; padding:.2rem .5rem; border-radius:var(--radius-full,999px); font-weight:600; border:1px solid rgba(255,255,255,.15) }
        .ext-source-badge--remotive { background:rgba(99,102,241,.15); color:#818cf8; border-color:rgba(99,102,241,.25) }
        .ext-source-badge--arbeitnow { background:rgba(16,185,129,.15); color:#34d399; border-color:rgba(16,185,129,.25) }
        .ext-source-badge--remoteok { background:rgba(245,158,11,.15); color:#fbbf24; border-color:rgba(245,158,11,.25) }
        .ext-source-badge--jobicy { background:rgba(236,72,153,.15); color:#f472b6; border-color:rgba(236,72,153,.25) }
        .ext-source-badge--external { background:rgba(167,139,250,.15); color:#a78bfa; border-color:rgba(167,139,250,.25) }
        .ext-section-header { display:flex; align-items:center; justify-content:space-between; margin:var(--space-xl,2rem) 0 var(--space-md); padding-bottom:.5rem; border-bottom:1px solid var(--glass-border) }
        .ext-section-header h3 { margin:0; font-size:1.05rem; font-weight:700; color:var(--text-primary); display:flex; align-items:center; gap:.5rem }
        .ext-search-bar { display:flex; gap:.5rem; align-items:center }
        .ext-search-bar input { padding:.4rem .75rem; background:var(--bg-tertiary,#161519); border:1px solid var(--glass-border); border-radius:var(--radius-md,8px); color:var(--text-primary); font-size:.8rem; width:200px }
        .ext-search-bar input:focus { outline:none; border-color:var(--accent-teal,#2C666E) }
        .ext-loading { text-align:center; padding:2rem; color:var(--text-muted); font-size:.85rem }
        .ext-loading .spinner { display:inline-block; width:20px; height:20px; border:2px solid var(--glass-border); border-top-color:var(--accent-teal); border-radius:50%; animation:spin .6s linear infinite; margin-right:.5rem; vertical-align:middle }
        @keyframes spin { to { transform:rotate(360deg) } }
    </style>
{% endblock %}

{% block content %}
{# ── Hub Header ── #}
<div class="hub-header">
    <h1>
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--accent-teal,#2C666E)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/></svg>
        Offers & Contracts
    </h1>
    <span class="hub-role-badge">
        {% if is_granted('ROLE_PROJECT_OWNER') %}Owner View
        {% elseif is_granted('ROLE_GIG_WORKER') %}Applicant View
        {% elseif is_granted('ROLE_HR') %}HR View
        {% elseif is_granted('ROLE_ADMIN') %}Admin View
        {% endif %}
    </span>
</div>

{# ── Tab Bar ── #}
<div class="hub-tabs" id="hubTabs">
    <button class="hub-tab active" data-tab="marketplace" onclick="switchHubTab('marketplace')">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        Marketplace
        <span class="tab-count">{{ offers|length }}</span>
    </button>

    {% if is_granted('ROLE_PROJECT_OWNER') or is_granted('ROLE_ADMIN') %}
    <button class="hub-tab" data-tab="myoffers" onclick="switchHubTab('myoffers')">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/><line x1="12" y1="12" x2="12" y2="16"/><line x1="10" y1="14" x2="14" y2="14"/></svg>
        My Offers
        <span class="tab-count">{{ myOfferCounts.total }}</span>
    </button>
    {% endif %}

    <button class="hub-tab" data-tab="applications" onclick="switchHubTab('applications')">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
        Applications
        <span class="tab-count">{{ appCounts.total }}</span>
    </button>

    {% if is_granted('ROLE_HR') or is_granted('ROLE_PROJECT_OWNER') or is_granted('ROLE_ADMIN') %}
    <button class="hub-tab" data-tab="contracts" onclick="switchHubTab('contracts')">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
        Contracts
        <span class="tab-count">{{ contracts|length }}</span>
    </button>
    {% endif %}

    <button class="hub-tab" data-tab="assistant" onclick="switchHubTab('assistant')">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
        AI Assistant
    </button>
</div>

{# ════════════════════════════════════════════════════════════════════════════ #}
{# ── TAB 1: MARKETPLACE ──────────────────────────────────────────────────── #}
{# ════════════════════════════════════════════════════════════════════════════ #}
<div class="hub-panel active" id="panel-marketplace">
    {# Toolbar: search + currency #}
    <div class="hub-toolbar">
        <div class="hub-search-wrap">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--text-muted)" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <input type="text" id="marketplaceSearch" placeholder="Search offers by title, skills, location..." oninput="filterMarketplace()">
        </div>
        <select class="currency-select" id="currencySelect" onchange="convertCurrency()">
            <option value="">💱 Original</option>
            {% for code, name in currencies %}
                <option value="{{ code }}">{{ code }} — {{ name }}</option>
            {% endfor %}
        </select>
    </div>

    {# Pill Filters #}
    <div class="pill-filters" id="pillFilters">
        <button class="pill-filter active" data-type="" onclick="filterByType(this)">All</button>
        <button class="pill-filter" data-type="FULL_TIME" onclick="filterByType(this)">Full-Time</button>
        <button class="pill-filter" data-type="FREELANCE" onclick="filterByType(this)">Freelance</button>
        <button class="pill-filter" data-type="INTERNSHIP" onclick="filterByType(this)">Internship</button>
        <button class="pill-filter" data-type="CONTRACT" onclick="filterByType(this)">Contract</button>
        <button class="pill-filter" data-type="PART_TIME" onclick="filterByType(this)">Part-Time</button>
        <span style="width:1px;height:20px;background:var(--glass-border);margin:0 .25rem"></span>
        <button class="pill-filter" data-type="EXTERNAL" onclick="filterByType(this)">🌐 External</button>
    </div>

    {# Offers Grid #}
    <div class="offers-grid" id="offersGrid">
        {% for o in offers %}
        <div class="offer-card" data-type="{{ o.offerType }}" data-title="{{ o.title|lower }}" data-skills="{{ o.requiredSkills|lower|default('') }}" data-location="{{ o.location|lower|default('') }}" data-amount="{{ o.amount|default(0) }}" data-currency="{{ o.currency|default('TND') }}">
            {% if appliedOfferIds is defined and o.id in appliedOfferIds %}
                <span class="applied-badge">✓ Applied</span>
            {% endif %}
            <div class="offer-card-header">
                <div>
                    <a href="{{ path('app_offer_show', {id: o.id}) }}" class="offer-card-title">{{ o.title }}</a>
                    {% set tc = {'FULL_TIME':'green','PART_TIME':'blue','FREELANCE':'purple','INTERNSHIP':'orange','CONTRACT':'blue'} %}
                    <span class="badge badge--{{ tc[o.offerType] ?? 'blue' }}" style="font-size:.7rem">{{ o.offerType ? o.offerType|replace({'_':' '}) : '—' }}</span>
                </div>
            </div>
            <div class="offer-card-meta">
                {% if o.department %}<span><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 20a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V8l-7 5V8l-7 5V4a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2Z"/></svg> {{ o.department.name }}</span>{% endif %}
                {% if o.location %}<span><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg> {{ o.location }}</span>{% endif %}
                {% if o.startDate %}<span><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg> {{ o.startDate|date('M d') }}{% if o.endDate %} — {{ o.endDate|date('M d, Y') }}{% endif %}</span>{% endif %}
            </div>
            {% if o.requiredSkills %}
            <div class="offer-card-skills">
                {% for skill in o.requiredSkills|split(',') %}
                    <span class="skill-tag">{{ skill|trim }}</span>
                {% endfor %}
            </div>
            {% endif %}
            {% if o.description %}
                <p style="font-size:.8rem;color:var(--text-muted);margin:0 0 .75rem;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden">{{ o.description|slice(0,150) }}{% if o.description|length > 150 %}…{% endif %}</p>
            {% endif %}
            <div class="offer-card-footer">
                <div>
                    {% if o.amount %}
                        <div class="offer-budget original-budget">{{ o.amount|number_format(2) }} {{ o.currency ?? 'TND' }}</div>
                        <div class="offer-budget-converted converted-budget" style="display:none"></div>
                    {% else %}
                        <span style="color:var(--text-muted);font-size:.85rem">Negotiable</span>
                    {% endif %}
                </div>
                <a href="{{ path('app_offer_show', {id: o.id}) }}" class="btn btn-primary btn-sm">View Details</a>
            </div>
        </div>
        {% else %}
        <div class="empty-state" style="grid-column:1/-1">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/></svg>
            <p>No open offers at the moment.</p>
        </div>
        {% endfor %}
    </div>

    {# ── External Jobs Section ── #}
    <div class="ext-section-header">
        <h3>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--accent-teal,#2C666E)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
            External Jobs
            <span id="extJobCount" class="tab-count" style="font-size:.7rem">0</span>
        </h3>
