{% extends 'layouts/admin.html.twig' %}

{% block title %}{{ department.name }} | SynergyGig{% endblock %}

{% block page_title %}{{ department.name }}{% endblock %}

{% block breadcrumb %}
    <nav class="breadcrumb">
        <a href="{{ path('app_dashboard') }}">Home</a>
        <span class="sep">/</span>
        <a href="{{ path('app_department_index') }}">Departments</a>
        <span class="sep">/</span>
        <span>{{ department.name }}</span>
    </nav>
{% endblock %}

{% block header_actions %}
    <a href="{{ path('app_department_edit', {id: department.id}) }}" class="btn btn-secondary">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
        Edit
    </a>
{% endblock %}

{% block content %}
    <div class="bento-grid bento-grid--stats" style="margin-bottom: var(--space-2xl);">
        <div class="card card--glow-purple">
            <div class="card-title" style="margin-bottom: var(--space-sm);">Department Name</div>
            <div class="card-value" style="font-size: 1.5rem;">{{ department.name }}</div>
        </div>
        <div class="card card--glow-blue">
            <div class="card-title" style="margin-bottom: var(--space-sm);">Manager</div>
            <div style="display: flex; align-items: center; gap: var(--space-sm); margin-top: var(--space-sm);">
                {% if department.manager %}
                    <div class="avatar">{{ department.manager.first_name|first|upper }}{{ department.manager.last_name|first|upper }}</div>
                    <div>
                        <div style="font-weight: 500;">{{ department.manager.first_name }} {{ department.manager.last_name }}</div>
                        <div class="text-muted" style="font-size: 0.8125rem;">{{ department.manager.email }}</div>
                    </div>
                {% else %}
                    <span class="text-muted">No manager assigned</span>
                {% endif %}
            </div>
        </div>
        <div class="card card--glow-green">
            <div class="card-title" style="margin-bottom: var(--space-sm);">Budget</div>
            <div class="card-value" style="font-size: 1.5rem;">
                {% if department.allocated_budget %}
                    ${{ department.allocated_budget|number_format(2, '.', ',') }}
                {% else %}
                    <span class="text-muted">—</span>
                {% endif %}
            </div>
        </div>
    </div>

    {% if department.description %}
    <div class="card" style="margin-bottom: var(--space-2xl);">
        <h3 style="margin-bottom: var(--space-md); font-size: 1rem;">Description</h3>
        <p>{{ department.description }}</p>
    </div>
    {% endif %}

    <div class="card">
        <div class="card-header">
            <h3 style="margin: 0; font-size: 1rem;">Details</h3>
        </div>
        <div class="table-wrapper">
            <table class="table">
                <tbody>
                    <tr>
                        <td class="text-muted" style="width: 200px;">ID</td>
                        <td>{{ department.id }}</td>
                    </tr>
                    <tr>
                        <td class="text-muted">Created</td>
                        <td>{{ department.created_at|date('F d, Y \\a\\t H:i') }}</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
