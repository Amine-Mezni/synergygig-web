{% extends 'layouts/admin.html.twig' %}

{% block title %}Departments | SynergyGig{% endblock %}
{% block page_title %}Departments{% endblock %}

{% block header_actions %}
    <a href="{{ path('app_department_new') }}" class="btn btn-primary">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        New Department
    </a>
{% endblock %}

{% block content %}
    {# Search bar #}
    <div class="card" style="padding:var(--space-md) var(--space-lg);margin-bottom:var(--space-lg);display:flex;align-items:center;gap:var(--space-md)">
        <form method="get" action="{{ path('app_department_index') }}" style="flex:1;display:flex;align-items:center;gap:var(--space-md)">
            <div style="position:relative;flex:1">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--text-muted)" stroke-width="2" style="position:absolute;left:.75rem;top:50%;transform:translateY(-50%)"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                <input type="text" name="q" value="{{ app.request.query.get('q') }}" placeholder="Search departments..." class="form-control" style="padding-left:2.25rem">
            </div>
            <button type="submit" class="btn btn-secondary btn-sm">Search</button>
        </form>
    </div>

    <div class="card">
        {% if departments is not empty %}
            <div class="table-wrapper">
                <table class="table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Name</th>
                            <th>Description</th>
                            <th>Manager</th>
                            <th>Budget</th>
                            <th>Created</th>
                            <th style="text-align: right;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for dept in departments %}
                        <tr>
                            <td class="text-muted">{{ dept.id }}</td>
                            <td>
                                <a href="{{ path('app_department_show', {id: dept.id}) }}" style="color: var(--text-primary); font-weight: 500;">
                                    {{ dept.name }}
                                </a>
                            </td>
                            <td class="text-muted" style="max-width: 250px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                {{ dept.description ?? '—' }}
                            </td>
                            <td>
                                {% if dept.manager %}
                                    <div style="display: flex; align-items: center; gap: var(--space-sm);">
                                        <div class="avatar avatar--sm">{{ dept.manager.first_name|first|upper }}{{ dept.manager.last_name|first|upper }}</div>
                                        {{ dept.manager.first_name }} {{ dept.manager.last_name }}
                                    </div>
                                {% else %}
                                    <span class="text-muted">—</span>
                                {% endif %}
                            </td>
                            <td>
                                {% if dept.allocated_budget %}
                                    <span class="badge badge--green">${{ dept.allocated_budget|number_format(0, '.', ',') }}</span>
                                {% else %}
                                    <span class="text-muted">—</span>
                                {% endif %}
                            </td>
                            <td class="text-muted">{{ dept.created_at|date('M d, Y') }}</td>
                            <td style="text-align: right;">
                                <details class="crud-actions-menu">
                                    <summary class="btn btn-ghost btn-sm" title="Actions"><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="5" r="2"/><circle cx="12" cy="12" r="2"/><circle cx="12" cy="19" r="2"/></svg></summary>
                                    <div class="crud-actions-dropdown">
                                        <a href="{{ path('app_department_show', {id: dept.id}) }}" class="crud-action-item"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg> View</a>
                                        <a href="{{ path('app_department_edit', {id: dept.id}) }}" class="crud-action-item"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg> Edit</a>
                                        <form method="post" action="{{ path('app_department_delete', {id: dept.id}) }}" onsubmit="return confirm('Delete this department?')">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete-' ~ dept.id) }}">
                                            <button type="submit" class="crud-action-item crud-action-danger"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg> Delete</button>
                                        </form>
                                    </div>
                                </details>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% else %}
            <div class="empty-state">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 20a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V8l-7 5V8l-7 5V4a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2Z"/></svg>
                <h3>No departments yet</h3>
                <p>Create your first department to organize your workforce.</p>
                <a href="{{ path('app_department_new') }}" class="btn btn-primary" style="margin-top: var(--space-lg);">Create Department</a>
            </div>
        {% endif %}
    </div>

    {% if pagination is defined %}{% include 'components/_pagination.html.twig' %}{% endif %}
{% endblock %}
