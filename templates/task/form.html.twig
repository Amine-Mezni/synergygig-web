{% extends 'layouts/admin.html.twig' %}

{% block page_title %}{{ task is defined and task.id ? 'Edit Task' : 'New Task' }}{% endblock %}

{% block content %}
<div class="card" style="max-width:800px">
    <div class="card__header">
        <h3>{{ task is defined and task.id ? 'Edit Task' : 'Create Task' }}</h3>
    </div>
    <div class="card__body">
        {{ form_start(form, {'attr': {'class': 'form', 'novalidate': 'novalidate'}}) }}

        <div class="form-grid" style="display:grid;grid-template-columns:1fr 1fr;gap:1rem">
            <div class="form-group" style="grid-column:1/-1">
                {{ form_label(form.title) }}
                {{ form_widget(form.title, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.title) }}
            </div>

            <div class="form-group">
                {{ form_label(form.project) }}
                {{ form_widget(form.project, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.project) }}
            </div>
            <div class="form-group">
                {{ form_label(form.assignedTo) }}
                {{ form_widget(form.assignedTo, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.assignedTo) }}
            </div>

            <div class="form-group">
                {{ form_label(form.status) }}
                {{ form_widget(form.status, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.status) }}
            </div>
            <div class="form-group">
                {{ form_label(form.priority) }}
                {{ form_widget(form.priority, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.priority) }}
            </div>

            <div class="form-group">
                {{ form_label(form.due_date) }}
                {{ form_widget(form.due_date, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.due_date) }}
            </div>

            <div class="form-group" style="grid-column:1/-1">
                {{ form_label(form.description) }}
                {{ form_widget(form.description, {'attr': {'class': 'form-control', 'rows': '4'}}) }}
                {{ form_errors(form.description) }}
            </div>
        </div>

        <div style="display:flex;gap:0.5rem;margin-top:1.5rem">
            <button type="submit" class="btn btn-primary">Save Task</button>
            <a href="{{ path('app_task_index') }}" class="btn btn-ghost">Cancel</a>
        </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
