{% extends 'layouts/admin.html.twig' %}

{% block page_title %}Interviews{% endblock %}

{% block header_actions %}
    {% if is_granted('ROLE_HR') %}
    <a href="{{ path('app_interview_new') }}" class="btn btn-primary btn-sm">+ Schedule Interview</a>
    {% endif %}
{% endblock %}

{% block content %}
{# Search, filter, and view toggle #}
<div class="card" style="padding:var(--space-md) var(--space-lg);margin-bottom:var(--space-lg);display:flex;align-items:center;gap:var(--space-md);flex-wrap:wrap">
    <form method="get" action="{{ path('app_interview_index') }}" style="flex:1;display:flex;align-items:center;gap:var(--space-md);flex-wrap:wrap">
        <div style="position:relative;flex:1;min-width:230px">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--text-muted)" stroke-width="2" style="position:absolute;left:.75rem;top:50%;transform:translateY(-50%)"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <input type="text" name="q" value="{{ app.request.query.get('q') }}" placeholder="Search by candidate or position..." class="form-control" style="padding-left:2.25rem">
        </div>
        <select name="status" class="form-control form-select" style="width:auto;min-width:140px">
            <option value="">All Status</option>
            <option value="PENDING" {{ app.request.query.get('status') == 'PENDING' ? 'selected' }}>Pending</option>
            <option value="ACCEPTED" {{ app.request.query.get('status') == 'ACCEPTED' ? 'selected' }}>Accepted</option>
            <option value="REJECTED" {{ app.request.query.get('status') == 'REJECTED' ? 'selected' }}>Declined</option>
            <option value="COMPLETED" {{ app.request.query.get('status') == 'COMPLETED' ? 'selected' }}>Completed</option>
            <option value="CANCELLED" {{ app.request.query.get('status') == 'CANCELLED' ? 'selected' }}>Cancelled</option>
        </select>
        <button type="submit" class="btn btn-secondary btn-sm">Filter</button>
        {% if app.request.query.get('q') or app.request.query.get('status') %}
        <a href="{{ path('app_interview_index') }}" class="btn btn-ghost btn-sm" style="color:var(--color-danger)">✕ Clear</a>
        {% endif %}
    </form>

    <div style="display:flex;align-items:center;gap:6px;flex-shrink:0">
        <span class="text-muted" style="font-size:.8rem;white-space:nowrap">View as:</span>
        <button type="button" id="btn-interview-view-list" onclick="setInterviewView('list')" title="List view"
            style="padding:5px 8px;border-radius:6px;border:1px solid var(--border-color);background:var(--bg-card);cursor:pointer;display:flex;align-items:center;color:var(--text-primary)">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
        </button>
        <button type="button" id="btn-interview-view-grid" onclick="setInterviewView('grid')" title="Grid view"
            style="padding:5px 8px;border-radius:6px;border:1px solid var(--border-color);background:var(--bg-card);cursor:pointer;display:flex;align-items:center;color:var(--text-primary)">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
        </button>
    </div>
</div>

{% if interviews|length > 0 %}

{# List view #}
<div id="interview-list-view" class="card">
    <div class="table-wrap" style="overflow:visible">
        <table class="table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Organizer</th>
                    <th>Candidate</th>
                    <th>Date &amp; Time</th>
                    <th>Offer</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for i in interviews %}
                {% set sc = {'PENDING': 'orange', 'ACCEPTED': 'green', 'REJECTED': 'red', 'COMPLETED': 'green', 'CANCELLED': 'red'} %}
                <tr>
                    <td class="text-muted">{{ i.id }}</td>
                    <td>
                        {% if i.organizer %}
                            <div style="display:flex;align-items:center;gap:0.5rem">
                                <div class="avatar avatar--sm">{{ i.organizer.firstName|first }}{{ i.organizer.lastName|first }}</div>
                                {{ i.organizer.firstName }} {{ i.organizer.lastName }}
                            </div>
                        {% else %}—{% endif %}
                    </td>
                    <td>
                        {% if i.candidate %}
                            <div style="display:flex;align-items:center;gap:0.5rem">
                                <div class="avatar avatar--sm">{{ i.candidate.firstName|first }}{{ i.candidate.lastName|first }}</div>
                                {{ i.candidate.firstName }} {{ i.candidate.lastName }}
                            </div>
                        {% else %}—{% endif %}
                    </td>
                    <td>{{ i.dateTime ? i.dateTime|date('M d, Y H:i') : '—' }}</td>
                    <td>{% if i.offer %}<span style="color:var(--accent-blue)">{{ i.offer.title }}</span>{% else %}—{% endif %}</td>
                    <td>
                        {% if i.status == 'PENDING' and is_granted('ROLE_HR') %}
                        <button type="button" class="badge badge--orange interview-status-btn" style="border:none;cursor:pointer;font:inherit;letter-spacing:inherit"
                            data-accept-url="{{ path('app_interview_accept', {id: i.id}) }}"
                            data-accept-token="{{ csrf_token('accept' ~ i.id) }}"
                            data-decline-url="{{ path('app_interview_decline', {id: i.id}) }}"
                            data-decline-token="{{ csrf_token('decline' ~ i.id) }}"
                            onclick="showInterviewPopup(this)" title="Click to accept or decline">
                            ⏳ PENDING
                        </button>
                        {% else %}
                        <span class="badge badge--{{ sc[i.status] ?? 'blue' }}">{{ i.status == 'REJECTED' ? 'DECLINED' : (i.status ?? 'N/A') }}</span>
                        {% endif %}
                    </td>
                    <td>
                        <details class="crud-actions-menu">
                            <summary class="btn btn-ghost btn-sm" title="Actions"><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="5" r="2"/><circle cx="12" cy="12" r="2"/><circle cx="12" cy="19" r="2"/></svg></summary>
                            <div class="crud-actions-dropdown">
                                <a href="{{ path('app_interview_show', {id: i.id}) }}" class="crud-action-item"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg> View</a>
                                {% if is_granted('ROLE_HR') %}
                                <a href="{{ path('app_interview_edit', {id: i.id}) }}" class="crud-action-item"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg> Edit</a>
                                <form method="post" action="{{ path('app_interview_delete', {id: i.id}) }}" onsubmit="event.preventDefault();showConfirm(this,{type:'danger',title:'Delete Interview',message:'Are you sure you want to delete this interview?',okText:'Delete'});return false">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ i.id) }}">
                                    <button type="submit" class="crud-action-item crud-action-danger"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg> Delete</button>
                                </form>
                                {% endif %}
                            </div>
                        </details>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

{# Grid view #}
<div id="interview-grid-view" style="display:none;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:var(--space-lg)">
    {% for i in interviews %}
    {% set sc = {'PENDING': 'orange', 'ACCEPTED': 'green', 'REJECTED': 'red', 'COMPLETED': 'green', 'CANCELLED': 'red'} %}
    <div class="card" style="padding:0;overflow:visible;position:relative">
        <details class="crud-actions-menu" style="position:absolute;top:var(--space-sm);right:var(--space-sm)">
            <summary class="btn btn-ghost btn-sm" style="padding:4px" title="Actions">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="5" r="2"/><circle cx="12" cy="12" r="2"/><circle cx="12" cy="19" r="2"/></svg>
            </summary>
            <div class="crud-actions-dropdown" style="right:0;left:auto">
                <a href="{{ path('app_interview_show', {id: i.id}) }}" class="crud-action-item"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg> View</a>
                {% if is_granted('ROLE_HR') %}
                <a href="{{ path('app_interview_edit', {id: i.id}) }}" class="crud-action-item"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg> Edit</a>
                <form method="post" action="{{ path('app_interview_delete', {id: i.id}) }}" onsubmit="event.preventDefault();showConfirm(this,{type:'danger',title:'Delete Interview',message:'Are you sure you want to delete this interview?',okText:'Delete'});return false">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ i.id) }}">
                    <button type="submit" class="crud-action-item crud-action-danger"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg> Delete</button>
                </form>
                {% endif %}
            </div>
        </details>

        <div style="padding:var(--space-lg)">
            <div style="display:flex;align-items:center;gap:.75rem;margin-bottom:var(--space-md);padding-right:2rem">
                {% if i.candidate %}
                <div class="avatar avatar--lg" style="width:46px;height:46px;font-size:1.1rem;flex-shrink:0">{{ i.candidate.firstName|first }}{{ i.candidate.lastName|first }}</div>
                <div>
                    <div style="font-weight:600;color:var(--text-primary)">{{ i.candidate.firstName }} {{ i.candidate.lastName }}</div>
                    <div class="text-muted" style="font-size:.75rem">Candidate</div>
                </div>
                {% else %}
                <div class="avatar avatar--lg" style="width:46px;height:46px;font-size:1.1rem">?</div>
                <span class="text-muted">Unknown Candidate</span>
                {% endif %}
            </div>

            <div style="display:flex;align-items:center;gap:.5rem;flex-wrap:wrap;margin-bottom:var(--space-sm)">
                {% if i.offer %}<span class="badge badge--purple">{{ i.offer.title }}</span>{% endif %}
                {% if i.status == 'PENDING' and is_granted('ROLE_HR') %}
                <button type="button" class="badge badge--orange interview-status-btn" style="border:none;cursor:pointer;font:inherit;letter-spacing:inherit"
                    data-accept-url="{{ path('app_interview_accept', {id: i.id}) }}"
                    data-accept-token="{{ csrf_token('accept' ~ i.id) }}"
                    data-decline-url="{{ path('app_interview_decline', {id: i.id}) }}"
                    data-decline-token="{{ csrf_token('decline' ~ i.id) }}"
                    onclick="showInterviewPopup(this)" title="Click to accept or decline">
                    ⏳ PENDING
                </button>
                {% else %}
                <span class="badge badge--{{ sc[i.status] ?? 'blue' }}">{{ i.status == 'REJECTED' ? 'DECLINED' : (i.status ?? 'N/A') }}</span>
                {% endif %}
            </div>

            <div class="text-muted" style="font-size:.8125rem;display:flex;align-items:center;gap:.4rem;margin-bottom:4px">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                {{ i.dateTime ? i.dateTime|date('M d, Y H:i') : '—' }}
            </div>

            <div class="text-muted" style="font-size:.75rem">Organizer: {% if i.organizer %}{{ i.organizer.firstName }} {{ i.organizer.lastName }}{% else %}—{% endif %}</div>
            <div class="text-muted" style="font-size:.75rem"># {{ i.id }}</div>
        </div>
    </div>
    {% endfor %}
</div>

{% else %}
<div class="card">
    <div style="text-align:center;padding:3rem">
        <p class="text-muted">No interviews scheduled.</p>
        {% if is_granted('ROLE_HR') %}
        <a href="{{ path('app_interview_new') }}" class="btn btn-primary" style="margin-top:1rem">+ Schedule Interview</a>
        {% endif %}
    </div>
</div>
{% endif %}

{# Status popup #}
<div id="interview-popup-portal" style="display:none;position:fixed;z-index:9999;background:#1a191d;border:1px solid #333;border-radius:10px;padding:6px;min-width:180px;box-shadow:0 12px 32px rgba(0,0,0,.5)">
    <div id="interview-popup-arrow" style="position:absolute;top:-5px;left:50%;transform:translateX(-50%);width:10px;height:10px;background:#1a191d;border-left:1px solid #333;border-top:1px solid #333;rotate:45deg"></div>
    <form id="interview-popup-accept-form" method="post" style="margin:0">
        <input type="hidden" id="interview-popup-accept-token" name="_token">
        <button type="submit" style="width:100%;background:none;border:none;padding:9px 14px;text-align:left;color:#4ade80;font-size:.85rem;font-weight:600;cursor:pointer;border-radius:6px;display:flex;align-items:center;gap:8px;white-space:nowrap"
            onmouseover="this.style.background='rgba(74,222,128,.12)'" onmouseout="this.style.background='none'">
            ✓ Accept
        </button>
    </form>
    <div style="height:1px;background:#333;margin:2px 6px"></div>
    <form id="interview-popup-decline-form" method="post" style="margin:0">
        <input type="hidden" id="interview-popup-decline-token" name="_token">
        <button type="submit" style="width:100%;background:none;border:none;padding:9px 14px;text-align:left;color:#f87171;font-size:.85rem;font-weight:600;cursor:pointer;border-radius:6px;display:flex;align-items:center;gap:8px;white-space:nowrap"
            onmouseover="this.style.background='rgba(248,113,113,.12)'" onmouseout="this.style.background='none'">
            ✕ Decline
        </button>
    </form>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
function setInterviewView(v) {
    const lv = document.getElementById('interview-list-view');
    const gv = document.getElementById('interview-grid-view');
    const bl = document.getElementById('btn-interview-view-list');
    const bg = document.getElementById('btn-interview-view-grid');

    if (!lv || !gv || !bl || !bg) {
        return;
    }

    if (v === 'grid') {
        lv.style.display = 'none';
        gv.style.display = 'grid';
        bl.style.background = 'var(--bg-card)';
        bg.style.background = 'var(--color-primary,#7c3aed)';
        bg.style.color = '#fff';
        bg.style.borderColor = 'transparent';
        bl.style.color = 'var(--text-primary)';
        bl.style.borderColor = 'var(--border-color)';
    } else {
        lv.style.display = '';
        gv.style.display = 'none';
        bg.style.background = 'var(--bg-card)';
        bl.style.background = 'var(--color-primary,#7c3aed)';
        bl.style.color = '#fff';
        bl.style.borderColor = 'transparent';
        bg.style.color = 'var(--text-primary)';
        bg.style.borderColor = 'var(--border-color)';
    }
    try { localStorage.setItem('interviewView', v); } catch (e) {}
}

let _activeInterviewBtn = null;
function showInterviewPopup(btn) {
    const portal = document.getElementById('interview-popup-portal');
    if (!portal) {
        return;
    }

    if (_activeInterviewBtn === btn && portal.style.display !== 'none') {
        portal.style.display = 'none';
        _activeInterviewBtn = null;
        return;
    }
    _activeInterviewBtn = btn;

    document.getElementById('interview-popup-accept-form').action = btn.dataset.acceptUrl;
    document.getElementById('interview-popup-accept-token').value = btn.dataset.acceptToken;
    document.getElementById('interview-popup-decline-form').action = btn.dataset.declineUrl;
    document.getElementById('interview-popup-decline-token').value = btn.dataset.declineToken;

    portal.style.display = 'block';
    const rect = btn.getBoundingClientRect();
    const pw = portal.offsetWidth || 180;
    let left = rect.left + rect.width / 2 - pw / 2;
    left = Math.max(8, Math.min(left, window.innerWidth - pw - 8));
    portal.style.top = (rect.bottom + window.scrollY + 8) + 'px';
    portal.style.left = left + 'px';

    const arrowLeft = (rect.left + rect.width / 2) - left;
    document.getElementById('interview-popup-arrow').style.left = arrowLeft + 'px';
}

document.addEventListener('click', function(e) {
    const portal = document.getElementById('interview-popup-portal');
    if (!portal) {
        return;
    }

    if (!e.target.closest('.interview-status-btn') && !e.target.closest('#interview-popup-portal')) {
        portal.style.display = 'none';
        _activeInterviewBtn = null;
    }
});

try {
    const saved = localStorage.getItem('interviewView');
    if (saved) {
        setInterviewView(saved);
    } else {
        setInterviewView('list');
    }
} catch (e) {
    setInterviewView('list');
}
</script>
{% endblock %}