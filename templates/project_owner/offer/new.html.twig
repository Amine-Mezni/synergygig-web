{% extends 'admin/base_admin.html.twig' %}

{% block title %}Créer une offre{% endblock %}

{% block admin_content %}
<div class="container-fluid pt-4 px-4">
    <div class="offer-form-wrapper">
        <div class="offer-form-header text-center">
            <span class="offer-form-badge">SynergyGig</span>
            <h1>Créer une offre</h1>
            <p>Publiez votre offre avec une présentation moderne et un contrôle de saisie côté serveur.</p>
        </div>

        <div class="offer-form-card">
            {% for message in app.flashes('success') %}
                <div class="custom-success-popup">
                    <i class="bi bi-check-circle-fill me-2"></i>
                    {{ message }}
                </div>
            {% endfor %}

            {% for message in app.flashes('error') %}
                <div class="custom-error-popup">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    {{ message }}
                </div>
            {% endfor %}

            {{ form_start(form, {'attr': {'novalidate': 'novalidate', 'enctype': 'multipart/form-data'}}) }}

            <div class="row g-4">
                <div class="col-md-6">
                    <div class="offer-field">
                        {{ form_label(form.title, 'Titre') }}
                        {{ form_widget(form.title, {
                            'attr': {
                                'class': 'form-control offer-input',
                                'placeholder': 'Ex: Création logo gaming'
                            }
                        }) }}
                        <div class="text-danger small mt-2">
                            {{ form_errors(form.title) }}
                        </div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="offer-field">
                        {{ form_label(form.type, 'Type') }}
                        {{ form_widget(form.type, {
                            'attr': {
                                'class': 'form-select offer-input'
                            }
                        }) }}
                        <div class="text-danger small mt-2">
                            {{ form_errors(form.type) }}
                        </div>
                    </div>
                </div>

                <div class="col-12">
                    <div class="offer-field">
                        {{ form_label(form.description, 'Description') }}
                        {{ form_widget(form.description, {
                            'attr': {
                                'class': 'form-control offer-input offer-textarea',
                                'rows': 7,
                                'placeholder': 'Décrivez clairement votre besoin, les compétences attendues, les délais et les objectifs...'
                            }
                        }) }}
                        <div class="text-danger small mt-2">
                            {{ form_errors(form.description) }}
                        </div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="offer-field">
                        {{ form_label(form.amount, 'Montant') }}
                        {{ form_widget(form.amount, {
                            'attr': {
                                'class': 'form-control offer-input',
                                'placeholder': 'Ex: 150'
                            }
                        }) }}
                        <div class="text-danger small mt-2">
                            {{ form_errors(form.amount) }}
                        </div>
                    </div>
                </div>

                {% if form.imageFile is defined %}
                    <div class="col-md-6">
                        <div class="offer-field">
                            {{ form_label(form.imageFile, 'Image de l’offre') }}
                            {{ form_widget(form.imageFile, {
                                'attr': {
                                    'class': 'form-control offer-input offer-file-input'
                                }
                            }) }}
                            <div class="text-danger small mt-2">
                                {{ form_errors(form.imageFile) }}
                            </div>
                        </div>
                    </div>
                {% endif %}
            </div>

            <div class="offer-form-actions">
                <button type="submit" class="offer-btn offer-btn-primary">
                    Créer l’offre
                </button>

                <a href="{{ path('app_project_owner_offer_list') }}" class="offer-btn offer-btn-secondary">
                    Retour
                </a>
            </div>

            {{ form_end(form) }}
        </div>
    </div>
</div>
{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    .offer-form-wrapper {
        max-width: 1100px;
        margin: 0 auto;
    }

    .offer-form-header {
        margin-bottom: 35px;
    }

    .offer-form-badge {
        display: inline-block;
        padding: 8px 18px;
        border-radius: 999px;
        background: rgba(255, 0, 76, 0.14);
        color: #ff4d6d;
        border: 1px solid rgba(255, 0, 76, 0.30);
        font-weight: 600;
        margin-bottom: 16px;
    }

    .offer-form-header h1 {
        color: #ffffff;
        font-size: 2.4rem;
        font-weight: 800;
        margin-bottom: 12px;
    }

    .offer-form-header p {
        color: rgba(255, 255, 255, 0.72);
        max-width: 700px;
        margin: 0 auto;
        font-size: 1.05rem;
    }

    .offer-form-card {
        position: relative;
        overflow: hidden;
        border-radius: 28px;
        padding: 38px;
        background: linear-gradient(145deg, rgba(18,18,24,0.95), rgba(8,8,12,0.92));
        border: 1px solid rgba(255, 0, 76, 0.16);
        box-shadow: 0 18px 50px rgba(0, 0, 0, 0.45);
    }

    .offer-form-card::before {
        content: "";
        position: absolute;
        inset: 0;
        background: radial-gradient(circle at center, rgba(255, 0, 76, 0.10), transparent 42%);
        pointer-events: none;
    }

    .offer-field {
        position: relative;
        z-index: 1;
        display: flex;
        flex-direction: column;
        height: 100%;
    }

    .offer-field label {
        display: block;
        color: #ffffff;
        font-weight: 600;
        margin-bottom: 10px;
    }

    .offer-input {
        background: linear-gradient(145deg, rgba(20,20,28,0.96), rgba(12,12,18,0.96)) !important;
        border: 1px solid rgba(255, 255, 255, 0.10) !important;
        color: #ffffff !important;
        border-radius: 16px !important;
        min-height: 54px;
        padding: 14px 18px;
        box-shadow: none !important;
        width: 100%;
    }

    .offer-input::placeholder {
        color: rgba(255, 255, 255, 0.45);
    }

    .offer-input:focus {
        border-color: rgba(255, 0, 76, 0.60) !important;
        box-shadow: 0 0 0 0.2rem rgba(255, 0, 76, 0.12) !important;
        background: rgba(255, 255, 255, 0.08) !important;
    }

    .offer-textarea {
        min-height: 180px !important;
        resize: vertical;
        padding-top: 14px;
    }

    .offer-file-input {
        padding: 12px 14px;
        cursor: pointer;
        height: 58px;
        display: flex;
        align-items: center;
    }

    .offer-file-input::file-selector-button {
        background: linear-gradient(90deg, #ff003c, #ff4d4d);
        color: white;
        border: none;
        padding: 10px 16px;
        margin-right: 14px;
        border-radius: 12px;
        cursor: pointer;
    }

    .offer-form-actions {
        position: relative;
        z-index: 1;
        display: flex;
        gap: 14px;
        flex-wrap: wrap;
        margin-top: 28px;
    }

    .offer-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 170px;
        padding: 14px 26px;
        border-radius: 999px;
        text-decoration: none;
        font-weight: 700;
        border: none;
        transition: all 0.25s ease;
    }

    .offer-btn-primary {
        background: linear-gradient(90deg, #ff003c, #ff4d4d);
        color: #fff;
        box-shadow: 0 10px 24px rgba(255, 0, 76, 0.28);
    }

    .offer-btn-primary:hover {
        transform: translateY(-2px);
        color: #fff;
    }

    .offer-btn-secondary {
        background: rgba(255, 255, 255, 0.08);
        color: #ffffff;
        border: 1px solid rgba(255, 255, 255, 0.12);
    }

    .offer-btn-secondary:hover {
        background: rgba(255, 255, 255, 0.14);
        color: #ffffff;
    }

    .text-danger ul {
        margin: 0;
        padding-left: 18px;
    }

    .text-danger li {
        color: #ff7b93;
    }

    @media (max-width: 768px) {
        .offer-form-card {
            padding: 24px;
            border-radius: 22px;
        }

        .offer-form-header h1 {
            font-size: 2rem;
        }
    }
</style>
{% endblock %}