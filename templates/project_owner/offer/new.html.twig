{% extends 'front/base_front.html.twig' %}

{% block title %}Créer une offre{% endblock %}

{% block body %}
<section class="post-offer-section">
    <div class="container">
        <div class="post-offer-wrapper">
            <div class="post-offer-header text-center">
                <span class="post-offer-badge">SynergyGig</span>
                <h1>Créer une offre</h1>
                <p>Publiez votre gig rapidement avec une présentation moderne et professionnelle.</p>
            </div>

            <div class="post-offer-card">
                {% for message in app.flashes('success') %}
                    <div class="front-success-popup">
                        <i class="bi bi-check-circle-fill me-2"></i>
                        {{ message }}
                    </div>
                {% endfor %}

                {% for message in app.flashes('error') %}
                    <div class="front-error-popup">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        {{ message }}
                    </div>
                {% endfor %}

                {{ form_start(form, {'attr': {'enctype': 'multipart/form-data'}}) }}

                {{ form_errors(form) }}

                <div class="row g-4">
                    <div class="col-md-6">
                        <div class="front-field">
                            {{ form_label(form.title) }}
                            {{ form_widget(form.title, {
                                'attr': {
                                    'class': 'form-control front-input',
                                    'placeholder': 'Ex: Création logo gaming'
                                }
                            }) }}
                            {{ form_errors(form.title) }}
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="front-field">
                            {{ form_label(form.type) }}
                            {{ form_widget(form.type, {
                                'attr': {
                                    'class': 'form-select front-input'
                                }
                            }) }}
                            {{ form_errors(form.type) }}
                        </div>
                    </div>

                    <div class="col-12">
                        <div class="front-field">
                            {{ form_label(form.description) }}
                            {{ form_widget(form.description, {
                                'attr': {
                                    'class': 'form-control front-input front-textarea',
                                    'rows': 7,
                                    'placeholder': 'Décrivez clairement votre besoin, le style souhaité, les délais, les objectifs...'
                                }
                            }) }}
                            {{ form_errors(form.description) }}
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="front-field">
                            {{ form_label(form.amount) }}
                            {{ form_widget(form.amount, {
                                'attr': {
                                    'class': 'form-control front-input',
                                    'placeholder': 'Ex: 150'
                                }
                            }) }}
                            {{ form_errors(form.amount) }}
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="front-field">
                            {{ form_label(form.imageFile) }}
                            {{ form_widget(form.imageFile, {
                                'attr': {
                                    'class': 'form-control front-input front-file-input'
                                }
                            }) }}
                            {{ form_errors(form.imageFile) }}
                        </div>
                    </div>
                </div>

                <div class="post-offer-actions">
                    <button type="submit" class="front-btn front-btn-primary">
                        Créer l'offre
                    </button>

                    <a href="{{ path('app_home') }}" class="front-btn front-btn-secondary">
                        Retour
                    </a>
                </div>

                {{ form_end(form) }}
            </div>
        </div>
    </div>
</section>
{% endblock %}

{% block stylesheets %}
<style>
    .post-offer-section {
        min-height: 100vh;
        padding: 140px 0 80px;
        background:
            radial-gradient(circle at top left, rgba(255, 0, 76, 0.18), transparent 30%),
            radial-gradient(circle at bottom right, rgba(255, 60, 60, 0.12), transparent 28%),
            linear-gradient(135deg, #050505 0%, #0b0b12 45%, #12060a 100%);
    }

    .post-offer-wrapper {
        max-width: 1100px;
        margin: 0 auto;
    }

    .post-offer-header {
        margin-bottom: 35px;
    }

    .post-offer-badge {
        display: inline-block;
        padding: 8px 18px;
        border-radius: 999px;
        background: rgba(255, 0, 76, 0.14);
        color: #ff4d6d;
        border: 1px solid rgba(255, 0, 76, 0.30);
        font-weight: 600;
        margin-bottom: 16px;
    }

    .post-offer-header h1 {
        color: #ffffff;
        font-size: 2.6rem;
        font-weight: 800;
        margin-bottom: 12px;
    }

    .post-offer-header p {
        color: rgba(255, 255, 255, 0.72);
        max-width: 700px;
        margin: 0 auto;
        font-size: 1.05rem;
    }

    .post-offer-card {
        position: relative;
        overflow: hidden;
        border-radius: 28px;
        padding: 38px;
        background: linear-gradient(145deg, rgba(18,18,24,0.95), rgba(8,8,12,0.92));
        border: 1px solid rgba(255, 0, 76, 0.16);
        box-shadow: 0 18px 50px rgba(0, 0, 0, 0.45);
    }

    .post-offer-card::before {
        content: "";
        position: absolute;
        inset: 0;
        background: radial-gradient(circle at center, rgba(255, 0, 76, 0.10), transparent 42%);
        pointer-events: none;
    }

    .front-success-popup {
        position: relative;
        z-index: 1;
        background: linear-gradient(90deg, #b3002d, #ff003c);
        color: #fff;
        border: 1px solid rgba(255,255,255,0.12);
        padding: 14px 18px;
        border-radius: 14px;
        font-weight: 700;
        margin-bottom: 20px;
        box-shadow: 0 12px 28px rgba(255, 0, 76, 0.22);
        display: flex;
        align-items: center;
    }

    .front-error-popup {
        position: relative;
        z-index: 1;
        background: linear-gradient(90deg, #2c0b0b, #5c1111);
        color: #fff;
        border: 1px solid rgba(255,255,255,0.10);
        padding: 14px 18px;
        border-radius: 14px;
        font-weight: 700;
        margin-bottom: 20px;
        box-shadow: 0 12px 28px rgba(120, 0, 0, 0.20);
        display: flex;
        align-items: center;
    }

    .front-field {
        position: relative;
        z-index: 1;
        display: flex;
        flex-direction: column;
        height: 100%;
    }

    .front-field label {
        display: block;
        color: #ffffff;
        font-weight: 600;
        margin-bottom: 10px;
    }

    .front-input {
        background: linear-gradient(145deg, rgba(20,20,28,0.96), rgba(12,12,18,0.96)) !important;
        border: 1px solid rgba(255, 255, 255, 0.10) !important;
        color: #ffffff !important;
        border-radius: 16px !important;
        min-height: 54px;
        padding: 14px 18px;
        box-shadow: none !important;
        width: 100%;
    }

    .front-input::placeholder {
        color: rgba(255, 255, 255, 0.45);
    }

    .front-input:focus {
        border-color: rgba(255, 0, 76, 0.60) !important;
        box-shadow: 0 0 0 0.2rem rgba(255, 0, 76, 0.12) !important;
        background: rgba(255, 255, 255, 0.08) !important;
    }

    .front-textarea {
        min-height: 180px !important;
        resize: vertical;
        padding-top: 14px;
    }

    .form-select option,
    select option {
        background: #ffffff;
        color: #111111;
    }

    .front-file-input {
        padding: 12px 14px;
        cursor: pointer;
        height: 58px;
        display: flex;
        align-items: center;
    }

    .front-file-input::file-selector-button {
        background: linear-gradient(90deg, #ff003c, #ff4d4d);
        color: white;
        border: none;
        padding: 10px 16px;
        margin-right: 14px;
        border-radius: 12px;
        cursor: pointer;
    }

    .post-offer-actions {
        position: relative;
        z-index: 1;
        display: flex;
        gap: 14px;
        flex-wrap: wrap;
        margin-top: 28px;
    }

    .front-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 170px;
        padding: 14px 26px;
        border-radius: 999px;
        text-decoration: none;
        font-weight: 700;
        border: none;
        transition: all 0.25s ease;
    }

    .front-btn-primary {
        background: linear-gradient(90deg, #ff003c, #ff4d4d);
        color: #fff;
        box-shadow: 0 10px 24px rgba(255, 0, 76, 0.28);
    }

    .front-btn-primary:hover {
        transform: translateY(-2px);
        color: #fff;
    }

    .front-btn-secondary {
        background: rgba(255, 255, 255, 0.08);
        color: #ffffff;
        border: 1px solid rgba(255, 255, 255, 0.12);
    }

    .front-btn-secondary:hover {
        background: rgba(255, 255, 255, 0.14);
        color: #ffffff;
    }

    .invalid-feedback,
    .form-error-message,
    ul li {
        color: #ff7b93;
    }

    @media (max-width: 768px) {
        .post-offer-section {
            padding: 120px 0 60px;
        }

        .post-offer-card {
            padding: 24px;
            border-radius: 22px;
        }

        .post-offer-header h1 {
            font-size: 2rem;
        }
    }
</style>
{% endblock %}