{% extends 'project_owner/base_project_owner.html.twig' %}

{% block title %}Mes offres{% endblock %}

{% block body %}
<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="mb-1">Mes offres</h1>
            <p class="text-muted mb-0">Gérez les offres que vous avez créées.</p>
        </div>

        <a href="{{ path('app_project_owner_offer_new') }}" class="btn btn-primary rounded-pill px-4">
            + Nouvelle offre
        </a>
    </div>

    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body p-0">
            {% if offers is not empty %}
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="px-4 py-3">Titre</th>
                                <th class="py-3">Type</th>
                                <th class="py-3">Montant</th>
                                <th class="py-3">Statut</th>
                                <th class="py-3">Date</th>
                                <th class="py-3 text-end pe-4">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for offer in offers %}
                                <tr>
                                    <td class="px-4 py-3">
                                        <div class="fw-semibold">{{ offer.title }}</div>
                                        <div class="text-muted small">
                                            {{ offer.description|length > 70 ? offer.description|slice(0, 70) ~ '...' : offer.description }}
                                        </div>
                                    </td>

                                    <td>{{ offer.type }}</td>

                                    <td>{{ offer.amount }} $</td>

                                    <td>
                                        {% if offer.status == 'DRAFT' %}
                                            <span class="badge bg-warning text-dark">Brouillon</span>
                                        {% elseif offer.status == 'PUBLISHED' %}
                                            <span class="badge bg-success">Publiée</span>
                                        {% elseif offer.status == 'CLOSED' %}
                                            <span class="badge bg-secondary">Clôturée</span>
                                        {% else %}
                                            <span class="badge bg-dark">{{ offer.status }}</span>
                                        {% endif %}
                                    </td>

                                    <td>{{ offer.createdAt|date('d/m/Y H:i') }}</td>

                                    <td class="text-end pe-4">
                                        <div class="d-flex justify-content-end gap-2">
                                            {% if offer.status == 'DRAFT' %}
                                                <a href="{{ path('app_project_owner_offer_edit', {'id': offer.id}) }}"
                                                   class="btn btn-sm btn-warning rounded-pill px-3">
                                                    Modifier
                                                </a>
                                            {% endif %}
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% else %}
                <div class="p-4 text-center">
                    <h4 class="mb-2">Aucune offre créée</h4>
                    <p class="text-muted mb-3">Vous n’avez pas encore créé d’offre.</p>
                    <a href="{{ path('app_project_owner_offer_new') }}" class="btn btn-primary rounded-pill px-4">
                        Créer ma première offre
                    </a>
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}