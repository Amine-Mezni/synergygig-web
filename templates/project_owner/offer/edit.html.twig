{% extends 'project_owner/base_project_owner.html.twig' %}

{% block title %}Modifier l’offre{% endblock %}

{% block body %}
<div class="container py-4">
    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body p-4">
            <h1 class="mb-4">Modifier l’offre</h1>

            {{ form_start(form) }}

                <div class="mb-3">
                    {{ form_label(form.title) }}
                    {{ form_widget(form.title) }}
                    <div class="text-danger small">
                        {{ form_errors(form.title) }}
                    </div>
                </div>

                <div class="mb-3">
                    {{ form_label(form.description) }}
                    {{ form_widget(form.description) }}
                    <div class="text-danger small">
                        {{ form_errors(form.description) }}
                    </div>
                </div>

                <div class="mb-3">
                    {{ form_label(form.type) }}
                    {{ form_widget(form.type) }}
                    <div class="text-danger small">
                        {{ form_errors(form.type) }}
                    </div>
                </div>

                <div class="mb-3">
                    {{ form_label(form.amount) }}
                    {{ form_widget(form.amount) }}
                    <div class="text-danger small">
                        {{ form_errors(form.amount) }}
                    </div>
                </div>

                {% if form.imageFile is defined %}
                    <div class="mb-3">
                        {{ form_label(form.imageFile) }}
                        {{ form_widget(form.imageFile) }}
                        <div class="text-danger small">
                            {{ form_errors(form.imageFile) }}
                        </div>
                    </div>
                {% endif %}

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary rounded-pill px-4">
                        Enregistrer les modifications
                    </button>

                    <a href="{{ path('app_project_owner_offer_list') }}" class="btn btn-outline-secondary rounded-pill px-4">
                        Annuler
                    </a>
                </div>

            {{ form_end(form) }}
        </div>
    </div>
</div>
{% endblock %}