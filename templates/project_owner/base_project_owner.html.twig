<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>{% block title %}Espace HR{% endblock %}</title>

    <link href="{{ asset('front/css/variables.css') }}" rel="stylesheet">
    <link href="{{ asset('front/css/base.css') }}" rel="stylesheet">
    <link href="{{ asset('front/css/components.css') }}" rel="stylesheet">
</head>

<body style="background:#0b0f19; color:white;">

<!-- NAVBAR -->
<nav style="display:flex; justify-content:space-between; align-items:center; padding:20px 40px; border-bottom:1px solid rgba(255,255,255,0.1);">

    <!-- LOGO -->
    <div style="font-weight:700; font-size:20px;">
        SynergyGig
    </div>

    <!-- MENU -->
    <div style="display:flex; gap:20px; align-items:center;">

        <a href="{{ path('app_home') }}" style="color:white; text-decoration:none;">
            Dashboard
        </a>

        <a href="{{ path('app_project_owner_offer_new') }}" style="color:white; text-decoration:none;">
            Ajouter une offre
        </a>

        <a href="{{ path('app_project_owner_offer_list') }}" style="color:white; text-decoration:none;">
            Mes offres
        </a>

        <!-- BOUTON LOGOUT -->
        <a href="{{ path('app_logout') }}" 
           style="background:#ef4444; padding:8px 14px; border-radius:999px; text-decoration:none; color:white;">
            Déconnexion
        </a>

    </div>
</nav>

<!-- CONTENU -->
<main style="padding:40px;">
    {% block body %}{% endblock %}
</main>

</body>
</html>