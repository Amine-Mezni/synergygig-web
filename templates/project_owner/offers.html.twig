{% extends 'layouts/admin.html.twig' %}

{% block page_title %}My Offers{% endblock %}

{% block header_actions %}
    <a href="{{ path('app_project_owner_offer_new') }}" class="btn btn-primary btn-sm">+ New Offer</a>
{% endblock %}

{% block content %}
{# Stats #}
<div class="bento-grid" style="grid-template-columns:repeat(4,1fr);gap:1rem;margin-bottom:1.5rem">
    <a href="{{ path('app_project_owner_offers') }}" class="card" style="padding:1.25rem;text-align:center;text-decoration:none;{{ currentStatus is null ? 'outline:2px solid var(--accent-blue);outline-offset:-2px' : '' }}">
        <div class="text-muted" style="font-size:.75rem;margin-bottom:.25rem">Total</div>
        <div style="font-size:1.75rem;font-weight:700;color:var(--text-primary)">{{ totalCount }}</div>
    </a>
    <a href="{{ path('app_project_owner_offers', {status: 'DRAFT'}) }}" class="card" style="padding:1.25rem;text-align:center;text-decoration:none;{{ currentStatus == 'DRAFT' ? 'outline:2px solid var(--accent-blue);outline-offset:-2px' : '' }}">
        <div class="text-muted" style="font-size:.75rem;margin-bottom:.25rem">Drafts</div>
        <div style="font-size:1.75rem;font-weight:700;color:var(--accent-blue)">{{ draftCount }}</div>
    </a>
    <a href="{{ path('app_project_owner_offers', {status: 'OPEN'}) }}" class="card" style="padding:1.25rem;text-align:center;text-decoration:none;{{ currentStatus == 'OPEN' ? 'outline:2px solid var(--color-success);outline-offset:-2px' : '' }}">
        <div class="text-muted" style="font-size:.75rem;margin-bottom:.25rem">Open</div>
        <div style="font-size:1.75rem;font-weight:700;color:var(--color-success)">{{ openCount }}</div>
    </a>
    <a href="{{ path('app_project_owner_offers', {status: 'CLOSED'}) }}" class="card" style="padding:1.25rem;text-align:center;text-decoration:none;{{ currentStatus == 'CLOSED' ? 'outline:2px solid var(--color-danger);outline-offset:-2px' : '' }}">
        <div class="text-muted" style="font-size:.75rem;margin-bottom:.25rem">Closed</div>
        <div style="font-size:1.75rem;font-weight:700;color:var(--color-danger)">{{ closedCount }}</div>
    </a>
</div>

{# Filter bar #}
<div class="card" style="padding:var(--space-md) var(--space-lg);margin-bottom:var(--space-lg);display:flex;align-items:center;gap:var(--space-md)">
    <form method="get" action="{{ path('app_project_owner_offers') }}" style="flex:1;display:flex;align-items:center;gap:var(--space-md)">
        <input type="text" name="q" value="{{ app.request.query.get('q') }}" placeholder="Search your offers..." class="form-control" style="max-width:250px">
        <button type="submit" class="btn btn-secondary btn-sm">Search</button>
    </form>
</div>

{# Table #}
<div class="card">
    {% if offers|length > 0 %}
    <div class="table-wrap">
        <table class="table">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Type</th>
                    <th>Status</th>
                    <th>Budget</th>
                    <th>Created</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for o in offers %}
                <tr>
                    <td><a href="{{ path('app_offer_show', {id: o.id}) }}" style="color:var(--accent-blue);font-weight:500">{{ o.title }}</a></td>
                    <td>{{ o.offerType ? o.offerType|replace({'_': ' '}) : '—' }}</td>
                    <td>
                        {% set sc = {'DRAFT': 'blue', 'OPEN': 'green', 'CLOSED': 'red', 'CANCELLED': 'orange'} %}
                        <span class="badge badge--{{ sc[o.status] ?? 'blue' }}">{{ o.status }}</span>
                    </td>
                    <td>{{ o.amount ? o.amount ~ ' ' ~ (o.currency ?? 'TND') : '—' }}</td>
                    <td>{{ o.createdAt ? o.createdAt|date('M d, Y') : '—' }}</td>
                    <td>
                        <details class="crud-actions-menu">
                            <summary class="btn btn-ghost btn-sm" title="Actions"><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="5" r="2"/><circle cx="12" cy="12" r="2"/><circle cx="12" cy="19" r="2"/></svg></summary>
                            <div class="crud-actions-dropdown">
                                <a href="{{ path('app_offer_show', {id: o.id}) }}" class="crud-action-item"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg> View</a>
                                <a href="{{ path('app_project_owner_offer_edit', {id: o.id}) }}" class="crud-action-item"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg> Edit</a>
                                <a href="{{ path('app_project_owner_applications', {id: o.id}) }}" class="crud-action-item" style="color:var(--accent-purple)"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg> Applications</a>
                            </div>
                        </details>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    {% else %}
    <div style="text-align:center;padding:3rem">
        <p class="text-muted">You haven't created any offers yet.</p>
        <a href="{{ path('app_project_owner_offer_new') }}" class="btn btn-primary" style="margin-top:1rem">+ Create Offer</a>
    </div>
    {% endif %}
</div>

{% if pagination is defined %}{% include 'components/_pagination.html.twig' %}{% endif %}
{% endblock %}
