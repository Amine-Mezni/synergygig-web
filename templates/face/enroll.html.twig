{% extends 'layouts/admin.html.twig' %}

{% block page_title %}Enroll Face ID{% endblock %}

{% block breadcrumb %}
    <nav class="breadcrumb">
        <a href="{{ path('app_dashboard') }}">Home</a>
        <span class="sep">/</span>
        <a href="{{ path('app_user_show', {id: app.user.id}) }}">Profile</a>
        <span class="sep">/</span>
        <span>Face Enrollment</span>
    </nav>
{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .face-enroll { max-width: 520px; margin: 0 auto; }
        .face-enroll__video-wrap {
            position: relative;
            border-radius: 12px;
            overflow: hidden;
            background: #000;
            aspect-ratio: 4/3;
            margin-bottom: var(--space-lg);
        }
        .face-enroll__video {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transform: scaleX(-1);
        }
        .face-enroll__canvas { display: none; }
        .face-enroll__guide {
            position: absolute;
            top: 50%; left: 50%;
            transform: translate(-50%, -50%);
            width: 55%; height: 75%;
            border: 2px dashed rgba(44,102,110,0.5);
            border-radius: 50%;
            pointer-events: none;
        }
        .face-enroll__guide-text {
            position: absolute;
            bottom: 12px;
            left: 50%;
            transform: translateX(-50%);
            font-size: 0.75rem;
            color: var(--text-muted);
            text-align: center;
            pointer-events: none;
        }
        .face-enroll__actions {
            display: flex;
            gap: var(--space-md);
            justify-content: center;
        }
        .face-enroll__status {
            margin: 0 0 var(--space-md);
            font-size: 0.82rem;
            color: var(--text-muted);
        }
        .face-enroll__fallback {
            display: none;
            margin-bottom: var(--space-md);
            text-align: left;
            background: rgba(255,255,255,0.03);
            border: 1px dashed var(--border-color);
            border-radius: 10px;
            padding: var(--space-sm);
        }
        .face-enroll__fallback label {
            display: block;
            margin-bottom: 6px;
            font-size: 0.8rem;
            color: var(--text-muted);
        }
        .face-enroll__preview {
            border-radius: 12px;
            max-width: 100%;
            margin-bottom: var(--space-lg);
            display: none;
        }
    </style>
{% endblock %}

{% block content %}
<div class="face-enroll">
    <div class="card" style="text-align:center">
        <h3 style="margin-bottom:var(--space-md)">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:middle;margin-right:8px"><rect x="1" y="1" width="22" height="22" rx="3"/><circle cx="12" cy="10" r="3"/><path d="M7 20v-1a5 5 0 0 1 10 0v1"/></svg>
            Face ID Enrollment
        </h3>
        <p class="text-muted" style="margin-bottom:var(--space-lg);font-size:0.85rem">
            Position your face within the oval guide, then click <strong>Capture</strong>. Make sure you have good lighting.
        </p>

        <div class="face-enroll__video-wrap" id="videoWrap">
            <video class="face-enroll__video" id="video" autoplay playsinline></video>
            <canvas class="face-enroll__canvas" id="canvas"></canvas>
            <div class="face-enroll__guide"></div>
            <div class="face-enroll__guide-text">Center your face in the oval</div>
        </div>

        <img class="face-enroll__preview" id="preview" alt="Captured face">
        <div class="face-enroll__status" id="faceStatus">Preparing camera...</div>

        <form method="post" action="{{ path('app_face_enroll_process') }}" id="enrollForm" enctype="multipart/form-data">
            <input type="hidden" name="face_image" id="faceImage">
            <div class="face-enroll__fallback" id="fallbackWrap">
                <label for="faceUpload">If camera does not work, upload a clear selfie image:</label>
                <input type="file" id="faceUpload" name="face_upload" accept="image/*">
            </div>
            <div class="face-enroll__actions">
                <button type="button" id="captureBtn" class="btn btn-primary">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
                    Capture
                </button>
                <button type="button" id="retakeBtn" class="btn btn-secondary" style="display:none">Retake</button>
                <button type="submit" id="submitBtn" class="btn btn-primary" style="display:none">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                    Enroll Face
                </button>
            </div>
        </form>

        <a href="{{ path('app_user_show', {id: app.user.id}) }}" class="btn btn-ghost" style="margin-top:var(--space-md)">Cancel</a>
    </div>
</div>

{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
    (function() {
        var video = document.getElementById('video');
        var canvas = document.getElementById('canvas');
        var preview = document.getElementById('preview');
        var faceImage = document.getElementById('faceImage');
        var captureBtn = document.getElementById('captureBtn');
        var retakeBtn = document.getElementById('retakeBtn');
        var submitBtn = document.getElementById('submitBtn');
        var videoWrap = document.getElementById('videoWrap');
        var statusEl = document.getElementById('faceStatus');
        var fallbackWrap = document.getElementById('fallbackWrap');
        var fallbackInput = document.getElementById('faceUpload');
        var enrollForm = document.getElementById('enrollForm');
        var stream = null;
        var cameraReady = false;

        function setStatus(text, isError) {
            statusEl.textContent = text;
            statusEl.style.color = isError ? 'var(--danger,#E53E3E)' : 'var(--text-muted)';
        }

        function enableFallback(message) {
            setStatus(message, true);
            fallbackWrap.style.display = 'block';
            videoWrap.style.display = 'none';
            captureBtn.style.display = 'none';
            retakeBtn.style.display = 'none';
            submitBtn.style.display = '';
            submitBtn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg> Enroll From Image';
        }

        captureBtn.disabled = true;
        captureBtn.textContent = 'Starting camera...';

        if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) {
            enableFallback('Camera is not available in this browser/session. Please upload a selfie image instead.');
            return;
        }

        navigator.mediaDevices.getUserMedia({ video: { width: 640, height: 480, facingMode: 'user' } })
            .then(function(s) {
                stream = s;
                video.srcObject = s;
                video.onloadedmetadata = function() {
                    video.play();
                };
                video.onplaying = function() {
                    cameraReady = true;
                    captureBtn.disabled = false;
                    setStatus('Camera ready. Capture your face and then click Enroll Face.', false);
                    captureBtn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg> Capture';
                };
            })
            .catch(function(err) {
                enableFallback('Camera access failed. You can upload a selfie image instead.');
                videoWrap.innerHTML = '<div style="padding:2rem;color:var(--danger,#E53E3E);font-size:0.9rem"><strong>Camera access failed.</strong><br><br>Please allow camera access, or use upload fallback below.<br><small style="color:var(--text-muted)">Error: ' + (err.message || err.name || 'Unknown') + '</small></div>';
            });

        captureBtn.addEventListener('click', function() {
            if (!cameraReady || video.videoWidth === 0) {
                alert('Camera is not ready yet. Please wait a moment.');
                return;
            }
            canvas.width = video.videoWidth;
            canvas.height = video.videoHeight;
            canvas.getContext('2d').drawImage(video, 0, 0);
            var dataUrl = canvas.toDataURL('image/png');
            faceImage.value = dataUrl;
            preview.src = dataUrl;
            preview.style.display = 'block';
            videoWrap.style.display = 'none';
            captureBtn.style.display = 'none';
            retakeBtn.style.display = '';
            submitBtn.style.display = '';
            setStatus('Face captured. Click Enroll Face to save.', false);
        });

        retakeBtn.addEventListener('click', function() {
            faceImage.value = '';
            preview.style.display = 'none';
            videoWrap.style.display = '';
            captureBtn.style.display = '';
            retakeBtn.style.display = 'none';
            submitBtn.style.display = 'none';
            setStatus('Retake your face capture, then click Enroll Face.', false);
        });

        fallbackInput.addEventListener('change', function() {
            if (fallbackInput.files && fallbackInput.files.length > 0) {
                submitBtn.style.display = '';
                setStatus('Image selected. Click Enroll From Image.', false);
            }
        });

        enrollForm.addEventListener('submit', function(e) {
            var hasCapture = !!faceImage.value;
            var hasUpload = fallbackInput.files && fallbackInput.files.length > 0;
            if (!hasCapture && !hasUpload) {
                e.preventDefault();
                alert('Please capture your face or upload a selfie image first.');
                return;
            }
            submitBtn.disabled = true;
            submitBtn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="animation:spin 1s linear infinite"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg> Processing...';
            if (stream) stream.getTracks().forEach(function(t) { t.stop(); });
        });

        window.addEventListener('beforeunload', function() {
            if (stream) stream.getTracks().forEach(function(t) { t.stop(); });
        });
    })();
    </script>
    <style>@keyframes spin{from{transform:rotate(0)}to{transform:rotate(360deg)}}</style>
{% endblock %}
