{% extends 'layouts/auth.html.twig' %}

{% block title %}Reset Password | SynergyGig{% endblock %}

{% block auth_body %}
    <div style="text-align:center;margin-bottom:var(--space-xl)">
        <div style="width:56px;height:56px;margin:0 auto var(--space-md);background:linear-gradient(135deg,rgba(44,102,110,.18),rgba(144,221,240,.10));border-radius:50%;display:flex;align-items:center;justify-content:center">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--primary,#2C666E)" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <h2 style="font-family:var(--font-heading,Outfit,sans-serif);margin:0 0 var(--space-xs)">Set a new password</h2>
        <p style="color:var(--text-secondary);font-size:.875rem;margin:0">Must be at least 8 characters.</p>
    </div>

    {% for flash_error in app.flashes('reset_password_error') %}
        <div style="background:rgba(239,68,68,.10);border:1px solid rgba(239,68,68,.3);color:#ef4444;padding:.75rem 1rem;border-radius:8px;font-size:.875rem;margin-bottom:1rem">
            {{ flash_error }}
        </div>
    {% endfor %}

    {{ form_start(resetForm) }}
        <div class="form-group">
            <label class="form-label">New Password</label>
            {{ form_widget(resetForm.plainPassword.first) }}
            {{ form_errors(resetForm.plainPassword.first) }}
        </div>
        <div class="form-group" style="margin-top:var(--space-md)">
            <label class="form-label">Confirm New Password</label>
            {{ form_widget(resetForm.plainPassword.second) }}
            {{ form_errors(resetForm.plainPassword.second) }}
        </div>
        <button type="submit" class="btn btn-primary" style="width:100%;margin-top:var(--space-lg)">
            Reset Password
        </button>
    {{ form_end(resetForm) }}
{% endblock %}
