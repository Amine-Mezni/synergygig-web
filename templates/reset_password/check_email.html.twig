{% extends 'layouts/auth.html.twig' %}

{% block title %}Check Your Email | SynergyGig{% endblock %}

{% block auth_body %}
    <div style="text-align:center;padding:var(--space-xl) 0">
        <div style="width:64px;height:64px;margin:0 auto var(--space-md);background:linear-gradient(135deg,rgba(44,102,110,.18),rgba(144,221,240,.10));border-radius:50%;display:flex;align-items:center;justify-content:center">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--primary,#2C666E)" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        </div>
        <h2 style="font-family:var(--font-heading,Outfit,sans-serif);margin:0 0 var(--space-sm)">Check your email</h2>
        <p style="color:var(--text-secondary);font-size:.9rem;max-width:360px;margin:0 auto var(--space-md)">
            We've sent a password reset link to your email. The link will expire in
            <strong style="color:var(--text-primary)">{{ resetToken.expirationMessageKey|trans(resetToken.expirationMessageData, 'ResetPasswordBundle') }}</strong>.
        </p>
        <p style="color:var(--text-muted);font-size:.8rem">
            Didn't receive it? Check your spam folder or
            <a href="{{ path('app_forgot_password_request') }}" style="color:var(--primary,#2C666E)">request another link</a>.
        </p>
    </div>
{% endblock %}
