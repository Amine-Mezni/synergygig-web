{% extends 'layouts/admin.html.twig' %}

{% block title %}Edit Profile | SynergyGig{% endblock %}
{% block page_title %}Edit Profile{% endblock %}

{% block header_actions %}
    <a href="{{ path('app_profile') }}" class="btn btn-ghost btn-sm">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
        Back to Profile
    </a>
{% endblock %}

{% block content %}
<div style="max-width:640px;margin:0 auto">

    {# ── Avatar Upload Card ── #}
    <div class="card" style="margin-bottom:var(--space-lg);padding:var(--space-xl)">
        <h2 style="font-size:1.125rem;color:var(--text-primary);margin:0 0 var(--space-lg)">Profile Photo</h2>
        <div style="display:flex;align-items:center;gap:var(--space-xl);flex-wrap:wrap">
            <div style="flex-shrink:0">
                {% if user.avatar_path %}
                    <img id="avatar-preview" src="{{ asset('uploads/avatars/' ~ user.avatar_path) }}" alt="Avatar"
                         style="width:96px;height:96px;border-radius:50%;object-fit:cover;border:3px solid var(--border-color)">
                {% else %}
                    <div id="avatar-preview-initials" style="width:96px;height:96px;border-radius:50%;background:linear-gradient(135deg,var(--accent-primary,#7c3aed),var(--accent-secondary,#a78bfa));display:flex;align-items:center;justify-content:center;font-size:2rem;font-weight:700;color:#fff;border:3px solid var(--border-color)">
                        {{ user.firstName|first|upper }}{{ user.lastName|first|upper }}
                    </div>
                    <img id="avatar-preview" src="" alt="" style="width:96px;height:96px;border-radius:50%;object-fit:cover;border:3px solid var(--border-color);display:none">
                {% endif %}
            </div>
            <div style="flex:1">
                <form method="post" action="{{ path('app_profile_upload_avatar') }}" enctype="multipart/form-data">
                    <input type="hidden" name="_token" value="{{ csrf_token('avatar-self') }}">
                    <label style="display:inline-flex;align-items:center;gap:.5rem;padding:9px 16px;border-radius:8px;border:1px dashed var(--border-color);cursor:pointer;font-size:.875rem;color:var(--text-muted);transition:border-color .2s,color .2s"
                           onmouseover="this.style.borderColor='var(--accent-primary,#7c3aed)';this.style.color='var(--text-primary)'" onmouseout="this.style.borderColor='var(--border-color)';this.style.color='var(--text-muted)'">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                        Choose photo
                        <input type="file" name="avatar" accept="image/jpeg,image/png,image/gif,image/webp" style="display:none" onchange="previewAvatar(this)">
                    </label>
                    <button type="submit" id="avatar-upload-btn" class="btn btn-primary btn-sm" style="margin-left:.5rem;display:none">Upload</button>
                    <div class="text-muted" style="font-size:.75rem;margin-top:.5rem">JPG, PNG, GIF or WEBP · max 5 MB</div>
                </form>
            </div>
        </div>
    </div>

    <div class="card" style="padding:var(--space-xl)">
        <h2 style="font-size:1.125rem;color:var(--text-primary);margin:0 0 var(--space-xl)">Personal Information</h2>

        {{ form_start(form, {'attr': {'novalidate': 'novalidate'}})}}
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:var(--space-lg)">
            {% if form.firstName is defined %}
            <div class="form-group">
                {{ form_label(form.firstName, 'First Name', {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(form.firstName, {'attr': {'class': 'form-control'}}) }}
            </div>
            {% endif %}
            {% if form.lastName is defined %}
            <div class="form-group">
                {{ form_label(form.lastName, 'Last Name', {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(form.lastName, {'attr': {'class': 'form-control'}}) }}
            </div>
            {% endif %}
        </div>
        {% if form.email is defined %}
        <div class="form-group" style="margin-top:var(--space-lg)">
            {{ form_label(form.email, 'Email', {'label_attr': {'class': 'form-label'}}) }}
            {{ form_widget(form.email, {'attr': {'class': 'form-control'}}) }}
        </div>
        {% endif %}
        {% if form.phone is defined %}
        <div class="form-group" style="margin-top:var(--space-lg)">
            {{ form_label(form.phone, 'Phone', {'label_attr': {'class': 'form-label'}}) }}
            {{ form_widget(form.phone, {'attr': {'class': 'form-control'}}) }}
        </div>
        {% endif %}
        {% if form.address is defined %}
        <div class="form-group" style="margin-top:var(--space-lg)">
            {{ form_label(form.address, 'Address', {'label_attr': {'class': 'form-label'}}) }}
            {{ form_widget(form.address, {'attr': {'class': 'form-control'}}) }}
        </div>
        {% endif %}

        <div style="display:flex;gap:var(--space-sm);margin-top:var(--space-xl)">
            <button type="submit" class="btn btn-primary">Save Changes</button>
            <a href="{{ path('app_profile') }}" class="btn btn-ghost">Cancel</a>
        </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
function previewAvatar(input) {
    if (!input.files || !input.files[0]) return;
    const reader = new FileReader();
    reader.onload = function(e) {
        const img = document.getElementById('avatar-preview');
        const initials = document.getElementById('avatar-preview-initials');
        if (img) { img.src = e.target.result; img.style.display = 'block'; }
        if (initials) initials.style.display = 'none';
    };
    reader.readAsDataURL(input.files[0]);
    const btn = document.getElementById('avatar-upload-btn');
    if (btn) btn.style.display = 'inline-flex';
}
</script>
{% endblock %}
