<!DOCTYPE html>
<html lang="en" class="{% block html_class %}{% endblock %}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}SynergyGig{% endblock %}</title>

    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

    <!-- CSS -->
    <link rel="stylesheet" href="{{ asset('front/css/variables.css') }}">
<link rel="stylesheet" href="{{ asset('front/css/base.css') }}">
<link rel="stylesheet" href="{{ asset('front/css/components.css') }}">

    <script>
    (function(){
        try{
            var t = localStorage.getItem('sg_theme');
            if(t) document.documentElement.setAttribute('data-theme', t);
        } catch(e){}
    })();
    </script>

    {% block stylesheets %}{% endblock %}
</head>

<body>

{% block body %}{% endblock %}

{% block javascripts %}{% endblock %}

</body>
</html>