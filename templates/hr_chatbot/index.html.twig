{% extends 'layouts/admin.html.twig' %}

{% block title %}HR Policy Chatbot | SynergyGig{% endblock %}
{% block page_title %}HR Policy Assistant{% endblock %}

{% block content %}
<div style="max-width:800px;margin:0 auto;display:flex;flex-direction:column;height:calc(100vh - 200px);min-height:500px">

    <div id="js-chat" style="flex:1;overflow-y:auto;padding:1rem;border:1px solid var(--border);border-radius:10px;background:var(--bg-card);margin-bottom:1rem">
        <div class="chat-msg assistant" style="margin-bottom:1rem;display:flex;gap:0.75rem">
            <div style="width:36px;height:36px;border-radius:50%;background:linear-gradient(135deg,#3b82f6,#a855f7);display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:1.1rem">🤖</div>
            <div style="background:var(--bg-surface,#f1f5f9);padding:0.75rem 1rem;border-radius:0 12px 12px 12px;max-width:80%;color:var(--text-primary);line-height:1.6">
                Hello! I'm your HR Policy Assistant. I can help with questions about:
                <ul style="margin:0.5rem 0 0;padding-left:1.2rem">
                    <li>Leave policies (annual, sick, maternity, paternity)</li>
                    <li>Attendance & working hours</li>
                    <li>Payroll & compensation</li>
                    <li>Training & certifications</li>
                    <li>Interview processes</li>
                    <li>Contracts & onboarding</li>
                    <li>Workplace conduct</li>
                </ul>
                <br>Ask me anything!
            </div>
        </div>
    </div>

    <div style="display:flex;gap:0.5rem">
        <input id="js-input" type="text" placeholder="Ask about HR policies..."
            style="flex:1;padding:0.75rem 1rem;border:1px solid var(--border);border-radius:8px;background:var(--bg-card);color:var(--text-primary);font-size:0.95rem"
            autocomplete="off">
        <button id="js-send" class="btn btn-primary" style="padding:0.75rem 1.5rem;white-space:nowrap">
            Send ➤
        </button>
    </div>

    <div style="margin-top:0.5rem;display:flex;flex-wrap:wrap;gap:0.4rem">
        {% set quickQs = [
            'What is the annual leave policy?',
            'How does sick leave work?',
            'What are the payroll dates?',
            'How to request leave?',
            'What training is required?'
        ] %}
        {% for q in quickQs %}
        <button class="js-quick" style="padding:0.3rem 0.6rem;border:1px solid var(--border);border-radius:16px;background:var(--bg-card);color:var(--text-secondary);font-size:0.75rem;cursor:pointer;transition:all .15s"
            onmouseover="this.style.borderColor='var(--accent)';this.style.color='var(--accent)'"
            onmouseout="this.style.borderColor='var(--border)';this.style.color='var(--text-secondary)'"
        >{{ q }}</button>
        {% endfor %}
    </div>
</div>

<script>
const chat    = document.getElementById('js-chat');
const input   = document.getElementById('js-input');
const sendBtn = document.getElementById('js-send');
let history   = [];

function addMsg(role, text) {
    const isUser = role === 'user';
    const div = document.createElement('div');
    div.style.cssText = 'margin-bottom:1rem;display:flex;gap:0.75rem;' + (isUser ? 'flex-direction:row-reverse;' : '');

    const avatar = document.createElement('div');
    avatar.style.cssText = 'width:36px;height:36px;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:1.1rem;'
        + (isUser ? 'background:linear-gradient(135deg,#22c55e,#16a34a)' : 'background:linear-gradient(135deg,#3b82f6,#a855f7)');
    avatar.textContent = isUser ? '👤' : '🤖';

    const bubble = document.createElement('div');
    bubble.style.cssText = 'padding:0.75rem 1rem;border-radius:' + (isUser ? '12px 0 12px 12px' : '0 12px 12px 12px')
        + ';max-width:80%;color:var(--text-primary);line-height:1.6;'
        + (isUser ? 'background:var(--accent);color:#fff' : 'background:var(--bg-surface,#f1f5f9)');
    bubble.innerHTML = markdownToHtml(text);

    div.appendChild(avatar);
    div.appendChild(bubble);
    chat.appendChild(div);
    chat.scrollTop = chat.scrollHeight;
}

async function send() {
    const q = input.value.trim();
    if (!q) return;

    addMsg('user', q);
    history.push({role: 'user', content: q});
    input.value = '';
    sendBtn.disabled = true;
    sendBtn.textContent = '...';

    try {
        const resp = await fetch('{{ path("app_hr_chatbot_ask") }}', {
            method: 'POST',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify({question: q, history: history})
        });
        const data = await resp.json();
        const answer = data.answer || data.error || 'Sorry, something went wrong.';
        addMsg('assistant', answer);
        history.push({role: 'assistant', content: answer});
    } catch (e) {
        addMsg('assistant', 'Connection error. Please try again.');
    } finally {
        sendBtn.disabled = false;
        sendBtn.textContent = 'Send ➤';
        input.focus();
    }
}

sendBtn.addEventListener('click', send);
input.addEventListener('keydown', e => { if (e.key === 'Enter') send(); });
document.querySelectorAll('.js-quick').forEach(btn => {
    btn.addEventListener('click', () => { input.value = btn.textContent; send(); });
});

function markdownToHtml(md) {
    return md
        .replace(/^### (.+)$/gm, '<h4 style="margin:0.5rem 0 0.25rem">$1</h4>')
        .replace(/^## (.+)$/gm, '<h3 style="margin:0.5rem 0 0.25rem">$1</h3>')
        .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
        .replace(/\*(.+?)\*/g, '<em>$1</em>')
        .replace(/`(.+?)`/g, '<code style="background:rgba(0,0,0,.1);padding:0.1rem 0.3rem;border-radius:3px">$1</code>')
        .replace(/^- (.+)$/gm, '<li>$1</li>')
        .replace(/(<li>.*<\/li>)/gs, '<ul style="margin:0.25rem 0;padding-left:1.2rem">$1</ul>')
        .replace(/\n{2,}/g, '<br><br>')
        .replace(/\n/g, '<br>');
}
</script>
{% endblock %}
