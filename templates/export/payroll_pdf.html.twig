<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Payroll Slip — {{ payroll.user ? payroll.user.firstName ~ ' ' ~ payroll.user.lastName : 'Employee' }}</title>
    <style>
        @media print { body { margin: 0; } .no-print { display: none; } }
        body { font-family: 'Segoe UI', Arial, sans-serif; max-width: 800px; margin: 2rem auto; color: #1e293b; }
        .header { display: flex; justify-content: space-between; align-items: center; border-bottom: 3px solid #3b82f6; padding-bottom: 1rem; margin-bottom: 1.5rem; }
        .header h1 { margin: 0; font-size: 1.5rem; color: #3b82f6; }
        .header .meta { text-align: right; font-size: 0.875rem; color: #64748b; }
        table { width: 100%; border-collapse: collapse; margin-bottom: 1.5rem; }
        th, td { padding: 0.6rem 1rem; text-align: left; border-bottom: 1px solid #e2e8f0; }
        th { background: #f8fafc; font-weight: 600; color: #475569; font-size: 0.8rem; text-transform: uppercase; }
        .total-row td { font-weight: 700; font-size: 1.1rem; border-top: 2px solid #3b82f6; }
        .footer { margin-top: 2rem; padding-top: 1rem; border-top: 1px solid #e2e8f0; font-size: 0.8rem; color: #94a3b8; text-align: center; }
        .btn-print { display: inline-block; padding: 0.5rem 1.5rem; background: #3b82f6; color: #fff; border: none; border-radius: 6px; cursor: pointer; font-size: 0.9rem; margin-bottom: 1rem; }
    </style>
</head>
<body>
    <button class="btn-print no-print" onclick="window.print()">🖨️ Print / Save as PDF</button>

    <div class="header">
        <div>
            <h1>SynergyGig</h1>
            <div style="font-size:0.85rem;color:#64748b">Payroll Slip</div>
        </div>
        <div class="meta">
            <div><strong>Period:</strong> {{ payroll.month }}/{{ payroll.year }}</div>
            <div><strong>Generated:</strong> {{ payroll.generatedAt ? payroll.generatedAt|date('M d, Y') : 'N/A' }}</div>
            <div><strong>Status:</strong> {{ payroll.status }}</div>
        </div>
    </div>

    <table>
        <tr><th colspan="2">Employee Information</th></tr>
        <tr><td>Name</td><td>{{ payroll.user ? payroll.user.firstName ~ ' ' ~ payroll.user.lastName : 'N/A' }}</td></tr>
        <tr><td>Email</td><td>{{ payroll.user ? payroll.user.email : 'N/A' }}</td></tr>
        <tr><td>Department</td><td>{{ payroll.user and payroll.user.department ? payroll.user.department.name : 'N/A' }}</td></tr>
    </table>

    <table>
        <tr><th>Description</th><th style="text-align:right">Amount</th></tr>
        <tr><td>Base Salary</td><td style="text-align:right">{{ payroll.baseSalary|number_format(2) }}</td></tr>
        <tr><td>Hours Worked</td><td style="text-align:right">{{ payroll.totalHoursWorked|number_format(2) }} hrs</td></tr>
        <tr><td>Hourly Rate</td><td style="text-align:right">{{ payroll.hourlyRate|number_format(2) }}</td></tr>
        <tr><td style="color:#22c55e">Bonus (+)</td><td style="text-align:right;color:#22c55e">+{{ payroll.bonus|number_format(2) }}</td></tr>
        <tr><td style="color:#ef4444">Deductions (-)</td><td style="text-align:right;color:#ef4444">-{{ payroll.deductions|number_format(2) }}</td></tr>
        <tr class="total-row"><td>Net Salary</td><td style="text-align:right">{{ payroll.netSalary|number_format(2) }}</td></tr>
    </table>

    <div class="footer">
        This is a computer-generated payroll slip. &mdash; SynergyGig HR Platform &copy; {{ "now"|date('Y') }}
    </div>
</body>
</html>
