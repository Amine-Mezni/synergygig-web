{% extends 'layouts/admin.html.twig' %}

{% block page_title %}Edit Offer — {{ offer.title }}{% endblock %}

{% block header_actions %}
    <a href="{{ path('app_hr_offers') }}" class="btn btn-ghost btn-sm">Back to Review Offers</a>
{% endblock %}

{% block content %}
<div class="card" style="max-width:800px">
    <div class="card__header">
        <h3>Edit Offer</h3>
    </div>
    <div class="card__body">
        {{ form_start(form, {'attr': {'class': 'form', 'novalidate': 'novalidate'}}) }}

        <div class="form-grid" style="display:grid;grid-template-columns:1fr 1fr;gap:1rem">
            <div class="form-group" style="grid-column:1/-1">
                {{ form_label(form.title) }}
                {{ form_widget(form.title) }}
                {{ form_errors(form.title) }}
            </div>
            <div class="form-group" style="grid-column:1/-1">
                {{ form_label(form.description) }}
                {{ form_widget(form.description) }}
                {{ form_errors(form.description) }}
            </div>
            <div class="form-group">
                {{ form_label(form.offer_type) }}
                {{ form_widget(form.offer_type) }}
                {{ form_errors(form.offer_type) }}
            </div>
            <div class="form-group">
                {{ form_label(form.department) }}
                {{ form_widget(form.department) }}
                {{ form_errors(form.department) }}
            </div>
            <div class="form-group" style="grid-column:1/-1">
                {{ form_label(form.required_skills) }}
                {{ form_widget(form.required_skills) }}
                {{ form_errors(form.required_skills) }}
            </div>
            <div class="form-group">
                {{ form_label(form.location) }}
                {{ form_widget(form.location) }}
                {{ form_errors(form.location) }}
            </div>
            <div class="form-group">
                {{ form_label(form.amount) }}
                {{ form_widget(form.amount) }}
                {{ form_errors(form.amount) }}
            </div>
            <div class="form-group">
                {{ form_label(form.currency) }}
                {{ form_widget(form.currency) }}
                {{ form_errors(form.currency) }}
            </div>
            <div class="form-group">
                {{ form_label(form.start_date) }}
                {{ form_widget(form.start_date) }}
                {{ form_errors(form.start_date) }}
            </div>
            <div class="form-group">
                {{ form_label(form.end_date) }}
                {{ form_widget(form.end_date) }}
                {{ form_errors(form.end_date) }}
            </div>
        </div>

        <div style="display:flex;gap:0.5rem;margin-top:1.5rem">
            <button type="submit" class="btn btn-primary">Save Changes</button>
            <a href="{{ path('app_hr_offers') }}" class="btn btn-ghost">Cancel</a>
        </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
