{% extends 'layouts/admin.html.twig' %}

{% block page_title %}Applications{% endblock %}

{% block header_actions %}
    <a href="{{ path('app_application_new') }}" class="btn btn-primary btn-sm">+ New Application</a>
{% endblock %}

{% block content %}
{# Filter bar #}
<div class="card" style="padding:var(--space-md) var(--space-lg);margin-bottom:var(--space-lg);display:flex;align-items:center;gap:var(--space-md)">
    <form method="get" action="{{ path('app_application_index') }}" style="flex:1;display:flex;align-items:center;gap:var(--space-md)">
        <input type="text" name="q" value="{{ app.request.query.get('q') }}" placeholder="Search applicant or offer..." class="form-control" style="max-width:220px">
        <select name="status" class="form-control form-select" style="width:auto;min-width:140px">
            <option value="">All Status</option>
            <option value="PENDING" {{ app.request.query.get('status') == 'PENDING' ? 'selected' }}>Pending</option>
            <option value="REVIEWED" {{ app.request.query.get('status') == 'REVIEWED' ? 'selected' }}>Reviewed</option>
            <option value="ACCEPTED" {{ app.request.query.get('status') == 'ACCEPTED' ? 'selected' }}>Accepted</option>
            <option value="REJECTED" {{ app.request.query.get('status') == 'REJECTED' ? 'selected' }}>Rejected</option>
        </select>
        <button type="submit" class="btn btn-secondary btn-sm">Filter</button>
        {% if app.request.query.get('q') or app.request.query.get('status') %}
            <a href="{{ path('app_application_index') }}" class="btn btn-ghost btn-sm">Clear</a>
        {% endif %}
    </form>
</div>

<div class="card">
    {% if applications|length > 0 %}
    <div class="table-wrap">
        <table class="table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Applicant</th>
                    <th>Offer</th>
                    <th>AI Score</th>
                    <th>Status</th>
                    <th>Applied At</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for a in applications %}
                <tr>
                    <td class="text-muted">{{ a.id }}</td>
                    <td>
                        {% if a.applicant %}
                            <div style="display:flex;align-items:center;gap:0.5rem">
                                <div class="avatar avatar--sm">{{ a.applicant.firstName|first }}{{ a.applicant.lastName|first }}</div>
                                {{ a.applicant.firstName }} {{ a.applicant.lastName }}
                            </div>
                        {% else %}—{% endif %}
                    </td>
                    <td>{% if a.offer %}<a href="{{ path('app_offer_show', {id: a.offer.id}) }}" style="color:var(--accent-blue)">{{ a.offer.title }}</a>{% else %}—{% endif %}</td>
                    <td>
                        {% if a.aiScore is not null %}
                            <span style="font-weight:600;{% if a.aiScore >= 70 %}color:var(--color-success){% elseif a.aiScore >= 40 %}color:var(--color-warning){% else %}color:var(--color-danger){% endif %}">{{ a.aiScore }}%</span>
                        {% else %}—{% endif %}
                    </td>
                    <td>
                        {% set sc = {'PENDING': 'orange', 'REVIEWED': 'blue', 'SHORTLISTED': 'purple', 'ACCEPTED': 'green', 'REJECTED': 'red', 'WITHDRAWN': 'red'} %}
                        <span class="badge badge--{{ sc[a.status] ?? 'blue' }}">{{ a.status ?? 'N/A' }}</span>
                    </td>
                    <td>{{ a.appliedAt ? a.appliedAt|date('M d, Y H:i') : '—' }}</td>
                    <td>
                        <details class="crud-actions-menu">
                            <summary class="btn btn-ghost btn-sm" title="Actions"><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="5" r="2"/><circle cx="12" cy="12" r="2"/><circle cx="12" cy="19" r="2"/></svg></summary>
                            <div class="crud-actions-dropdown">
                                <a href="{{ path('app_application_show', {id: a.id}) }}" class="crud-action-item"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg> View</a>
                                {% if is_granted('ROLE_HR') and a.status == 'PENDING' %}
                                <a href="{{ path('app_application_accept', {id: a.id}) }}" class="crud-action-item" style="color:var(--color-success)" onclick="return confirm('Accept this application?')"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg> Accept</a>
                                <a href="{{ path('app_application_reject', {id: a.id}) }}" class="crud-action-item" style="color:var(--color-danger)" onclick="return confirm('Reject this application?')"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg> Reject</a>
                                {% endif %}
                                <a href="{{ path('app_application_edit', {id: a.id}) }}" class="crud-action-item"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg> Edit</a>
                                <form method="post" action="{{ path('app_application_delete', {id: a.id}) }}" onsubmit="return confirm('Delete this application?')">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ a.id) }}">
                                    <button type="submit" class="crud-action-item crud-action-danger"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg> Delete</button>
                                </form>
                            </div>
                        </details>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    {% else %}
    <div style="text-align:center;padding:3rem">
        <p class="text-muted">No applications yet.</p>
        <a href="{{ path('app_application_new') }}" class="btn btn-primary" style="margin-top:1rem">+ Submit Application</a>
    </div>
    {% endif %}
</div>

{% if pagination is defined %}{% include 'components/_pagination.html.twig' %}{% endif %}
{% endblock %}
