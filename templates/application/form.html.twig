{% extends 'layouts/admin.html.twig' %}

{% block page_title %}{{ application is defined and application.id ? 'Edit Application' : 'New Application' }}{% endblock %}

{% block content %}
<div class="card" style="max-width:800px">
    <div class="card__header">
        <h3>{{ application is defined and application.id ? 'Edit Application' : 'Submit Application' }}</h3>
    </div>
    <div class="card__body">
        {{ form_start(form, {'attr': {'class': 'form', 'novalidate': 'novalidate'}}) }}

        <div class="form-grid" style="display:grid;grid-template-columns:1fr 1fr;gap:1rem">
            <div class="form-group">
                {{ form_label(form.offer) }}
                {{ form_widget(form.offer, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.offer) }}
            </div>
            <div class="form-group">
                {{ form_label(form.applicant) }}
                {{ form_widget(form.applicant, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.applicant) }}
            </div>

            <div class="form-group" style="grid-column:1/-1">
                {{ form_label(form.status) }}
                {{ form_widget(form.status, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.status) }}
            </div>

            <div class="form-group" style="grid-column:1/-1">
                {{ form_label(form.cover_letter) }}
                {{ form_widget(form.cover_letter, {'attr': {'class': 'form-control', 'rows': '5'}}) }}
                {{ form_errors(form.cover_letter) }}
            </div>
        </div>

        <div style="display:flex;gap:0.5rem;margin-top:1.5rem">
            <button type="submit" class="btn btn-primary">Save Application</button>
            <a href="{{ path('app_application_index') }}" class="btn btn-ghost">Cancel</a>
        </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
