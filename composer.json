{
  "name": "synergygig/web",
  "description": "SynergyGig - HR & Workforce Management Web Platform (Symfony 6.4)",
  "type": "project",
  "license": "proprietary",
  "require": {
    "php": ">=8.1",
    "symfony/console": "6.4.*",
    "symfony/dotenv": "6.4.*",
    "symfony/framework-bundle": "6.4.*",
    "symfony/yaml": "6.4.*",
    "symfony/orm-pack": "^2.5",
    "symfony/maker-bundle": "^1.53",
    "symfony/security-bundle": "6.4.*",
    "symfony/twig-bundle": "6.4.*",
    "symfony/translation": "6.4.*",
    "symfony/validator": "6.4.*",
    "symfony/web-profiler-bundle": "6.4.*",
    "symfony/monolog-bundle": "^3.8",
    "symfony/messenger": "6.4.*",
    "symfony/http-client": "6.4.*",
    "symfony/asset": "6.4.*",
    "symfony/runtime": "6.4.*",
    "symfony/form": "^6.4",
    "symfony/mime": "^6.4",
    "symfony/mailer": "^6.4",
    "knplabs/knp-paginator-bundle": "^6.10",
    "dompdf/dompdf": "^3.1",
    "lexik/jwt-authentication-bundle": "^2.18",
    "symfonycasts/reset-password-bundle": "^1.25",
    "symfony/rate-limiter": "^6.4",
    "symfony/lock": "^6.4",
    "knpuniversity/oauth2-client-bundle": "^2.20",
    "league/oauth2-google": "^5.0",
    "league/oauth2-github": "^3.1",
    "doctrine/dbal": "^3.7 <4.0",
    "doctrine/doctrine-bundle": "^2.18",
    "symfony/property-info": "^6.4",
    "symfony/routing": "^6.4",
    "symfony/cache": "^6.4",
    "symfony/var-dumper": "^6.4",
    "symfony/var-exporter": "^6.4",
    "symfony/error-handler": "^6.4",
    "symfony/filesystem": "^6.4",
    "symfony/finder": "^6.4",
    "symfony/password-hasher": "^6.4",
    "symfony/security-core": "^6.4",
    "symfony/security-csrf": "^6.4",
    "symfony/security-http": "^6.4",
    "symfony/string": "^6.4",
    "symfony/process": "^6.4",
    "symfony/doctrine-bridge": "^6.4",
    "ahmed-bhs/doctrine-doctor": "1.0",
    "webmozart/assert": "1.11",
    "doctrine/instantiator": "1.5",
    "symfony/serializer": "6.4.37"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0",
    "symfony/debug-bundle": "6.4.*",
    "phpstan/phpstan": "^1.10",
    "phpstan/extension-installer": "^1.3"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "App\\Tests\\": "tests/"
    }
  },
  "scripts": {
  },
  "conflict": {
    "symfony/symfony": "*"
  },
  "extra": {
    "symfony": {
      "allow-contrib": true,
      "require": "6.4.*"
    }
  },
  "config": {
    "allow-plugins": {
      "phpstan/extension-installer": true,
      "symfony/runtime": true
    }
  }
}
