{
    "name": "synergygig/web-app",
    "description": "SynergyGig Web Application - Symfony 7.1",
    "type": "project",
    "require": {
        "php": ">=8.3",
        "symfony/framework-bundle": "*",
        "symfony/console": "*",
        "symfony/flex": "*"
    },
    "require-dev": {},
    "config": {
        "allow-plugins": {
            "symfony/flex": true
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    }
}
